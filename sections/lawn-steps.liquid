{%- liquid
  assign step_count = 0
-%}

<section
  id="lawn-steps-{{ section.id }}"
  class="lawn-steps"
  style="
    --steps-bg: {{ section.settings.bg_color }};
    --steps-green: {{ section.settings.green_color }};
    --steps-accent: {{ section.settings.accent_color }};
    --steps-heading: {{ section.settings.heading_color }};
    --steps-text: {{ section.settings.text_color }};
    --steps-muted: {{ section.settings.muted_color }};
    --steps-max-width: {{ section.settings.max_width }}px;
    --steps-section-height: {{ section.settings.section_height }}px;
    --steps-header-top: {{ section.settings.header_top }}px;
    --steps-side-space: {{ section.settings.side_space }}px;
    --steps-heading-width: {{ section.settings.heading_width }}px;
    --steps-lead-width: {{ section.settings.lead_width }}px;
    --steps-image-size: {{ section.settings.step_image_size }}px;
    --steps-hill-width: {{ section.settings.grass_hill_width }}px;
    --steps-hill-right: -{{ section.settings.grass_hill_push_right }}px;
    --steps-hill-bottom: -{{ section.settings.grass_hill_drop }}px;
  "
>
  <div class="lawn-steps__container">
    <div class="lawn-steps__header">
      {%- if section.settings.eyebrow != blank -%}
        <p class="lawn-steps__eyebrow">{{ section.settings.eyebrow }}</p>
      {%- endif -%}

      {%- if section.settings.heading != blank -%}
        <h2 class="lawn-steps__heading">{{ section.settings.heading }}</h2>
      {%- endif -%}

      {%- if section.settings.lead != blank -%}
        <p class="lawn-steps__lead">{{ section.settings.lead }}</p>
      {%- endif -%}
    </div>

    <div class="lawn-steps__stage">
      {%- if section.settings.show_curve -%}
        <svg class="lawn-steps__curve" viewBox="0 0 1270 824" fill="none" aria-hidden="true" preserveAspectRatio="none">
          <path
            d="M270 474 C340 488 382 468 420 405 C463 334 507 338 560 365 C620 396 625 314 690 285 C762 253 820 276 875 270 C928 264 960 268 1015 277"
            stroke="var(--steps-green)"
            stroke-width="2"
            stroke-linecap="round"
          />
        </svg>
      {%- endif -%}

      {%- for block in section.blocks -%}
        {%- if block.type == 'step' -%}
          {%- assign step_count = step_count | plus: 1 -%}

          <article class="lawn-steps__item lawn-steps__item--{{ step_count }}" {{ block.shopify_attributes }}>
            <div class="lawn-steps__image-wrap">
              <span class="lawn-steps__image-ring">
                {%- if block.settings.image != blank -%}
                  {{
                    block.settings.image
                    | image_url: width: 500
                    | image_tag:
                      loading: 'lazy',
                      class: 'lawn-steps__image',
                      alt: block.settings.image_alt,
                      width: 500,
                      height: 500
                  }}
                {%- else -%}
                  {%- assign fallback_image = 'step' | append: step_count | append: '-grass-clean.png' -%}
                  <img
                    class="lawn-steps__image"
                    src="{{ fallback_image | asset_url }}"
                    alt="{{ block.settings.image_alt | escape }}"
                    width="500"
                    height="500"
                    loading="lazy"
                  >
                {%- endif -%}
              </span>

              <span class="lawn-steps__number">
                {{ block.settings.number | default: step_count }}
              </span>
            </div>

            {%- if block.settings.title != blank -%}
              <h3 class="lawn-steps__title">{{ block.settings.title }}</h3>
            {%- endif -%}

            {%- if block.settings.text != blank -%}
              <p class="lawn-steps__text">{{ block.settings.text }}</p>
            {%- endif -%}
          </article>
        {%- endif -%}
      {%- endfor -%}
    </div>
  </div>

  {%- if section.settings.show_grass_hill -%}
    <div class="lawn-steps__hill" aria-hidden="true">
      {%- if section.settings.grass_hill_image != blank -%}
        {{
          section.settings.grass_hill_image
          | image_url: width: 1200
          | image_tag:
            loading: 'lazy',
            class: 'lawn-steps__hill-img',
            alt: '',
            width: 1200,
            height: 1200
        }}
      {%- else -%}
        <img
          class="lawn-steps__hill-img"
          src="{{ 'grass-hill.png' | asset_url }}"
          alt=""
          width="1200"
          height="1200"
          loading="lazy"
        >
      {%- endif -%}
    </div>
  {%- endif -%}
</section>

<style>
  #lawn-steps-{{ section.id }} {
    position: relative;
    isolation: isolate;
    overflow: hidden;
    min-height: var(--steps-section-height);
    background: var(--steps-bg);
    color: var(--steps-text);
  }

  #lawn-steps-{{ section.id }} * {
    box-sizing: border-box;
  }

  #lawn-steps-{{ section.id }} .lawn-steps__container {
    position: relative;
    z-index: 2;
    width: min(100%, var(--steps-max-width));
    min-height: var(--steps-section-height);
    margin: 0 auto;
  }

  #lawn-steps-{{ section.id }} .lawn-steps__header {
    position: absolute;
    z-index: 6;
    top: var(--steps-header-top);
    left: var(--steps-side-space);
    width: var(--steps-heading-width);
    max-width: calc(100% - 160px);
  }

  #lawn-steps-{{ section.id }} .lawn-steps__eyebrow {
    margin: 0 0 14px;
    color: var(--steps-green);
    font-family: "Poppins", var(--font-body-family), sans-serif;
    font-size: 16px;
    line-height: 1.2;
    font-weight: 500;
    letter-spacing: 0;
  }

  #lawn-steps-{{ section.id }} .lawn-steps__heading {
    margin: 0;
    width: var(--steps-heading-width);
    max-width: 100%;
    color: var(--steps-heading);
    font-family: "Clash Grotesk", "Poppins", var(--font-heading-family), sans-serif;
    font-size: 52px;
    line-height: 64px;
    font-weight: 600;
    letter-spacing: -0.4px;
  }

  #lawn-steps-{{ section.id }} .lawn-steps__lead {
    margin: 24px 0 0;
    width: var(--steps-lead-width);
    max-width: 100%;
    color: var(--steps-muted);
    font-family: "Poppins", var(--font-body-family), sans-serif;
    font-size: 19px;
    line-height: 28px;
    font-weight: 500;
    letter-spacing: 0;
  }

  #lawn-steps-{{ section.id }} .lawn-steps__stage {
    position: absolute;
    inset: 0;
    z-index: 4;
  }

  #lawn-steps-{{ section.id }} .lawn-steps__curve {
    position: absolute;
    inset: 0;
    z-index: 1;
    width: 100%;
    height: 100%;
    pointer-events: none;
  }

  #lawn-steps-{{ section.id }} .lawn-steps__item {
    position: absolute;
    z-index: 4;
    width: 385px;
    text-align: center;
  }

  #lawn-steps-{{ section.id }} .lawn-steps__item--1 {
    left: 80px;
    top: 366px;
  }

  #lawn-steps-{{ section.id }} .lawn-steps__item--2 {
    left: 438px;
    top: 286px;
  }

  #lawn-steps-{{ section.id }} .lawn-steps__item--3 {
    left: 798px;
    top: 206px;
  }

  #lawn-steps-{{ section.id }} .lawn-steps__image-wrap {
    position: relative;
    width: var(--steps-image-size);
    height: var(--steps-image-size);
    margin: 0 auto 38px;
  }

  #lawn-steps-{{ section.id }} .lawn-steps__image-ring {
    display: block;
    width: 100%;
    height: 100%;
    padding: 8px;
    border: 1.5px dashed var(--steps-green);
    border-radius: 50%;
    background: #ffffff;
  }

  #lawn-steps-{{ section.id }} .lawn-steps__image {
    display: block;
    width: 100%;
    height: 100%;
    border-radius: 50%;
    object-fit: cover;
  }

  #lawn-steps-{{ section.id }} .lawn-steps__number {
    position: absolute;
    left: 50%;
    bottom: -18px;
    display: grid;
    place-items: center;
    width: 44px;
    height: 44px;
    transform: translateX(-50%);
    border-radius: 999px;
    background: var(--steps-accent);
    color: #ffffff;
    font-family: "Clash Grotesk", "Poppins", var(--font-heading-family), sans-serif;
    font-size: 32px;
    line-height: 38px;
    font-weight: 600;
    letter-spacing: -0.4px;
    box-shadow: 0 8px 18px rgba(252, 88, 16, 0.18);
  }

  #lawn-steps-{{ section.id }} .lawn-steps__title {
    margin: 0;
    color: var(--steps-heading);
    font-family: "Clash Grotesk", "Poppins", var(--font-heading-family), sans-serif;
    font-size: 32px;
    line-height: 38px;
    font-weight: 600;
    letter-spacing: -0.4px;
  }

  #lawn-steps-{{ section.id }} .lawn-steps__text {
    margin: 16px auto 0;
    max-width: 385px;
    color: var(--steps-text);
    font-family: "Poppins", var(--font-body-family), sans-serif;
    font-size: 19px;
    line-height: 28px;
    font-weight: 500;
    letter-spacing: 0;
  }

  #lawn-steps-{{ section.id }} .lawn-steps__hill {
    position: absolute;
    z-index: 1;
    right: var(--steps-hill-right);
    bottom: var(--steps-hill-bottom);
    width: var(--steps-hill-width);
    max-width: 58vw;
    pointer-events: none;
    line-height: 0;
  }

  #lawn-steps-{{ section.id }} .lawn-steps__hill-img {
    display: block;
    width: 100%;
    height: auto;
  }

  @media screen and (max-width: 1240px) {
    #lawn-steps-{{ section.id }} .lawn-steps__container {
      transform: scale(0.88);
      transform-origin: top center;
    }

    #lawn-steps-{{ section.id }} {
      min-height: calc(var(--steps-section-height) * 0.88);
    }

    #lawn-steps-{{ section.id }} .lawn-steps__hill {
      transform: scale(0.88);
      transform-origin: right bottom;
    }
  }

  @media screen and (max-width: 989px) {
    #lawn-steps-{{ section.id }} {
      min-height: auto;
      padding: 58px 20px 72px;
    }

    #lawn-steps-{{ section.id }} .lawn-steps__container {
      width: 100%;
      min-height: auto;
      transform: none;
    }

    #lawn-steps-{{ section.id }} .lawn-steps__header {
      position: relative;
      top: auto;
      left: auto;
      width: 100%;
      max-width: 100%;
    }

    #lawn-steps-{{ section.id }} .lawn-steps__heading {
      width: 100%;
      font-size: 40px;
      line-height: 48px;
    }

    #lawn-steps-{{ section.id }} .lawn-steps__lead {
      width: 100%;
      font-size: 16px;
      line-height: 25px;
    }

    #lawn-steps-{{ section.id }} .lawn-steps__stage {
      position: relative;
      inset: auto;
      display: grid;
      gap: 48px;
      margin-top: 56px;
    }

    #lawn-steps-{{ section.id }} .lawn-steps__curve,
    #lawn-steps-{{ section.id }} .lawn-steps__hill {
      display: none;
    }

    #lawn-steps-{{ section.id }} .lawn-steps__item,
    #lawn-steps-{{ section.id }} .lawn-steps__item--1,
    #lawn-steps-{{ section.id }} .lawn-steps__item--2,
    #lawn-steps-{{ section.id }} .lawn-steps__item--3 {
      position: relative;
      top: auto;
      left: auto;
      width: min(100%, 385px);
      margin: 0 auto;
    }

    #lawn-steps-{{ section.id }} .lawn-steps__title {
      font-size: 30px;
      line-height: 36px;
    }

    #lawn-steps-{{ section.id }} .lawn-steps__text {
      font-size: 16px;
      line-height: 25px;
    }
  }

  @media screen and (max-width: 575px) {
    #lawn-steps-{{ section.id }} {
      padding-top: 46px;
      padding-bottom: 58px;
    }

    #lawn-steps-{{ section.id }} .lawn-steps__eyebrow {
      font-size: 14px;
    }

    #lawn-steps-{{ section.id }} .lawn-steps__heading {
      font-size: 32px;
      line-height: 38px;
    }

    #lawn-steps-{{ section.id }} .lawn-steps__lead {
      margin-top: 18px;
      font-size: 15px;
      line-height: 24px;
    }

    #lawn-steps-{{ section.id }} .lawn-steps__stage {
      margin-top: 42px;
      gap: 42px;
    }

    #lawn-steps-{{ section.id }} .lawn-steps__image-wrap {
      width: 148px;
      height: 148px;
      margin-bottom: 32px;
    }

    #lawn-steps-{{ section.id }} .lawn-steps__number {
      width: 40px;
      height: 40px;
      bottom: -16px;
      font-size: 26px;
      line-height: 32px;
    }

    #lawn-steps-{{ section.id }} .lawn-steps__title {
      font-size: 26px;
      line-height: 32px;
    }

    #lawn-steps-{{ section.id }} .lawn-steps__text {
      font-size: 15px;
      line-height: 24px;
    }
  }
</style>

{% schema %}
{
  "name": "Lawn — Steps",
  "tag": "section",
  "class": "lawn-steps-section",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "How It Words"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "How Envy Works To Build Better Lawns"
    },
    {
      "type": "textarea",
      "id": "lead",
      "label": "Lead text",
      "default": "This Blend Works In Three Simple Steps To Grow Thicker, Greener, Stronger Lawns Without Complexity Or Confusion."
    },
    {
      "type": "header",
      "content": "Images"
    },
    {
      "type": "checkbox",
      "id": "show_curve",
      "label": "Show curved connector line",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_grass_hill",
      "label": "Show bottom grass graphic",
      "default": true
    },
    {
      "type": "image_picker",
      "id": "grass_hill_image",
      "label": "Bottom grass graphic"
    },
    {
      "type": "header",
      "content": "Desktop layout"
    },
    {
      "type": "range",
      "id": "max_width",
      "label": "Content width",
      "min": 1000,
      "max": 1500,
      "step": 10,
      "unit": "px",
      "default": 1270
    },
    {
      "type": "range",
      "id": "section_height",
      "label": "Section height",
      "min": 650,
      "max": 950,
      "step": 10,
      "unit": "px",
      "default": 820
    },
    {
      "type": "range",
      "id": "header_top",
      "label": "Header top position",
      "min": 40,
      "max": 160,
      "step": 4,
      "unit": "px",
      "default": 104
    },
    {
      "type": "range",
      "id": "side_space",
      "label": "Side spacing",
      "min": 40,
      "max": 140,
      "step": 4,
      "unit": "px",
      "default": 80
    },
    {
      "type": "range",
      "id": "heading_width",
      "label": "Heading width",
      "min": 500,
      "max": 800,
      "step": 10,
      "unit": "px",
      "default": 700
    },
    {
      "type": "range",
      "id": "lead_width",
      "label": "Lead width",
      "min": 500,
      "max": 800,
      "step": 10,
      "unit": "px",
      "default": 700
    },
    {
      "type": "range",
      "id": "step_image_size",
      "label": "Step image size",
      "min": 120,
      "max": 220,
      "step": 2,
      "unit": "px",
      "default": 194
    },
    {
      "type": "range",
      "id": "grass_hill_width",
      "label": "Bottom grass width",
      "min": 300,
      "max": 800,
      "step": 10,
      "unit": "px",
      "default": 560
    },
    {
      "type": "range",
      "id": "grass_hill_push_right",
      "label": "Bottom grass push right",
      "min": 0,
      "max": 200,
      "step": 5,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "grass_hill_drop",
      "label": "Bottom grass drop",
      "min": 0,
      "max": 160,
      "step": 5,
      "unit": "px",
      "default": 0
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background",
      "default": "#FFFFFF"
    },
    {
      "type": "color",
      "id": "green_color",
      "label": "Primary green",
      "default": "#12B76A"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Number badge",
      "default": "#FC5810"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading color",
      "default": "#043320"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Body text color",
      "default": "#42473E"
    },
    {
      "type": "color",
      "id": "muted_color",
      "label": "Lead text color",
      "default": "#124236"
    }
  ],
  "max_blocks": 3,
  "blocks": [
    {
      "type": "step",
      "name": "Step",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Step image"
        },
        {
          "type": "text",
          "id": "image_alt",
          "label": "Image alt text",
          "default": "Grass growth step"
        },
        {
          "type": "text",
          "id": "number",
          "label": "Number",
          "default": "1"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Fast Germination"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Description",
          "default": "Quick Early Growth Fills Bare Areas Fast And Helps Reduce Weed Invasion During Establishment Stages."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Lawn — Steps",
      "blocks": [
        {
          "type": "step",
          "settings": {
            "number": "1",
            "title": "Fast Germination",
            "text": "Quick Early Growth Fills Bare Areas Fast And Helps Reduce Weed Invasion During Establishment Stages."
          }
        },
        {
          "type": "step",
          "settings": {
            "number": "2",
            "title": "Deep Roots",
            "text": "Stronger Root Systems Improve Drought Tolerance, Enhance Nutrient Uptake, And Support Long-Term Lawn Health."
          }
        },
        {
          "type": "step",
          "settings": {
            "number": "3",
            "title": "Thick Growth",
            "text": "Dense Turf Growth Crowds Out Weeds Naturally And Creates A Smooth, Full, Uniform Lawn Appearance."
          }
        }
      ]
    }
  ]
}
{% endschema %}