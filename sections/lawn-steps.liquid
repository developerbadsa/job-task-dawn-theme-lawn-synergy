{%- liquid
  assign step_count = 0
-%}

<section
  id="lawn-steps-{{ section.id }}"
  class="lawn-steps"
  style="
    --steps-bg: {{ section.settings.bg_color }};
    --steps-green: {{ section.settings.green_color }};
    --steps-accent: {{ section.settings.accent_color }};
    --steps-text: {{ section.settings.text_color }};
    --steps-muted: {{ section.settings.muted_color }};
    --steps-max-width: {{ section.settings.max_width }}px;
    --steps-section-height: {{ section.settings.section_height }}px;
    --steps-padding-top: {{ section.settings.padding_top }}px;
    --steps-padding-bottom: {{ section.settings.padding_bottom }}px;
    --steps-side-padding: {{ section.settings.side_padding }}px;
    --steps-image-size: {{ section.settings.step_image_size }}px;
    --steps-ring-gap: {{ section.settings.ring_gap }}px;
    --steps-curve-width: {{ section.settings.curve_width }}px;
    --steps-curve-left: {{ section.settings.curve_left }}px;
    --steps-curve-top: {{ section.settings.curve_top }}px;
    --steps-hill-width: {{ section.settings.grass_hill_width }}px;
    --steps-hill-bottom: -{{ section.settings.grass_hill_drop }}px;
    --steps-hill-shift: {{ section.settings.grass_hill_push_right }}px;
  "
>
  <div class="lawn-steps__container">
    <div class="lawn-steps__header">
      {%- if section.settings.eyebrow != blank -%}
        <p class="lawn-steps__eyebrow">{{ section.settings.eyebrow }}</p>
      {%- endif -%}

      {%- if section.settings.heading != blank -%}
        <h2 class="lawn-steps__heading">{{ section.settings.heading }}</h2>
      {%- endif -%}

      {%- if section.settings.lead != blank -%}
        <p class="lawn-steps__lead">{{ section.settings.lead }}</p>
      {%- endif -%}
    </div>

    <div class="lawn-steps__stage">
      {%- if section.settings.show_curve -%}
        <svg class="lawn-steps__curve" viewBox="0 0 880 250" fill="none" aria-hidden="true" preserveAspectRatio="none">
          <path
            d="M2 180 C80 200 130 176 174 109 C216 44 274 40 322 78 C365 112 382 120 424 62 C488 -22 585 26 690 24 C760 23 812 5 878 28"
            stroke="var(--steps-green)"
            stroke-width="2"
            stroke-linecap="round"
          />
        </svg>
      {%- endif -%}

      {%- for block in section.blocks -%}
        {%- if block.type == 'step' -%}
          {%- assign step_count = step_count | plus: 1 -%}

          <article class="lawn-steps__item lawn-steps__item--{{ step_count }}" {{ block.shopify_attributes }}>
            <div class="lawn-steps__image-wrap">
              <span class="lawn-steps__image-ring">
                {%- if block.settings.image != blank -%}
                  {{
                    block.settings.image
                    | image_url: width: 500
                    | image_tag:
                      loading: 'lazy',
                      class: 'lawn-steps__image',
                      alt: block.settings.image_alt,
                      width: 500,
                      height: 500
                  }}
                {%- else -%}
                  {%- assign fallback_image = 'step' | append: step_count | append: '-grass-clean.png' -%}
                  <img
                    class="lawn-steps__image"
                    src="{{ fallback_image | asset_url }}"
                    alt="{{ block.settings.image_alt | escape }}"
                    width="500"
                    height="500"
                    loading="lazy"
                  >
                {%- endif -%}
              </span>

              <span class="lawn-steps__number">
                {{ block.settings.number | default: step_count }}
              </span>
            </div>

            {%- if block.settings.title != blank -%}
              <h3 class="lawn-steps__title">{{ block.settings.title }}</h3>
            {%- endif -%}

            {%- if block.settings.text != blank -%}
              <p class="lawn-steps__text">{{ block.settings.text }}</p>
            {%- endif -%}
          </article>
        {%- endif -%}
      {%- endfor -%}
    </div>
  </div>

  {%- if section.settings.show_grass_hill -%}
    <div class="lawn-steps__hill" aria-hidden="true">
      {%- if section.settings.grass_hill_image != blank -%}
        {{
          section.settings.grass_hill_image
          | image_url: width: 1000
          | image_tag:
            loading: 'lazy',
            class: 'lawn-steps__hill-img',
            alt: '',
            width: 1000,
            height: 1000
        }}
      {%- else -%}
        <img
          class="lawn-steps__hill-img"
          src="{{ 'grass-hill.png' | asset_url }}"
          alt=""
          width="1000"
          height="1000"
          loading="lazy"
        >
      {%- endif -%}
    </div>
  {%- endif -%}
</section>

<style>
  #lawn-steps-{{ section.id }} {
    position: relative;
    isolation: isolate;
    overflow: hidden;
    min-height: var(--steps-section-height);
    padding-top: var(--steps-padding-top);
    padding-bottom: var(--steps-padding-bottom);
    background: var(--steps-bg);
    color: var(--steps-text);
  }

  #lawn-steps-{{ section.id }} .lawn-steps__container {
    position: relative;
    z-index: 3;
    width: min(100% - calc(var(--steps-side-padding) * 2), var(--steps-max-width));
    min-height: calc(var(--steps-section-height) - var(--steps-padding-top) - var(--steps-padding-bottom));
    margin-inline: auto;
  }

  #lawn-steps-{{ section.id }} .lawn-steps__header {
    position: relative;
    z-index: 8;
    max-width: 704px;
  }

  #lawn-steps-{{ section.id }} .lawn-steps__eyebrow {
    margin: 0 0 12px;
    color: var(--steps-green);
    font-size: 15px;
    line-height: 1.2;
    font-weight: 600;
    letter-spacing: -0.02em;
  }

  #lawn-steps-{{ section.id }} .lawn-steps__heading {
    margin: 0;
    max-width: 704px;
    color: var(--steps-text);
    font-size: 52px;
    line-height: 64px;
    font-weight: 700;
    letter-spacing: -0.4px;
  }

  #lawn-steps-{{ section.id }} .lawn-steps__lead {
    margin: 22px 0 0;
    max-width: 704px;
    color: var(--steps-muted);
    font-size: 19px;
    line-height: 28px;
    font-weight: 500;
    letter-spacing: 0;
  }

  #lawn-steps-{{ section.id }} .lawn-steps__stage {
    position: absolute;
    inset: 0;
    z-index: 5;
  }

  #lawn-steps-{{ section.id }} .lawn-steps__curve {
    position: absolute;
    z-index: 1;
    left: var(--steps-curve-left);
    top: var(--steps-curve-top);
    width: var(--steps-curve-width);
    height: 250px;
    pointer-events: none;
  }

  #lawn-steps-{{ section.id }} .lawn-steps__item {
    position: absolute;
    z-index: 4;
    width: 385px;
    text-align: center;
  }

  #lawn-steps-{{ section.id }} .lawn-steps__item--1 {
    left: 74px;
    top: 322px;
  }

  #lawn-steps-{{ section.id }} .lawn-steps__item--2 {
    left: 475px;
    top: 242px;
  }

  #lawn-steps-{{ section.id }} .lawn-steps__item--3 {
    left: 872px;
    top: 152px;
  }

  #lawn-steps-{{ section.id }} .lawn-steps__image-wrap {
    position: relative;
    width: var(--steps-image-size);
    height: var(--steps-image-size);
    margin: 0 auto 46px;
  }

  #lawn-steps-{{ section.id }} .lawn-steps__image-ring {
    display: block;
    width: 100%;
    height: 100%;
    padding: var(--steps-ring-gap);
    border: 1.5px dashed var(--steps-green);
    border-radius: 50%;
    background: #ffffff;
  }

  #lawn-steps-{{ section.id }} .lawn-steps__image {
    display: block;
    width: 100%;
    height: 100%;
    border-radius: 50%;
    object-fit: cover;
  }

  #lawn-steps-{{ section.id }} .lawn-steps__number {
    position: absolute;
    right: 45px;
    bottom: -18px;
    display: grid;
    place-items: center;
    width: 44px;
    height: 44px;
    border-radius: 999px;
    background: var(--steps-accent);
    color: #ffffff;
    font-size: 25px;
    line-height: 1;
    font-weight: 700;
    letter-spacing: -0.4px;
  }

  #lawn-steps-{{ section.id }} .lawn-steps__title {
    margin: 0;
    color: var(--steps-text);
    font-size: 32px;
    line-height: 38px;
    font-weight: 700;
    letter-spacing: -0.4px;
  }

  #lawn-steps-{{ section.id }} .lawn-steps__text {
    margin: 15px auto 0;
    max-width: 385px;
    color: #42473e;
    font-size: 19px;
    line-height: 28px;
    font-weight: 500;
    letter-spacing: 0;
  }

  #lawn-steps-{{ section.id }} .lawn-steps__hill {
    position: absolute;
    z-index: 2;
    right: 0;
    bottom: var(--steps-hill-bottom);
    width: var(--steps-hill-width);
    transform: translateX(var(--steps-hill-shift));
    pointer-events: none;
  }

  #lawn-steps-{{ section.id }} .lawn-steps__hill-img {
    display: block;
    width: 100%;
    height: auto;
  }

  @media screen and (max-width: 1320px) {
    #lawn-steps-{{ section.id }} .lawn-steps__item--1 {
      left: 2%;
    }

    #lawn-steps-{{ section.id }} .lawn-steps__item--2 {
      left: 34%;
    }

    #lawn-steps-{{ section.id }} .lawn-steps__item--3 {
      left: auto;
      right: 3%;
    }

    #lawn-steps-{{ section.id }} .lawn-steps__curve {
      left: 17%;
      width: 68%;
    }
  }

  @media screen and (max-width: 989px) {
    #lawn-steps-{{ section.id }} {
      min-height: auto;
      padding-top: 56px;
      padding-bottom: 70px;
    }

    #lawn-steps-{{ section.id }} .lawn-steps__container {
      min-height: auto;
    }

    #lawn-steps-{{ section.id }} .lawn-steps__header {
      max-width: 100%;
    }

    #lawn-steps-{{ section.id }} .lawn-steps__heading {
      max-width: 100%;
      font-size: 40px;
      line-height: 48px;
    }

    #lawn-steps-{{ section.id }} .lawn-steps__lead {
      max-width: 100%;
      font-size: 16px;
      line-height: 25px;
    }

    #lawn-steps-{{ section.id }} .lawn-steps__stage {
      position: relative;
      inset: auto;
      display: grid;
      grid-template-columns: 1fr;
      gap: 52px;
      margin-top: 56px;
    }

    #lawn-steps-{{ section.id }} .lawn-steps__curve,
    #lawn-steps-{{ section.id }} .lawn-steps__hill {
      display: none;
    }

    #lawn-steps-{{ section.id }} .lawn-steps__item,
    #lawn-steps-{{ section.id }} .lawn-steps__item--1,
    #lawn-steps-{{ section.id }} .lawn-steps__item--2,
    #lawn-steps-{{ section.id }} .lawn-steps__item--3 {
      position: relative;
      inset: auto;
      width: min(100%, 385px);
      margin-inline: auto;
    }

    #lawn-steps-{{ section.id }} .lawn-steps__image-wrap {
      width: 174px;
      height: 174px;
      margin-bottom: 36px;
    }

    #lawn-steps-{{ section.id }} .lawn-steps__title {
      font-size: 28px;
      line-height: 34px;
    }

    #lawn-steps-{{ section.id }} .lawn-steps__text {
      font-size: 16px;
      line-height: 25px;
    }
  }

  @media screen and (max-width: 575px) {
    #lawn-steps-{{ section.id }} {
      padding-top: 44px;
      padding-bottom: 58px;
    }

    #lawn-steps-{{ section.id }} .lawn-steps__heading {
      font-size: 32px;
      line-height: 39px;
    }

    #lawn-steps-{{ section.id }} .lawn-steps__lead {
      margin-top: 16px;
      font-size: 15px;
      line-height: 24px;
    }

    #lawn-steps-{{ section.id }} .lawn-steps__stage {
      margin-top: 42px;
      gap: 44px;
    }

    #lawn-steps-{{ section.id }} .lawn-steps__image-wrap {
      width: 154px;
      height: 154px;
      margin-bottom: 32px;
    }

    #lawn-steps-{{ section.id }} .lawn-steps__number {
      right: 32px;
      width: 40px;
      height: 40px;
      font-size: 22px;
    }

    #lawn-steps-{{ section.id }} .lawn-steps__title {
      font-size: 25px;
      line-height: 31px;
    }

    #lawn-steps-{{ section.id }} .lawn-steps__text {
      max-width: 320px;
      font-size: 15px;
      line-height: 23px;
    }
  }
</style>

{% schema %}
{
  "name": "Lawn — Steps",
  "tag": "section",
  "class": "lawn-steps-section",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "How It Works"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "How Envy Works To Build Better Lawns"
    },
    {
      "type": "textarea",
      "id": "lead",
      "label": "Lead text",
      "default": "This Blend Works In Three Simple Steps To Grow Thicker, Greener, Stronger Lawns Without Complexity Or Confusion."
    },
    {
      "type": "header",
      "content": "Images"
    },
    {
      "type": "checkbox",
      "id": "show_curve",
      "label": "Show curved connector line",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_grass_hill",
      "label": "Show bottom grass graphic",
      "default": true
    },
    {
      "type": "image_picker",
      "id": "grass_hill_image",
      "label": "Bottom grass graphic"
    },
    {
      "type": "header",
      "content": "Desktop layout"
    },
    {
      "type": "range",
      "id": "max_width",
      "label": "Content width",
      "min": 960,
      "max": 1500,
      "step": 10,
      "unit": "px",
      "default": 1270
    },
    {
      "type": "range",
      "id": "section_height",
      "label": "Section height",
      "min": 620,
      "max": 920,
      "step": 10,
      "unit": "px",
      "default": 820
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Top spacing",
      "min": 40,
      "max": 140,
      "step": 5,
      "unit": "px",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Bottom spacing",
      "min": 0,
      "max": 120,
      "step": 5,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "side_padding",
      "label": "Side spacing",
      "min": 16,
      "max": 80,
      "step": 4,
      "unit": "px",
      "default": 48
    },
    {
      "type": "range",
      "id": "step_image_size",
      "label": "Step image size",
      "min": 150,
      "max": 220,
      "step": 2,
      "unit": "px",
      "default": 194
    },
    {
      "type": "range",
      "id": "ring_gap",
      "label": "Image ring gap",
      "min": 4,
      "max": 12,
      "step": 1,
      "unit": "px",
      "default": 7
    },
    {
      "type": "range",
      "id": "curve_width",
      "label": "Curve width",
      "min": 600,
      "max": 980,
      "step": 10,
      "unit": "px",
      "default": 880
    },
    {
      "type": "range",
      "id": "curve_left",
      "label": "Curve left position",
      "min": 120,
      "max": 360,
      "step": 5,
      "unit": "px",
      "default": 210
    },
    {
      "type": "range",
      "id": "curve_top",
      "label": "Curve top position",
      "min": 180,
      "max": 360,
      "step": 5,
      "unit": "px",
      "default": 275
    },
    {
      "type": "range",
      "id": "grass_hill_width",
      "label": "Bottom grass width",
      "min": 380,
      "max": 760,
      "step": 10,
      "unit": "px",
      "default": 620
    },
    {
      "type": "range",
      "id": "grass_hill_push_right",
      "label": "Bottom grass push right",
      "min": 0,
      "max": 200,
      "step": 5,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "grass_hill_drop",
      "label": "Bottom grass drop",
      "min": 0,
      "max": 120,
      "step": 5,
      "unit": "px",
      "default": 0
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background",
      "default": "#FFFFFF"
    },
    {
      "type": "color",
      "id": "green_color",
      "label": "Primary green",
      "default": "#20B26B"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Number badge",
      "default": "#FC5810"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Heading text",
      "default": "#043320"
    },
    {
      "type": "color",
      "id": "muted_color",
      "label": "Lead text",
      "default": "#42473E"
    }
  ],
  "max_blocks": 3,
  "blocks": [
    {
      "type": "step",
      "name": "Step",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Step image"
        },
        {
          "type": "text",
          "id": "image_alt",
          "label": "Image alt text",
          "default": "Grass growth step"
        },
        {
          "type": "text",
          "id": "number",
          "label": "Number",
          "default": "1"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Fast Germination"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Description",
          "default": "Quick Early Growth Fills Bare Areas Fast And Helps Reduce Weed Invasion During Establishment Stages."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Lawn — Steps",
      "blocks": [
        {
          "type": "step",
          "settings": {
            "number": "1",
            "title": "Fast Germination",
            "text": "Quick Early Growth Fills Bare Areas Fast And Helps Reduce Weed Invasion During Establishment Stages."
          }
        },
        {
          "type": "step",
          "settings": {
            "number": "2",
            "title": "Deep Roots",
            "text": "Stronger Root Systems Improve Drought Tolerance, Enhance Nutrient Uptake, And Support Long-Term Lawn Health."
          }
        },
        {
          "type": "step",
          "settings": {
            "number": "3",
            "title": "Thick Growth",
            "text": "Dense Turf Growth Crowds Out Weeds Naturally And Creates A Smooth, Full, Uniform Lawn Appearance."
          }
        }
      ]
    }
  ]
}
{% endschema %}