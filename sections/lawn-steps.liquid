{%- liquid
  assign step_count = 0
-%}

<section
  id="lawn-steps-{{ section.id }}"
  class="lawn-steps"
  style="
    --steps-bg: {{ section.settings.bg_color }};
    --steps-green: {{ section.settings.green_color }};
    --steps-accent: {{ section.settings.accent_color }};
    --steps-text: {{ section.settings.text_color }};
    --steps-muted: {{ section.settings.muted_color }};
    --steps-max-width: {{ section.settings.max_width }}px;
    --steps-section-height: {{ section.settings.section_height }}px;
    --steps-padding-top: {{ section.settings.padding_top }}px;
    --steps-padding-bottom: {{ section.settings.padding_bottom }}px;
    --steps-side-padding: {{ section.settings.side_padding }}px;
    --steps-image-size: {{ section.settings.step_image_size }}px;
    --steps-curve-width: {{ section.settings.curve_width }}px;
    --steps-curve-left: {{ section.settings.curve_left }}px;
    --steps-curve-top: {{ section.settings.curve_top }}px;
    --steps-hill-width: {{ section.settings.grass_hill_width }}px;
    --steps-hill-right: -{{ section.settings.grass_hill_push_right }}px;
    --steps-hill-bottom: -{{ section.settings.grass_hill_drop }}px;
  "
>
  <div class="lawn-steps__container">
    <div class="lawn-steps__header">
      {%- if section.settings.eyebrow != blank -%}
        <p class="lawn-steps__eyebrow">{{ section.settings.eyebrow }}</p>
      {%- endif -%}

      {%- if section.settings.heading != blank -%}
        <h2 class="lawn-steps__heading">{{ section.settings.heading }}</h2>
      {%- endif -%}

      {%- if section.settings.lead != blank -%}
        <p class="lawn-steps__lead">{{ section.settings.lead }}</p>
      {%- endif -%}
    </div>

    <div class="lawn-steps__stage">
      {%- if section.settings.show_curve -%}
        <svg class="lawn-steps__curve" viewBox="0 0 770 250" fill="none" aria-hidden="true" preserveAspectRatio="none">
          <path
            d="M2 176 C86 197 145 192 198 113 C246 40 300 31 366 91 C424 143 440 157 505 72 C575 -20 650 31 768 17"
            stroke="var(--steps-green)"
            stroke-width="2"
            stroke-linecap="round"
          />
        </svg>
      {%- endif -%}

      {%- for block in section.blocks -%}
        {%- if block.type == 'step' -%}
          {%- assign step_count = step_count | plus: 1 -%}

          <article class="lawn-steps__item lawn-steps__item--{{ step_count }}" {{ block.shopify_attributes }}>
            <div class="lawn-steps__image-wrap">
              <span class="lawn-steps__image-ring">
                {%- if block.settings.image != blank -%}
                  {{
                    block.settings.image
                    | image_url: width: 500
                    | image_tag:
                      loading: 'lazy',
                      class: 'lawn-steps__image',
                      alt: block.settings.image_alt,
                      width: 500,
                      height: 500
                  }}
                {%- else -%}
                  {%- assign fallback_image = 'step' | append: step_count | append: '-grass-clean.png' -%}
                  <img
                    class="lawn-steps__image"
                    src="{{ fallback_image | asset_url }}"
                    alt="{{ block.settings.image_alt | escape }}"
                    width="500"
                    height="500"
                    loading="lazy"
                  >
                {%- endif -%}
              </span>

              <span class="lawn-steps__number">
                {{ block.settings.number | default: step_count }}
              </span>
            </div>

            {%- if block.settings.title != blank -%}
              <h3 class="lawn-steps__title">{{ block.settings.title }}</h3>
            {%- endif -%}

            {%- if block.settings.text != blank -%}
              <p class="lawn-steps__text">{{ block.settings.text }}</p>
            {%- endif -%}
          </article>
        {%- endif -%}
      {%- endfor -%}
    </div>
  </div>

  {%- if section.settings.show_grass_hill -%}
    <div class="lawn-steps__hill" aria-hidden="true">
      {%- if section.settings.grass_hill_image != blank -%}
        {{
          section.settings.grass_hill_image
          | image_url: width: 1000
          | image_tag:
            loading: 'lazy',
            class: 'lawn-steps__hill-img',
            alt: '',
            width: 1000,
            height: 1000
        }}
      {%- else -%}
        <img
          class="lawn-steps__hill-img"
          src="{{ 'grass-hill.png' | asset_url }}"
          alt=""
          width="1000"
          height="1000"
          loading="lazy"
        >
      {%- endif -%}
    </div>
  {%- endif -%}
</section>

<style>
  #lawn-steps-{{ section.id }} {
    position: relative;
    isolation: isolate;
    overflow: hidden;
    min-height: var(--steps-section-height);
    padding-top: var(--steps-padding-top);
    padding-bottom: var(--steps-padding-bottom);
    background: var(--steps-bg);
    color: var(--steps-text);
  }

  #lawn-steps-{{ section.id }} .lawn-steps__container {
    position: relative;
    z-index: 2;
    width: min(100% - calc(var(--steps-side-padding) * 2), var(--steps-max-width));
    min-height: calc(var(--steps-section-height) - var(--steps-padding-top) - var(--steps-padding-bottom));
    margin-inline: auto;
  }

  #lawn-steps-{{ section.id }} .lawn-steps__header {
    position: relative;
    z-index: 5;
    max-width: 650px;
  }

  #lawn-steps-{{ section.id }} .lawn-steps__eyebrow {
    margin: 0 0 12px;
    color: var(--steps-green);
    font-size: 15px;
    line-height: 1.2;
    font-weight: 600;
    letter-spacing: -0.02em;
  }

  #lawn-steps-{{ section.id }} .lawn-steps__heading {
    margin: 0;
    max-width: 590px;
    color: var(--steps-text);
    font-size: clamp(38px, 3.35vw, 50px);
    line-height: 1.12;
    font-weight: 850;
    letter-spacing: -0.05em;
  }

  #lawn-steps-{{ section.id }} .lawn-steps__lead {
    margin: 22px 0 0;
    max-width: 660px;
    color: var(--steps-muted);
    font-size: 17px;
    line-height: 1.55;
    font-weight: 500;
    letter-spacing: -0.015em;
  }

  #lawn-steps-{{ section.id }} .lawn-steps__stage {
    position: absolute;
    inset: 0;
    z-index: 3;
  }

  #lawn-steps-{{ section.id }} .lawn-steps__curve {
    position: absolute;
    z-index: 1;
    left: var(--steps-curve-left);
    top: var(--steps-curve-top);
    width: var(--steps-curve-width);
    height: auto;
    pointer-events: none;
  }

  #lawn-steps-{{ section.id }} .lawn-steps__item {
    position: absolute;
    z-index: 4;
    width: 300px;
    text-align: center;
  }

  #lawn-steps-{{ section.id }} .lawn-steps__item--1 {
    left: 40px;
    top: 334px;
  }

  #lawn-steps-{{ section.id }} .lawn-steps__item--2 {
    left: 442px;
    top: 246px;
  }

  #lawn-steps-{{ section.id }} .lawn-steps__item--3 {
    right: 88px;
    top: 154px;
  }

  #lawn-steps-{{ section.id }} .lawn-steps__image-wrap {
    position: relative;
    width: var(--steps-image-size);
    height: var(--steps-image-size);
    margin: 0 auto 34px;
  }

  #lawn-steps-{{ section.id }} .lawn-steps__image-ring {
    display: block;
    width: 100%;
    height: 100%;
    padding: 8px;
    border: 2px dashed var(--steps-green);
    border-radius: 50%;
    background: #ffffff;
  }

  #lawn-steps-{{ section.id }} .lawn-steps__image {
    display: block;
    width: 100%;
    height: 100%;
    border-radius: 50%;
    object-fit: cover;
  }

  #lawn-steps-{{ section.id }} .lawn-steps__number {
    position: absolute;
    right: 22px;
    bottom: -16px;
    display: grid;
    place-items: center;
    width: 44px;
    height: 44px;
    border-radius: 999px;
    background: var(--steps-accent);
    color: #ffffff;
    font-size: 25px;
    line-height: 1;
    font-weight: 850;
    letter-spacing: -0.04em;
    box-shadow: 0 8px 18px rgba(252, 88, 16, 0.22);
  }

  #lawn-steps-{{ section.id }} .lawn-steps__title {
    margin: 0;
    color: var(--steps-text);
    font-size: 28px;
    line-height: 1.15;
    font-weight: 850;
    letter-spacing: -0.045em;
  }

  #lawn-steps-{{ section.id }} .lawn-steps__text {
    margin: 16px auto 0;
    max-width: 296px;
    color: #333333;
    font-size: 16px;
    line-height: 1.42;
    font-weight: 500;
    letter-spacing: -0.015em;
  }

  #lawn-steps-{{ section.id }} .lawn-steps__hill {
    position: absolute;
    z-index: 1;
    right: var(--steps-hill-right);
    bottom: var(--steps-hill-bottom);
    width: var(--steps-hill-width);
    pointer-events: none;
  }

  #lawn-steps-{{ section.id }} .lawn-steps__hill-img {
    display: block;
    width: 100%;
    height: auto;
  }

  @media screen and (max-width: 1240px) {
    #lawn-steps-{{ section.id }} .lawn-steps__item--1 {
      left: 0;
    }

    #lawn-steps-{{ section.id }} .lawn-steps__item--2 {
      left: 36%;
    }

    #lawn-steps-{{ section.id }} .lawn-steps__item--3 {
      right: 0;
    }

    #lawn-steps-{{ section.id }} .lawn-steps__curve {
      left: 20%;
      width: 64%;
    }

    #lawn-steps-{{ section.id }} .lawn-steps__hill {
      width: min(var(--steps-hill-width), 45vw);
    }
  }

  @media screen and (max-width: 989px) {
    #lawn-steps-{{ section.id }} {
      min-height: auto;
      padding-top: 58px;
      padding-bottom: 76px;
      overflow: hidden;
    }

    #lawn-steps-{{ section.id }} .lawn-steps__container {
      min-height: auto;
    }

    #lawn-steps-{{ section.id }} .lawn-steps__stage {
      position: relative;
      inset: auto;
      display: grid;
      grid-template-columns: 1fr;
      gap: 46px;
      margin-top: 56px;
    }

    #lawn-steps-{{ section.id }} .lawn-steps__curve,
    #lawn-steps-{{ section.id }} .lawn-steps__hill {
      display: none;
    }

    #lawn-steps-{{ section.id }} .lawn-steps__item,
    #lawn-steps-{{ section.id }} .lawn-steps__item--1,
    #lawn-steps-{{ section.id }} .lawn-steps__item--2,
    #lawn-steps-{{ section.id }} .lawn-steps__item--3 {
      position: relative;
      inset: auto;
      width: min(100%, 360px);
      margin-inline: auto;
    }

    #lawn-steps-{{ section.id }} .lawn-steps__heading {
      font-size: clamp(34px, 8vw, 44px);
    }

    #lawn-steps-{{ section.id }} .lawn-steps__lead {
      font-size: 16px;
    }
  }

  @media screen and (max-width: 575px) {
    #lawn-steps-{{ section.id }} {
      padding-top: 46px;
      padding-bottom: 58px;
    }

    #lawn-steps-{{ section.id }} .lawn-steps__eyebrow {
      margin-bottom: 10px;
      font-size: 14px;
    }

    #lawn-steps-{{ section.id }} .lawn-steps__heading {
      font-size: 32px;
      line-height: 1.13;
    }

    #lawn-steps-{{ section.id }} .lawn-steps__lead {
      margin-top: 17px;
      font-size: 15px;
      line-height: 1.55;
    }

    #lawn-steps-{{ section.id }} .lawn-steps__stage {
      margin-top: 42px;
      gap: 40px;
    }

    #lawn-steps-{{ section.id }} .lawn-steps__image-wrap {
      width: 148px;
      height: 148px;
      margin-bottom: 28px;
    }

    #lawn-steps-{{ section.id }} .lawn-steps__number {
      width: 40px;
      height: 40px;
      right: 19px;
      bottom: -14px;
      font-size: 23px;
    }

    #lawn-steps-{{ section.id }} .lawn-steps__title {
      font-size: 25px;
    }

    #lawn-steps-{{ section.id }} .lawn-steps__text {
      font-size: 15px;
    }
  }
</style>

{% schema %}
{
  "name": "Lawn — Steps",
  "tag": "section",
  "class": "lawn-steps-section",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "How It Words"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "How Envy Works To Build Better Lawns"
    },
    {
      "type": "textarea",
      "id": "lead",
      "label": "Lead text",
      "default": "This Blend Works In Three Simple Steps To Grow Thicker, Greener, Stronger Lawns Without Complexity Or Confusion."
    },
    {
      "type": "header",
      "content": "Images"
    },
    {
      "type": "checkbox",
      "id": "show_curve",
      "label": "Show curved connector line",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_grass_hill",
      "label": "Show bottom grass graphic",
      "default": true
    },
    {
      "type": "image_picker",
      "id": "grass_hill_image",
      "label": "Bottom grass graphic"
    },
    {
      "type": "header",
      "content": "Desktop layout"
    },
    {
      "type": "range",
      "id": "max_width",
      "label": "Content width",
      "min": 900,
      "max": 1500,
      "step": 10,
      "unit": "px",
      "default": 1270
    },
    {
      "type": "range",
      "id": "section_height",
      "label": "Section height",
      "min": 600,
      "max": 950,
      "step": 10,
      "unit": "px",
      "default": 800
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Top spacing",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "default": 76
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Bottom spacing",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "side_padding",
      "label": "Side spacing",
      "min": 16,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 52
    },
    {
      "type": "range",
      "id": "step_image_size",
      "label": "Step image size",
      "min": 120,
      "max": 220,
      "step": 4,
      "unit": "px",
      "default": 168
    },
    {
      "type": "range",
      "id": "curve_width",
      "label": "Curve width",
      "min": 500,
      "max": 1000,
      "step": 10,
      "unit": "px",
      "default": 770
    },
    {
      "type": "range",
      "id": "curve_left",
      "label": "Curve left position",
      "min": 0,
      "max": 500,
      "step": 5,
      "unit": "px",
      "default": 285
    },
    {
      "type": "range",
      "id": "curve_top",
      "label": "Curve top position",
      "min": 120,
      "max": 420,
      "step": 4,
      "unit": "px",
      "default": 244
    },
    {
      "type": "range",
      "id": "grass_hill_width",
      "label": "Bottom grass width",
      "min": 300,
      "max": 900,
      "step": 10,
      "unit": "px",
      "default": 560
    },
    {
      "type": "range",
      "id": "grass_hill_push_right",
      "label": "Bottom grass push right",
      "min": 0,
      "max": 220,
      "step": 5,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "grass_hill_drop",
      "label": "Bottom grass drop",
      "min": 0,
      "max": 180,
      "step": 5,
      "unit": "px",
      "default": 0
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background",
      "default": "#FFFFFF"
    },
    {
      "type": "color",
      "id": "green_color",
      "label": "Primary green",
      "default": "#20B26B"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Number badge",
      "default": "#FC5810"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Heading text",
      "default": "#043B26"
    },
    {
      "type": "color",
      "id": "muted_color",
      "label": "Lead text",
      "default": "#244A3E"
    }
  ],
  "max_blocks": 3,
  "blocks": [
    {
      "type": "step",
      "name": "Step",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Step image"
        },
        {
          "type": "text",
          "id": "image_alt",
          "label": "Image alt text",
          "default": "Grass growth step"
        },
        {
          "type": "text",
          "id": "number",
          "label": "Number",
          "default": "1"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Fast Germination"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Description",
          "default": "Quick Early Growth Fills Bare Areas Fast And Helps Reduce Weed Invasion During Establishment Stages."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Lawn — Steps",
      "blocks": [
        {
          "type": "step",
          "settings": {
            "number": "1",
            "title": "Fast Germination",
            "text": "Quick Early Growth Fills Bare Areas Fast And Helps Reduce Weed Invasion During Establishment Stages."
          }
        },
        {
          "type": "step",
          "settings": {
            "number": "2",
            "title": "Deep Roots",
            "text": "Stronger Root Systems Improve Drought Tolerance, Enhance Nutrient Uptake, And Support Long-Term Lawn Health."
          }
        },
        {
          "type": "step",
          "settings": {
            "number": "3",
            "title": "Thick Growth",
            "text": "Dense Turf Growth Crowds Out Weeds Naturally And Creates A Smooth, Full, Uniform Lawn Appearance."
          }
        }
      ]
    }
  ]
}
{% endschema %}