<section
  id="lawn-steps-{{ section.id }}"
  class="lawn-steps"
  style="
    --steps-bg: {{ section.settings.bg_color }};
    --steps-green: {{ section.settings.green_color }};
    --steps-accent: {{ section.settings.accent_color }};
    --steps-heading: {{ section.settings.heading_color }};
    --steps-body: {{ section.settings.body_color }};
    --steps-max-width: {{ section.settings.max_width }}px;
    --steps-height: {{ section.settings.section_height }}px;
    --steps-padding-top: {{ section.settings.padding_top }}px;
    --steps-side-padding: {{ section.settings.side_padding }}px;
    --steps-image-size: {{ section.settings.step_image_size }}px;
    --steps-curve-width: {{ section.settings.curve_width }}px;
    --steps-curve-left: {{ section.settings.curve_left }}px;
    --steps-curve-top: {{ section.settings.curve_top }}px;
    --steps-hill-width: {{ section.settings.grass_hill_width }}px;
    --steps-hill-shift: {{ section.settings.grass_hill_push_right }}px;
    --steps-hill-drop: -{{ section.settings.grass_hill_drop }}px;
  "
>
  <div class="lawn-steps__inner">
    <div class="lawn-steps__header">
      {%- if section.settings.eyebrow != blank -%}
        <p class="lawn-steps__eyebrow">{{ section.settings.eyebrow }}</p>
      {%- endif -%}

      {%- if section.settings.heading != blank -%}
        <h2 class="lawn-steps__heading">{{ section.settings.heading }}</h2>
      {%- endif -%}

      {%- if section.settings.lead != blank -%}
        <p class="lawn-steps__lead">{{ section.settings.lead }}</p>
      {%- endif -%}
    </div>

    <div class="lawn-steps__stage">
      {%- if section.settings.show_curve -%}
        <svg class="lawn-steps__curve" viewBox="0 0 780 260" fill="none" aria-hidden="true" preserveAspectRatio="none">
          <path
            d="M3 188 C80 207 138 189 178 126 C231 42 293 38 360 91 C408 129 441 121 486 63 C551 -20 640 10 777 23"
            stroke="var(--steps-green)"
            stroke-width="2"
            stroke-linecap="round"
          />
        </svg>
      {%- endif -%}

      {%- for block in section.blocks -%}
        {%- if block.type == 'step' -%}
          <article class="lawn-steps__item lawn-steps__item--{{ forloop.index }}" {{ block.shopify_attributes }}>
            <div class="lawn-steps__image-wrap">
              <span class="lawn-steps__image-ring">
                {%- if block.settings.image != blank -%}
                  {{
                    block.settings.image
                    | image_url: width: 520
                    | image_tag:
                      loading: 'lazy',
                      class: 'lawn-steps__image',
                      alt: block.settings.image_alt,
                      width: 520,
                      height: 520
                  }}
                {%- else -%}
                  {%- assign fallback_image = 'step' | append: forloop.index | append: '-grass-clean.png' -%}
                  <img
                    class="lawn-steps__image"
                    src="{{ fallback_image | asset_url }}"
                    alt="{{ block.settings.image_alt | escape }}"
                    width="520"
                    height="520"
                    loading="lazy"
                  >
                {%- endif -%}
              </span>

              <span class="lawn-steps__number">
                {{ block.settings.number | default: forloop.index }}
              </span>
            </div>

            {%- if block.settings.title != blank -%}
              <h3 class="lawn-steps__title">{{ block.settings.title }}</h3>
            {%- endif -%}

            {%- if block.settings.text != blank -%}
              <p class="lawn-steps__text">{{ block.settings.text }}</p>
            {%- endif -%}
          </article>
        {%- endif -%}
      {%- endfor -%}
    </div>
  </div>

  {%- if section.settings.show_grass_hill -%}
    <div class="lawn-steps__hill" aria-hidden="true">
      {%- if section.settings.grass_hill_image != blank -%}
        {{
          section.settings.grass_hill_image
          | image_url: width: 1200
          | image_tag:
            loading: 'lazy',
            class: 'lawn-steps__hill-img',
            alt: '',
            width: 1200,
            height: 1200
        }}
      {%- else -%}
        <img
          class="lawn-steps__hill-img"
          src="{{ 'grass-hill.png' | asset_url }}"
          alt=""
          width="1200"
          height="1200"
          loading="lazy"
        >
      {%- endif -%}
    </div>
  {%- endif -%}
</section>

<style>
  #lawn-steps-{{ section.id }} {
    position: relative;
    isolation: isolate;
    overflow: hidden;
    min-height: var(--steps-height);
    padding-top: var(--steps-padding-top);
    background: var(--steps-bg);
    color: var(--steps-heading);
  }

  #lawn-steps-{{ section.id }} .lawn-steps__inner {
    position: relative;
    z-index: 3;
    width: min(calc(100% - (var(--steps-side-padding) * 2)), var(--steps-max-width));
    min-height: calc(var(--steps-height) - var(--steps-padding-top));
    margin-inline: auto;
  }

  #lawn-steps-{{ section.id }} .lawn-steps__header {
    position: relative;
    z-index: 6;
    max-width: 704px;
  }

  #lawn-steps-{{ section.id }} .lawn-steps__eyebrow {
    margin: 0 0 12px;
    color: var(--steps-green);
    font-family: "Poppins", var(--font-body-family), sans-serif;
    font-size: 15px;
    line-height: 20px;
    font-weight: 600;
    letter-spacing: -0.2px;
  }

  #lawn-steps-{{ section.id }} .lawn-steps__heading {
    margin: 0;
    max-width: 704px;
    color: var(--steps-heading);
    font-family: "Clash Grotesk", var(--font-heading-family), sans-serif;
    font-size: 52px;
    line-height: 64px;
    font-weight: 600;
    letter-spacing: -0.4px;
  }

  #lawn-steps-{{ section.id }} .lawn-steps__lead {
    margin: 22px 0 0;
    max-width: 704px;
    color: var(--steps-heading);
    font-family: "Poppins", var(--font-body-family), sans-serif;
    font-size: 17px;
    line-height: 28px;
    font-weight: 500;
    letter-spacing: 0;
  }

  #lawn-steps-{{ section.id }} .lawn-steps__stage {
    position: absolute;
    inset: 0;
    z-index: 4;
    pointer-events: none;
  }

  #lawn-steps-{{ section.id }} .lawn-steps__curve {
    position: absolute;
    z-index: 1;
    left: var(--steps-curve-left);
    top: var(--steps-curve-top);
    width: var(--steps-curve-width);
    height: 260px;
    pointer-events: none;
  }

  #lawn-steps-{{ section.id }} .lawn-steps__item {
    position: absolute;
    z-index: 4;
    width: 385px;
    text-align: center;
    pointer-events: auto;
  }

  #lawn-steps-{{ section.id }} .lawn-steps__item--1 {
    left: 46px;
    top: 338px;
  }

  #lawn-steps-{{ section.id }} .lawn-steps__item--2 {
    left: 432px;
    top: 246px;
  }

  #lawn-steps-{{ section.id }} .lawn-steps__item--3 {
    left: 815px;
    top: 154px;
  }

  #lawn-steps-{{ section.id }} .lawn-steps__image-wrap {
    position: relative;
    width: var(--steps-image-size);
    height: var(--steps-image-size);
    margin: 0 auto 34px;
  }

  #lawn-steps-{{ section.id }} .lawn-steps__image-ring {
    display: block;
    width: 100%;
    height: 100%;
    padding: 8px;
    border: 1.4px dashed var(--steps-green);
    border-radius: 999px;
    background: #ffffff;
  }

  #lawn-steps-{{ section.id }} .lawn-steps__image {
    display: block;
    width: 100%;
    height: 100%;
    border-radius: 999px;
    object-fit: cover;
  }

  #lawn-steps-{{ section.id }} .lawn-steps__number {
    position: absolute;
    right: 40px;
    bottom: -18px;
    display: grid;
    place-items: center;
    width: 48px;
    height: 48px;
    border-radius: 999px;
    background: var(--steps-accent);
    color: #ffffff;
    font-family: "Clash Grotesk", var(--font-heading-family), sans-serif;
    font-size: 27px;
    line-height: 1;
    font-weight: 600;
    letter-spacing: -0.4px;
  }

  #lawn-steps-{{ section.id }} .lawn-steps__title {
    margin: 0 auto;
    max-width: 310px;
    color: var(--steps-heading);
    font-family: "Clash Grotesk", var(--font-heading-family), sans-serif;
    font-size: 32px;
    line-height: 38px;
    font-weight: 600;
    letter-spacing: -0.4px;
  }

  #lawn-steps-{{ section.id }} .lawn-steps__text {
    margin: 12px auto 0;
    max-width: 385px;
    color: var(--steps-body);
    font-family: "Poppins", var(--font-body-family), sans-serif;
    font-size: 19px;
    line-height: 28px;
    font-weight: 500;
    letter-spacing: 0;
  }

  #lawn-steps-{{ section.id }} .lawn-steps__hill {
    position: absolute;
    z-index: 2;
    right: max(calc((100vw - var(--steps-max-width)) / 2), 0px);
    bottom: var(--steps-hill-drop);
    width: var(--steps-hill-width);
    transform: translateX(var(--steps-hill-shift));
    pointer-events: none;
  }

  #lawn-steps-{{ section.id }} .lawn-steps__hill-img {
    display: block;
    width: 100%;
    height: auto;
  }

  @media screen and (max-width: 1299px) {
    #lawn-steps-{{ section.id }} .lawn-steps__heading {
      font-size: clamp(42px, 4vw, 52px);
      line-height: 1.18;
    }

    #lawn-steps-{{ section.id }} .lawn-steps__item--1 {
      left: 0;
    }

    #lawn-steps-{{ section.id }} .lawn-steps__item--2 {
      left: 34%;
    }

    #lawn-steps-{{ section.id }} .lawn-steps__item--3 {
      left: auto;
      right: 0;
    }

    #lawn-steps-{{ section.id }} .lawn-steps__curve {
      left: 18%;
      width: 62%;
    }
  }

  @media screen and (max-width: 989px) {
    #lawn-steps-{{ section.id }} {
      min-height: auto;
      padding: 58px 0 80px;
    }

    #lawn-steps-{{ section.id }} .lawn-steps__inner {
      min-height: auto;
      width: min(calc(100% - 32px), 620px);
    }

    #lawn-steps-{{ section.id }} .lawn-steps__header {
      max-width: 100%;
    }

    #lawn-steps-{{ section.id }} .lawn-steps__heading {
      font-size: 38px;
      line-height: 46px;
    }

    #lawn-steps-{{ section.id }} .lawn-steps__lead {
      font-size: 16px;
      line-height: 26px;
    }

    #lawn-steps-{{ section.id }} .lawn-steps__stage {
      position: relative;
      inset: auto;
      display: grid;
      gap: 48px;
      margin-top: 54px;
    }

    #lawn-steps-{{ section.id }} .lawn-steps__curve,
    #lawn-steps-{{ section.id }} .lawn-steps__hill {
      display: none;
    }

    #lawn-steps-{{ section.id }} .lawn-steps__item,
    #lawn-steps-{{ section.id }} .lawn-steps__item--1,
    #lawn-steps-{{ section.id }} .lawn-steps__item--2,
    #lawn-steps-{{ section.id }} .lawn-steps__item--3 {
      position: relative;
      inset: auto;
      width: min(100%, 385px);
      margin-inline: auto;
    }

    #lawn-steps-{{ section.id }} .lawn-steps__image-wrap {
      width: 174px;
      height: 174px;
    }

    #lawn-steps-{{ section.id }} .lawn-steps__title {
      font-size: 28px;
      line-height: 34px;
    }

    #lawn-steps-{{ section.id }} .lawn-steps__text {
      font-size: 17px;
      line-height: 26px;
    }
  }

  @media screen and (max-width: 575px) {
    #lawn-steps-{{ section.id }} {
      padding: 46px 0 64px;
    }

    #lawn-steps-{{ section.id }} .lawn-steps__eyebrow {
      font-size: 14px;
      line-height: 18px;
    }

    #lawn-steps-{{ section.id }} .lawn-steps__heading {
      font-size: 32px;
      line-height: 39px;
    }

    #lawn-steps-{{ section.id }} .lawn-steps__lead {
      margin-top: 16px;
      font-size: 15px;
      line-height: 24px;
    }

    #lawn-steps-{{ section.id }} .lawn-steps__stage {
      margin-top: 42px;
      gap: 42px;
    }

    #lawn-steps-{{ section.id }} .lawn-steps__image-wrap {
      width: 150px;
      height: 150px;
      margin-bottom: 30px;
    }

    #lawn-steps-{{ section.id }} .lawn-steps__number {
      width: 42px;
      height: 42px;
      right: 30px;
      bottom: -16px;
      font-size: 24px;
    }

    #lawn-steps-{{ section.id }} .lawn-steps__title {
      font-size: 25px;
      line-height: 31px;
    }

    #lawn-steps-{{ section.id }} .lawn-steps__text {
      max-width: 320px;
      font-size: 15px;
      line-height: 24px;
    }
  }
</style>

{% schema %}
{
  "name": "Lawn — Steps",
  "tag": "section",
  "class": "lawn-steps-section",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "How It Works"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "How Envy Works To Build Better Lawns"
    },
    {
      "type": "textarea",
      "id": "lead",
      "label": "Lead text",
      "default": "This Blend Works In Three Simple Steps To Grow Thicker, Greener, Stronger Lawns Without Complexity Or Confusion."
    },
    {
      "type": "header",
      "content": "Images"
    },
    {
      "type": "checkbox",
      "id": "show_curve",
      "label": "Show curved connector line",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_grass_hill",
      "label": "Show bottom grass graphic",
      "default": true
    },
    {
      "type": "image_picker",
      "id": "grass_hill_image",
      "label": "Bottom grass graphic"
    },
    {
      "type": "header",
      "content": "Desktop layout"
    },
    {
      "type": "range",
      "id": "max_width",
      "label": "Content width",
      "min": 1000,
      "max": 1400,
      "step": 10,
      "unit": "px",
      "default": 1270
    },
    {
      "type": "range",
      "id": "section_height",
      "label": "Section height",
      "min": 700,
      "max": 1000,
      "step": 10,
      "unit": "px",
      "default": 820
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Top spacing",
      "min": 0,
      "max": 160,
      "step": 4,
      "unit": "px",
      "default": 84
    },
    {
      "type": "range",
      "id": "side_padding",
      "label": "Side spacing",
      "min": 0,
      "max": 80,
      "step": 4,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "step_image_size",
      "label": "Step image size",
      "min": 160,
      "max": 220,
      "step": 2,
      "unit": "px",
      "default": 194
    },
    {
      "type": "range",
      "id": "curve_width",
      "label": "Curve width",
      "min": 650,
      "max": 900,
      "step": 10,
      "unit": "px",
      "default": 780
    },
    {
      "type": "range",
      "id": "curve_left",
      "label": "Curve left position",
      "min": 180,
      "max": 340,
      "step": 5,
      "unit": "px",
      "default": 245
    },
    {
      "type": "range",
      "id": "curve_top",
      "label": "Curve top position",
      "min": 160,
      "max": 280,
      "step": 4,
      "unit": "px",
      "default": 220
    },
    {
      "type": "range",
      "id": "grass_hill_width",
      "label": "Bottom grass width",
      "min": 420,
      "max": 760,
      "step": 10,
      "unit": "px",
      "default": 580
    },
    {
      "type": "range",
      "id": "grass_hill_push_right",
      "label": "Bottom grass push right",
      "min": 0,
      "max": 260,
      "step": 5,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "grass_hill_drop",
      "label": "Bottom grass drop",
      "min": 0,
      "max": 120,
      "step": 5,
      "unit": "px",
      "default": 0
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background",
      "default": "#FFFFFF"
    },
    {
      "type": "color",
      "id": "green_color",
      "label": "Primary green",
      "default": "#20B26B"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Number badge",
      "default": "#FC5810"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading text",
      "default": "#043320"
    },
    {
      "type": "color",
      "id": "body_color",
      "label": "Body text",
      "default": "#42473E"
    }
  ],
  "max_blocks": 3,
  "blocks": [
    {
      "type": "step",
      "name": "Step",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Step image"
        },
        {
          "type": "text",
          "id": "image_alt",
          "label": "Image alt text",
          "default": "Grass growth step"
        },
        {
          "type": "text",
          "id": "number",
          "label": "Number",
          "default": "1"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Fast Germination"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Description",
          "default": "Quick Early Growth Fills Bare Areas Fast And Helps Reduce Weed Invasion During Establishment Stages."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Lawn — Steps",
      "blocks": [
        {
          "type": "step",
          "settings": {
            "number": "1",
            "title": "Fast Germination",
            "text": "Quick Early Growth Fills Bare Areas Fast And Helps Reduce Weed Invasion During Establishment Stages."
          }
        },
        {
          "type": "step",
          "settings": {
            "number": "2",
            "title": "Deep Roots",
            "text": "Stronger Root Systems Improve Drought Tolerance, Enhance Nutrient Uptake, And Support Long-Term Lawn Health."
          }
        },
        {
          "type": "step",
          "settings": {
            "number": "3",
            "title": "Thick Growth",
            "text": "Dense Turf Growth Crowds Out Weeds Naturally And Creates A Smooth, Full, Uniform Lawn Appearance."
          }
        }
      ]
    }
  ]
}
{% endschema %}