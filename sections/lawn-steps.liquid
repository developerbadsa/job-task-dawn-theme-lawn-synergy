<section
  id="envy-steps-{{ section.id }}"
  class="envy-steps-section"
  style="
    --content-width: {{ section.settings.content_width }}px;
    --section-height: {{ section.settings.section_height }}px;
    --top-spacing: {{ section.settings.top_spacing }}px;
    --side-spacing: {{ section.settings.side_spacing }}px;
    --heading-width: {{ section.settings.heading_width }}px;
    --heading-size: {{ section.settings.heading_size }}px;
    --lead-width: {{ section.settings.lead_width }}px;
    --step-width: {{ section.settings.step_width }}px;
    --step-image-size: {{ section.settings.step_image_size }}px;
    --step-title-size: {{ section.settings.step_title_size }}px;
    --step-text-size: {{ section.settings.step_text_size }}px;
    --hill-width: {{ section.settings.bottom_grass_width }}px;
    --hill-left: {{ section.settings.bottom_grass_left }};
    --hill-bottom: {{ section.settings.bottom_grass_bottom }};
    --bg-color: {{ section.settings.background_color }};
    --dark-green: {{ section.settings.dark_green }};
    --body-color: {{ section.settings.body_color }};
    --accent-green: {{ section.settings.accent_green }};
    --orange: {{ section.settings.orange_color }};
  "
>
  <div class="envy-steps-section__inner">
    <div class="envy-steps-section__header">
      {%- if section.settings.eyebrow != blank -%}
        <p class="envy-steps-section__eyebrow">{{ section.settings.eyebrow }}</p>
      {%- endif -%}

      {%- if section.settings.heading != blank -%}
        <h2 class="envy-steps-section__heading">{{ section.settings.heading }}</h2>
      {%- endif -%}

      {%- if section.settings.lead != blank -%}
        <p class="envy-steps-section__lead">{{ section.settings.lead }}</p>
      {%- endif -%}
    </div>

    {%- if section.settings.show_curve -%}
      <svg
        class="envy-steps-section__curve"
        viewBox="0 0 1272 824"
        fill="none"
        aria-hidden="true"
        preserveAspectRatio="none"
      >
        <path
          d="M360 456 C448 468 482 424 536 374 C577 336 608 373 638 366 C681 356 695 307 748 282 C802 256 833 288 895 298"
          stroke="var(--accent-green)"
          stroke-width="2"
          stroke-linecap="round"
        />
      </svg>
    {%- endif -%}

    <div class="envy-steps-section__items">
      {%- for block in section.blocks -%}
        {%- if block.type == 'step' -%}
          {%- assign default_step_img = 'step' | append: forloop.index | append: '-grass-clean.png' -%}

          <article
            class="envy-steps-section__item"
            style="
              --step-left: {{ block.settings.desktop_left | default: '80px' }};
              --step-top: {{ block.settings.desktop_top | default: '360px' }};
            "
            {{ block.shopify_attributes }}
          >
            <div class="envy-steps-section__image-wrap">
              <div class="envy-steps-section__image-frame">
                {%- if block.settings.image != blank -%}
                  {{
                    block.settings.image
                    | image_url: width: 500
                    | image_tag:
                      loading: 'lazy',
                      class: 'envy-steps-section__image',
                      alt: block.settings.title,
                      width: 500,
                      height: 500
                  }}
                {%- else -%}
                  <img
                    class="envy-steps-section__image"
                    src="{{ default_step_img | asset_url }}"
                    alt="{{ block.settings.title | escape }}"
                    width="500"
                    height="500"
                    loading="lazy"
                  >
                {%- endif -%}
              </div>

              <span class="envy-steps-section__number">
                {{ block.settings.number | default: forloop.index }}
              </span>
            </div>

            {%- if block.settings.title != blank -%}
              <h3 class="envy-steps-section__title">{{ block.settings.title }}</h3>
            {%- endif -%}

            {%- if block.settings.text != blank -%}
              <p class="envy-steps-section__text">{{ block.settings.text }}</p>
            {%- endif -%}
          </article>
        {%- endif -%}
      {%- endfor -%}
    </div>
  </div>

  {%- if section.settings.show_bottom_grass -%}
    <div class="envy-steps-section__hill" aria-hidden="true">
      {%- if section.settings.bottom_grass_image != blank -%}
        {{
          section.settings.bottom_grass_image
          | image_url: width: 1000
          | image_tag:
            loading: 'lazy',
            class: 'envy-steps-section__hill-image',
            alt: '',
            width: 1000,
            height: 700
        }}
      {%- else -%}
        <img
          class="envy-steps-section__hill-image"
          src="{{ 'grass-hill.png' | asset_url }}"
          alt=""
          width="1000"
          height="700"
          loading="lazy"
        >
      {%- endif -%}
    </div>
  {%- endif -%}
</section>

<style>
  #envy-steps-{{ section.id }} {
    position: relative;
    width: 100%;
    min-height: var(--section-height);
    background: var(--bg-color);
    overflow: hidden;
  }

  #envy-steps-{{ section.id }} *,
  #envy-steps-{{ section.id }} *::before,
  #envy-steps-{{ section.id }} *::after {
    box-sizing: border-box;
  }

  #envy-steps-{{ section.id }} .envy-steps-section__inner {
    position: relative;
    z-index: 2;
    width: min(100%, var(--content-width));
    min-height: var(--section-height);
    margin: 0 auto;
    padding: var(--top-spacing) var(--side-spacing) 0;
  }

  #envy-steps-{{ section.id }} .envy-steps-section__header {
    position: relative;
    z-index: 5;
    width: 100%;
  }

  #envy-steps-{{ section.id }} .envy-steps-section__eyebrow {
    margin: 0 0 12px;
    color: var(--accent-green);
    font-family: "Poppins", var(--font-body-family), sans-serif;
    font-size: 16px;
    font-weight: 500;
    line-height: 19px;
    letter-spacing: 0;
  }

  #envy-steps-{{ section.id }} .envy-steps-section__heading {
    max-width: var(--heading-width);
    margin: 0;
    color: var(--dark-green);
    font-family: "Clash Grotesk", "Clash Display", var(--font-heading-family), sans-serif;
    font-size: var(--heading-size);
    font-weight: 600;
    line-height: 1.23;
    letter-spacing: -0.4px;
  }

  #envy-steps-{{ section.id }} .envy-steps-section__lead {
    max-width: var(--lead-width);
    margin: 24px 0 0;
    color: var(--body-color);
    font-family: "Poppins", var(--font-body-family), sans-serif;
    font-size: 19px;
    font-weight: 500;
    line-height: 28px;
    letter-spacing: 0;
  }

  #envy-steps-{{ section.id }} .envy-steps-section__curve {
    position: absolute;
    inset: 0;
    z-index: 1;
    width: 100%;
    height: 100%;
    pointer-events: none;
  }

  #envy-steps-{{ section.id }} .envy-steps-section__items {
    position: absolute;
    inset: 0;
    z-index: 4;
    pointer-events: none;
  }

  #envy-steps-{{ section.id }} .envy-steps-section__item {
    position: absolute;
    top: var(--step-top);
    left: var(--step-left);
    width: var(--step-width);
    text-align: center;
    pointer-events: auto;
  }

  #envy-steps-{{ section.id }} .envy-steps-section__image-wrap {
    position: relative;
    width: var(--step-image-size);
    height: var(--step-image-size);
    margin: 0 auto;
    border: 1.5px dashed var(--accent-green);
    border-radius: 50%;
    padding: 8px;
    background: #ffffff;
  }

  #envy-steps-{{ section.id }} .envy-steps-section__image-frame {
    width: 100%;
    height: 100%;
    border-radius: 50%;
    overflow: hidden;
    background: #ffffff;
  }

  #envy-steps-{{ section.id }} .envy-steps-section__image {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  #envy-steps-{{ section.id }} .envy-steps-section__number {
    position: absolute;
    left: 50%;
    bottom: -12px;
    display: inline-flex;
    width: 52px;
    height: 52px;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    background: var(--orange);
    color: #ffffff;
    font-family: "Clash Grotesk", "Clash Display", var(--font-heading-family), sans-serif;
    font-size: 27px;
    font-weight: 700;
    line-height: 1;
    transform: translateX(-50%);
  }

  #envy-steps-{{ section.id }} .envy-steps-section__title {
    margin: 34px 0 14px;
    color: var(--dark-green);
    font-family: "Clash Grotesk", "Clash Display", var(--font-heading-family), sans-serif;
    font-size: var(--step-title-size);
    font-weight: 600;
    line-height: 38px;
    letter-spacing: -0.4px;
  }

  #envy-steps-{{ section.id }} .envy-steps-section__text {
    max-width: 385px;
    margin: 0 auto;
    color: #42473e;
    font-family: "Poppins", var(--font-body-family), sans-serif;
    font-size: var(--step-text-size);
    font-weight: 500;
    line-height: 28px;
    letter-spacing: 0;
  }

  #envy-steps-{{ section.id }} .envy-steps-section__hill {
    position: absolute;
    z-index: 3;
    left: var(--hill-left);
    bottom: var(--hill-bottom);
    width: var(--hill-width);
    max-width: 58vw;
    line-height: 0;
    pointer-events: none;
  }

  #envy-steps-{{ section.id }} .envy-steps-section__hill-image {
    display: block;
    width: 100%;
    height: auto;
  }

  @media screen and (max-width: 1180px) {
    #envy-steps-{{ section.id }} .envy-steps-section__inner {
      padding-left: 40px;
      padding-right: 40px;
    }

    #envy-steps-{{ section.id }} .envy-steps-section__item {
      transform: scale(0.9);
      transform-origin: top center;
    }

    #envy-steps-{{ section.id }} .envy-steps-section__hill {
      width: 520px;
      max-width: 54vw;
    }
  }

  @media screen and (max-width: 900px) {
    #envy-steps-{{ section.id }} {
      min-height: auto;
      overflow: hidden;
    }

    #envy-steps-{{ section.id }} .envy-steps-section__inner {
      min-height: auto;
      padding: 70px 22px 330px;
    }

    #envy-steps-{{ section.id }} .envy-steps-section__heading {
      font-size: {{ section.settings.mobile_heading_size }}px;
      line-height: 1.18;
    }

    #envy-steps-{{ section.id }} .envy-steps-section__lead {
      margin-top: 18px;
      font-size: 15px;
      line-height: 24px;
    }

    #envy-steps-{{ section.id }} .envy-steps-section__curve {
      display: none;
    }

    #envy-steps-{{ section.id }} .envy-steps-section__items {
      position: relative;
      inset: auto;
      display: grid;
      gap: 38px;
      margin-top: 52px;
    }

    #envy-steps-{{ section.id }} .envy-steps-section__item {
      position: relative;
      top: auto;
      left: auto;
      width: 100%;
      max-width: 385px;
      margin: 0 auto;
      transform: none;
    }

    #envy-steps-{{ section.id }} .envy-steps-section__image-wrap {
      width: 170px;
      height: 170px;
    }

    #envy-steps-{{ section.id }} .envy-steps-section__number {
      width: 46px;
      height: 46px;
      font-size: 24px;
    }

    #envy-steps-{{ section.id }} .envy-steps-section__title {
      margin-top: 30px;
      font-size: 26px;
      line-height: 32px;
    }

    #envy-steps-{{ section.id }} .envy-steps-section__text {
      font-size: 15px;
      line-height: 24px;
    }

    #envy-steps-{{ section.id }} .envy-steps-section__hill {
      left: auto;
      right: -80px;
      bottom: 0;
      width: 430px;
      max-width: 90vw;
    }
  }
</style>

{% schema %}
{
  "name": "Lawn — Steps",
  "tag": "section",
  "class": "lawn-steps-section",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "How It Words"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "How Envy Works To Build Better Lawns"
    },
    {
      "type": "textarea",
      "id": "lead",
      "label": "Lead text",
      "default": "This Blend Works In Three Simple Steps To Grow Thicker, Greener, Stronger Lawns Without Complexity Or Confusion."
    },
    {
      "type": "header",
      "content": "Images"
    },
    {
      "type": "checkbox",
      "id": "show_curve",
      "label": "Show curved connector line",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_bottom_grass",
      "label": "Show bottom grass hill",
      "default": true
    },
    {
      "type": "image_picker",
      "id": "bottom_grass_image",
      "label": "Bottom grass hill image"
    },
    {
      "type": "header",
      "content": "Desktop layout"
    },
    {
      "type": "range",
      "id": "content_width",
      "label": "Content width",
      "min": 960,
      "max": 1600,
      "step": 8,
      "unit": "px",
      "default": 1272
    },
    {
      "type": "range",
      "id": "section_height",
      "label": "Section height",
      "min": 640,
      "max": 980,
      "step": 4,
      "unit": "px",
      "default": 824
    },
    {
      "type": "range",
      "id": "top_spacing",
      "label": "Top spacing",
      "min": 40,
      "max": 180,
      "step": 4,
      "unit": "px",
      "default": 108
    },
    {
      "type": "range",
      "id": "side_spacing",
      "label": "Side spacing",
      "min": 0,
      "max": 140,
      "step": 4,
      "unit": "px",
      "default": 80
    },
    {
      "type": "range",
      "id": "heading_width",
      "label": "Heading width",
