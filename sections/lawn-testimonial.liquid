{%- liquid
  assign person = section.settings.person_image
  assign avatar = section.settings.avatar_image
  assign bg_texture = section.settings.bg_texture_image
  assign grass_edge = section.settings.grass_edge_image

  assign person_alt = section.settings.person_alt | default: 'Customer holding Envy grass seed'
  assign avatar_alt = section.settings.avatar_alt | default: 'Customer avatar'

  assign texture_opacity = section.settings.texture_opacity | times: 0.01
-%}

<section
  id="lawn-testimonial-{{ section.id }}"
  class="lawn-testimonial-custom"
  style="
    --testimonial-width: {{ section.settings.content_width }}px;
    --testimonial-height: {{ section.settings.section_height }}px;
    --testimonial-panel-left: {{ section.settings.panel_left }}px;
    --testimonial-panel-radius: {{ section.settings.panel_radius }}px;
    --testimonial-person-left: {{ section.settings.person_left }}px;
    --testimonial-person-bottom: {{ section.settings.person_bottom }}px;
    --testimonial-person-width: {{ section.settings.person_width }}px;
    --testimonial-person-height: {{ section.settings.person_height }}px;
    --testimonial-content-left: {{ section.settings.content_left }}px;
    --testimonial-content-top: {{ section.settings.content_top }}px;
    --testimonial-content-width: {{ section.settings.content_box_width }}px;
    --testimonial-card-width: {{ section.settings.card_width }}px;
    --testimonial-card-height: {{ section.settings.card_height }}px;
    --testimonial-card-gap: {{ section.settings.card_top_gap }}px;
    --testimonial-grass-height: {{ section.settings.grass_height }}px;
    --testimonial-grass-overlap: {{ section.settings.grass_overlap }}px;
    --testimonial-panel-bg: {{ section.settings.panel_bg }};
    --testimonial-card-bg: {{ section.settings.card_bg }};
    --testimonial-primary: {{ section.settings.primary_green }};
    --testimonial-heading: {{ section.settings.heading_color }};
    --testimonial-body: {{ section.settings.body_color }};
    --testimonial-heading-size: {{ section.settings.heading_size }}px;
    --testimonial-quote-size: {{ section.settings.quote_size }}px;
    --testimonial-body-size: {{ section.settings.body_size }}px;
    --testimonial-texture-opacity: {{ texture_opacity }};
    {%- if bg_texture != blank -%}
      --testimonial-texture: url('{{ bg_texture | image_url: width: 2400 }}');
    {%- else -%}
      --testimonial-texture: none;
    {%- endif -%}
  "
>
  <div class="lawn-testimonial-custom__inner">
    <div class="lawn-testimonial-custom__panel" aria-hidden="true"></div>

    <div class="lawn-testimonial-custom__person">
      {%- if person != blank -%}
        {{
          person
          | image_url: width: 1200
          | image_tag:
            loading: 'lazy',
            class: 'lawn-testimonial-custom__person-img',
            alt: person_alt,
            width: 1200,
            height: 1400
        }}
      {%- else -%}
        <img
          class="lawn-testimonial-custom__person-img"
          src="{{ 'testimonial-man.png' | asset_url }}"
          alt="{{ person_alt | escape }}"
          width="1200"
          height="1400"
          loading="lazy"
        >
      {%- endif -%}
    </div>

    <div class="lawn-testimonial-custom__content">
      {%- if section.settings.eyebrow != blank -%}
        <p class="lawn-testimonial-custom__eyebrow">{{ section.settings.eyebrow }}</p>
      {%- endif -%}

      {%- if section.settings.heading != blank -%}
        <h2 class="lawn-testimonial-custom__heading">{{ section.settings.heading }}</h2>
      {%- endif -%}

      <article class="lawn-testimonial-custom__card">
        <div class="lawn-testimonial-custom__avatar">
          {%- if avatar != blank -%}
            {{
              avatar
              | image_url: width: 220
              | image_tag:
                loading: 'lazy',
                class: 'lawn-testimonial-custom__avatar-img',
                alt: avatar_alt,
                width: 220,
                height: 220
            }}
          {%- else -%}
            <img
              class="lawn-testimonial-custom__avatar-img"
              src="{{ 'testimonial-avatar.png' | asset_url }}"
              alt="{{ avatar_alt | escape }}"
              width="220"
              height="220"
              loading="lazy"
            >
          {%- endif -%}
        </div>

        <span class="lawn-testimonial-custom__quote-mark" aria-hidden="true">”</span>

        {%- if section.settings.quote != blank -%}
          <p class="lawn-testimonial-custom__quote">{{ section.settings.quote }}</p>
        {%- endif -%}

        <div class="lawn-testimonial-custom__meta">
          <div>
            {%- if section.settings.author_name != blank -%}
              <strong>{{ section.settings.author_name }}</strong>
            {%- endif -%}

            {%- if section.settings.author_role != blank -%}
              <small>{{ section.settings.author_role }}</small>
            {%- endif -%}
          </div>

          {%- if section.settings.stars != blank -%}
            <span class="lawn-testimonial-custom__stars">{{ section.settings.stars }}</span>
          {%- endif -%}
        </div>
      </article>
    </div>
  </div>

  {%- if section.settings.show_grass_edge -%}
    <div class="lawn-testimonial-custom__grass" aria-hidden="true">
      {%- if grass_edge != blank -%}
        {{
          grass_edge
          | image_url: width: 2600
          | image_tag:
            loading: 'lazy',
            class: 'lawn-testimonial-custom__grass-img',
            alt: '',
            width: 2600,
            height: 300
        }}
      {%- else -%}
        <img
          class="lawn-testimonial-custom__grass-img"
          src="{{ 'testimonial-grass-strip.png' | asset_url }}"
          alt=""
          width="2600"
          height="300"
          loading="lazy"
        >
      {%- endif -%}
    </div>
  {%- endif -%}
</section>

<style>
  #shopify-section-{{ section.id }} {
    position: relative;
    z-index: 2;
    overflow: visible !important;
  }

  #lawn-testimonial-{{ section.id }} {
    position: relative;
    z-index: 1;
    overflow: visible;
    min-height: var(--testimonial-height);
    background: #ffffff;
    color: var(--testimonial-body);
  }

  #lawn-testimonial-{{ section.id }} .lawn-testimonial-custom__inner {
    position: relative;
    width: min(100%, var(--testimonial-width));
    height: var(--testimonial-height);
    margin-inline: auto;
  }

  #lawn-testimonial-{{ section.id }} .lawn-testimonial-custom__panel {
    position: absolute;
    inset: 0 0 0 var(--testimonial-panel-left);
    z-index: 1;
    overflow: hidden;
    border-top-left-radius: var(--testimonial-panel-radius);
    background: var(--testimonial-panel-bg);
  }

  #lawn-testimonial-{{ section.id }} .lawn-testimonial-custom__panel::before {
    content: "";
    position: absolute;
    inset: 0;
    background-image: var(--testimonial-texture);
    background-size: cover;
    background-position: center;
    opacity: var(--testimonial-texture-opacity);
    mix-blend-mode: screen;
  }

  #lawn-testimonial-{{ section.id }} .lawn-testimonial-custom__panel::after {
    content: "";
    position: absolute;
    inset: 0;
    background: rgba(0, 50, 32, 0.2);
  }

  #lawn-testimonial-{{ section.id }} .lawn-testimonial-custom__person {
    position: absolute;
    left: var(--testimonial-person-left);
    bottom: var(--testimonial-person-bottom);
    z-index: 3;
    width: var(--testimonial-person-width);
    height: var(--testimonial-person-height);
    pointer-events: none;
  }

  #lawn-testimonial-{{ section.id }} .lawn-testimonial-custom__person-img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: contain;
    object-position: left bottom;
  }

  #lawn-testimonial-{{ section.id }} .lawn-testimonial-custom__content {
    position: absolute;
    left: var(--testimonial-content-left);
    top: var(--testimonial-content-top);
    z-index: 4;
    width: var(--testimonial-content-width);
  }

  #lawn-testimonial-{{ section.id }} .lawn-testimonial-custom__eyebrow {
    margin: 0 0 20px;
    color: var(--testimonial-primary);
    font-family: "Poppins", var(--font-body-family), sans-serif;
    font-size: 16px;
    line-height: 1.2;
    font-weight: 600;
    letter-spacing: -0.02em;
  }

  #lawn-testimonial-{{ section.id }} .lawn-testimonial-custom__heading {
    margin: 0;
    max-width: 650px;
    color: var(--testimonial-heading);
    font-family: "Clash Grotesk", var(--font-heading-family), sans-serif;
    font-size: var(--testimonial-heading-size);
    line-height: 1.23;
    font-weight: 700;
    letter-spacing: -0.04em;
  }

  #lawn-testimonial-{{ section.id }} .lawn-testimonial-custom__card {
    position: relative;
    width: var(--testimonial-card-width);
    min-height: var(--testimonial-card-height);
    margin-top: var(--testimonial-card-gap);
    padding: 62px 38px 36px;
    border-radius: 30px;
    background: var(--testimonial-card-bg);
    color: #ffffff;
    box-shadow: 0 26px 60px rgba(0, 0, 0, 0.16);
  }

  #lawn-testimonial-{{ section.id }} .lawn-testimonial-custom__avatar {
    position: absolute;
    top: -42px;
    left: 48px;
    width: 78px;
    height: 78px;
    padding: 4px;
    border-radius: 999px;
    background: #ffffff;
    box-shadow: 0 12px 28px rgba(0, 0, 0, 0.18);
  }

  #lawn-testimonial-{{ section.id }} .lawn-testimonial-custom__avatar-img {
    display: block;
    width: 100%;
    height: 100%;
    border-radius: inherit;
    object-fit: cover;
  }

  #lawn-testimonial-{{ section.id }} .lawn-testimonial-custom__quote-mark {
    position: absolute;
    top: -22px;
    right: 42px;
    color: #ffffff;
    font-family: Georgia, serif;
    font-size: 112px;
    line-height: 1;
    font-weight: 700;
  }

  #lawn-testimonial-{{ section.id }} .lawn-testimonial-custom__quote {
    margin: 0;
    max-width: 530px;
    color: #ffffff;
    font-family: "Poppins", var(--font-body-family), sans-serif;
    font-size: var(--testimonial-quote-size);
    line-height: 1.42;
    font-weight: 400;
    font-style: italic;
    letter-spacing: -0.02em;
  }

  #lawn-testimonial-{{ section.id }} .lawn-testimonial-custom__meta {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 28px;
    margin-top: 30px;
  }

  #lawn-testimonial-{{ section.id }} .lawn-testimonial-custom__meta strong {
    display: block;
    color: #ffffff;
    font-family: "Poppins", var(--font-body-family), sans-serif;
    font-size: 25px;
    line-height: 1.1;
    font-weight: 600;
    letter-spacing: -0.03em;
  }

  #lawn-testimonial-{{ section.id }} .lawn-testimonial-custom__meta small {
    display: block;
    margin-top: 5px;
    color: #ffffff;
    font-family: "Poppins", var(--font-body-family), sans-serif;
    font-size: 13px;
    line-height: 1.2;
    font-weight: 400;
  }

  #lawn-testimonial-{{ section.id }} .lawn-testimonial-custom__stars {
    flex: 0 0 auto;
    color: #ffffff;
    font-size: 22px;
    line-height: 1;
    letter-spacing: 5px;
    white-space: nowrap;
  }

  #lawn-testimonial-{{ section.id }} .lawn-testimonial-custom__grass {
    position: absolute;
    left: 50%;
    bottom: calc(var(--testimonial-grass-overlap) * -1);
    z-index: 8;
    width: 100vw;
    height: var(--testimonial-grass-height);
    transform: translateX(-50%);
    pointer-events: none;
  }

  #lawn-testimonial-{{ section.id }} .lawn-testimonial-custom__grass-img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: fill;
    object-position: center bottom;
  }

  @media screen and (max-width: 1279px) {
    #lawn-testimonial-{{ section.id }} .lawn-testimonial-custom__inner {
      width: 100%;
    }

    #lawn-testimonial-{{ section.id }} .lawn-testimonial-custom__person {
      left: 0;
      width: 56vw;
    }

    #lawn-testimonial-{{ section.id }} .lawn-testimonial-custom__content {
      left: 48%;
      width: min(48vw, var(--testimonial-content-width));
    }

    #lawn-testimonial-{{ section.id }} .lawn-testimonial-custom__card {
      width: 100%;
    }
  }

  @media screen and (max-width: 989px) {
    #lawn-testimonial-{{ section.id }} {
      overflow: hidden;
      min-height: auto;
      padding: 54px 20px 130px;
      background: var(--testimonial-panel-bg);
    }

    #lawn-testimonial-{{ section.id }} .lawn-testimonial-custom__inner {
      height: auto;
      width: min(100%, 640px);
    }

    #lawn-testimonial-{{ section.id }} .lawn-testimonial-custom__panel {
      inset: -54px -20px -130px;
      border-radius: 0;
    }

    #lawn-testimonial-{{ section.id }} .lawn-testimonial-custom__person,
    #lawn-testimonial-{{ section.id }} .lawn-testimonial-custom__content {
      position: relative;
      inset: auto;
      width: 100%;
    }

    #lawn-testimonial-{{ section.id }} .lawn-testimonial-custom__person {
      height: auto;
      margin: 0 auto 38px;
      max-width: 430px;
    }

    #lawn-testimonial-{{ section.id }} .lawn-testimonial-custom__person-img {
      height: auto;
    }

    #lawn-testimonial-{{ section.id }} .lawn-testimonial-custom__content {
      z-index: 5;
    }

    #lawn-testimonial-{{ section.id }} .lawn-testimonial-custom__heading {
      font-size: clamp(36px, 8vw, 48px);
    }

    #lawn-testimonial-{{ section.id }} .lawn-testimonial-custom__card {
      width: 100%;
      min-height: auto;
      margin-top: 72px;
      padding: 58px 26px 30px;
    }

    #lawn-testimonial-{{ section.id }} .lawn-testimonial-custom__quote {
      font-size: 20px;
    }

    #lawn-testimonial-{{ section.id }} .lawn-testimonial-custom__grass {
      height: 122px;
    }
  }

  @media screen and (max-width: 575px) {
    #lawn-testimonial-{{ section.id }} {
      padding: 44px 16px 110px;
    }

    #lawn-testimonial-{{ section.id }} .lawn-testimonial-custom__eyebrow {
      margin-bottom: 12px;
      font-size: 14px;
    }

    #lawn-testimonial-{{ section.id }} .lawn-testimonial-custom__heading {
      font-size: 34px;
      line-height: 1.18;
    }

    #lawn-testimonial-{{ section.id }} .lawn-testimonial-custom__quote {
      font-size: 18px;
      line-height: 1.45;
    }

    #lawn-testimonial-{{ section.id }} .lawn-testimonial-custom__meta {
      display: block;
    }

    #lawn-testimonial-{{ section.id }} .lawn-testimonial-custom__stars {
      display: block;
      margin-top: 20px;
      font-size: 18px;
      letter-spacing: 4px;
    }

    #lawn-testimonial-{{ section.id }} .lawn-testimonial-custom__quote-mark {
      right: 24px;
      font-size: 88px;
    }

    #lawn-testimonial-{{ section.id }} .lawn-testimonial-custom__avatar {
      left: 28px;
      width: 68px;
      height: 68px;
    }
  }
</style>

{% schema %}
{
  "name": "Lawn — Testimonial",
  "tag": "section",
  "class": "lawn-testimonial-section",
  "settings": [
    {
      "type": "header",
      "content": "Images"
    },
    {
      "type": "image_picker",
      "id": "person_image",
      "label": "Person photo"
    },
    {
      "type": "text",
      "id": "person_alt",
      "label": "Person alt text",
      "default": "Customer holding Envy grass seed"
    },
    {
      "type": "image_picker",
      "id": "bg_texture_image",
      "label": "Background texture image"
    },
    {
      "type": "range",
      "id": "texture_opacity",
      "label": "Texture opacity",
      "min": 0,
      "max": 40,
      "step": 1,
      "unit": "%",
      "default": 17
    },
    {
      "type": "image_picker",
      "id": "grass_edge_image",
      "label": "Bottom grass image"
    },
    {
      "type": "checkbox",
      "id": "show_grass_edge",
      "label": "Show bottom grass image",
      "default": true
    },
    {
      "type": "image_picker",
      "id": "avatar_image",
      "label": "Avatar"
    },
    {
      "type": "text",
      "id": "avatar_alt",
      "label": "Avatar alt text",
      "default": "Customer avatar"
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Real Results"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "What Happens When You Use Better Grass Seed"
    },
    {
      "type": "textarea",
      "id": "quote",
      "label": "Quote",
      "default": "I overseeded last fall and saw germination within days. My lawn filled in thick, dark green, and looks better than neighbors who use standard store seed."
    },
    {
      "type": "text",
      "id": "author_name",
      "label": "Author name",
      "default": "Helena"
    },
    {
      "type": "text",
      "id": "author_role",
      "label": "Author role",
      "default": "Model"
    },
    {
      "type": "text",
      "id": "stars",
      "label": "Stars",
      "default": "★★★★★"
    },
    {
      "type": "header",
      "content": "Desktop layout"
    },
    {
      "type": "range",
      "id": "content_width",
      "label": "Content width",
      "min": 1000,
      "max": 1500,
      "step": 10,
      "unit": "px",
      "default": 1270
    },
    {
      "type": "range",
      "id": "section_height",
      "label": "Section height",
      "min": 700,
      "max": 1100,
      "step": 5,
      "unit": "px",
      "default": 905
    },
    {
      "type": "range",
      "id": "panel_left",
      "label": "Green panel left offset",
      "min": 0,
      "max": 420,
      "step": 5,
      "unit": "px",
      "default": 250
    },
    {
      "type": "range",
      "id": "panel_radius",
      "label": "Green panel radius",
      "min": 0,
      "max": 60,
      "step": 2,
      "unit": "px",
      "default": 30
    },
    {
      "type": "range",
      "id": "person_left",
      "label": "Person left position",
      "min": 0,
      "max": 120,
      "step": 2,
      "unit": "px",
      "default": 18
    },
    {
      "type": "range",
      "id": "person_bottom",
      "label": "Person bottom position",
      "min": 0,
      "max": 120,
      "step": 2,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "person_width",
      "label": "Person width",
      "min": 500,
      "max": 900,
      "step": 5,
      "unit": "px",
      "default": 780
    },
    {
      "type": "range",
      "id": "person_height",
      "label": "Person height",
      "min": 650,
      "max": 1050,
      "step": 5,
      "unit": "px",
      "default": 905
    },
    {
      "type": "range",
      "id": "content_left",
      "label": "Text left position",
      "min": 420,
      "max": 780,
      "step": 5,
      "unit": "px",
      "default": 590
    },
    {
      "type": "range",
      "id": "content_top",
      "label": "Text top position",
      "min": 80,
      "max": 300,
      "step": 5,
      "unit": "px",
      "default": 150
    },
    {
      "type": "range",
      "id": "content_box_width",
      "label": "Text box width",
      "min": 500,
      "max": 760,
      "step": 4,
      "unit": "px",
      "default": 648
    },
    {
      "type": "range",
      "id": "card_width",
      "label": "Quote card width",
      "min": 500,
      "max": 760,
      "step": 4,
      "unit": "px",
      "default": 648
    },
    {
      "type": "range",
      "id": "card_height",
      "label": "Quote card height",
      "min": 260,
      "max": 420,
      "step": 4,
      "unit": "px",
      "default": 328
    },
    {
      "type": "range",
      "id": "card_top_gap",
      "label": "Quote card top gap",
      "min": 40,
      "max": 130,
      "step": 2,
      "unit": "px",
      "default": 88
    },
    {
      "type": "range",
      "id": "grass_height",
      "label": "Bottom grass height",
      "min": 100,
      "max": 260,
      "step": 4,
      "unit": "px",
      "default": 180
    },
    {
      "type": "range",
      "id": "grass_overlap",
      "label": "Bottom grass overflow",
      "min": 0,
      "max": 80,
      "step": 2,
      "unit": "px",
      "default": 22
    },
    {
      "type": "header",
      "content": "Typography"
    },
    {
      "type": "range",
      "id": "heading_size",
      "label": "Heading size",
      "min": 36,
      "max": 70,
      "step": 1,
      "unit": "px",
      "default": 52
    },
    {
      "type": "range",
      "id": "quote_size",
      "label": "Quote size",
      "min": 16,
      "max": 30,
      "step": 1,
      "unit": "px",
      "default": 24
    },
    {
      "type": "range",
      "id": "body_size",
      "label": "Body size",
      "min": 12,
      "max": 22,
      "step": 1,
      "unit": "px",
      "default": 17
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "panel_bg",
      "label": "Dark green background",
      "default": "#00452E"
    },
    {
      "type": "color",
      "id": "card_bg",
      "label": "Quote card background",
      "default": "#25AA6C"
    },
    {
      "type": "color",
      "id": "primary_green",
      "label": "Eyebrow green",
      "default": "#20B26B"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading color",
      "default": "#FFFFFF"
    },
    {
      "type": "color",
      "id": "body_color",
      "label": "Body color",
      "default": "#FFFFFF"
    }
