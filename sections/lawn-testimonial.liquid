{%- liquid
  assign person = section.settings.person_image
  assign avatar = section.settings.avatar_image
  assign bg_texture = section.settings.bg_texture_image
  assign grass_edge = section.settings.grass_edge_image

  assign person_alt = section.settings.person_alt | default: 'Customer holding Envy grass seed'
  assign avatar_alt = section.settings.avatar_alt | default: 'Customer avatar'

  assign eyebrow = section.settings.eyebrow | default: 'Real Results'
  assign heading = section.settings.heading | default: 'What Happens When You Use Better Grass Seed'
  assign quote = section.settings.quote | default: 'I overseeded last fall and saw germination within days. My lawn filled in thick, dark green, and looks better than neighbors who use standard store seed.'
  assign author_name = section.settings.author_name | default: 'Helena'
  assign author_role = section.settings.author_role | default: 'Model'
  assign stars = section.settings.stars | default: '★★★★★'

  assign layout_width = section.settings.layout_width | default: 1440
  assign layout_height = section.settings.layout_height | default: 891
  assign panel_left = section.settings.layout_panel_left | default: 301
  assign panel_radius = section.settings.layout_panel_radius | default: 50

  assign person_left = section.settings.layout_person_left | default: 18
  assign person_top = section.settings.layout_person_top | default: 0
  assign person_width = section.settings.layout_person_width | default: 779
  assign person_height = section.settings.layout_person_height | default: 905

  assign content_left = section.settings.layout_content_left | default: 711
  assign content_top = section.settings.layout_content_top | default: 156
  assign content_width = section.settings.layout_content_width | default: 647

  assign card_width = section.settings.layout_card_width | default: 647
  assign card_height = section.settings.layout_card_height | default: 328
  assign card_gap = section.settings.layout_card_gap | default: 50
  assign grass_height = section.settings.layout_grass_height | default: 148

  assign heading_size = section.settings.type_heading_size | default: 52
  assign quote_size = section.settings.type_quote_size | default: 24

  assign panel_bg = section.settings.visual_panel_bg | default: '#043320'
  assign card_bg = section.settings.visual_card_bg | default: '#25AA6C'
  assign primary_green = section.settings.visual_primary_green | default: '#25AA6C'
  assign heading_color = section.settings.visual_heading_color | default: '#FFFFFF'
  assign body_color = section.settings.visual_body_color | default: '#FFFFFF'

  assign texture_opacity = section.settings.texture_opacity | default: 26 | times: 0.01

  if bg_texture != blank
    assign texture_url = bg_texture | image_url: width: 2400
  else
    assign texture_url = blank
  endif
-%}

<section
  id="lawn-testimonial-{{ section.id }}"
  class="lawn-testimonial-custom"
  style="
    --testimonial-width: {{ layout_width }}px;
    --testimonial-height: {{ layout_height }}px;
    --testimonial-panel-left: {{ panel_left }}px;
    --testimonial-panel-radius: {{ panel_radius }}px;

    --testimonial-person-left: {{ person_left }}px;
    --testimonial-person-top: {{ person_top }}px;
    --testimonial-person-width: {{ person_width }}px;
    --testimonial-person-height: {{ person_height }}px;

    --testimonial-content-left: {{ content_left }}px;
    --testimonial-content-top: {{ content_top }}px;
    --testimonial-content-width: {{ content_width }}px;

    --testimonial-card-width: {{ card_width }}px;
    --testimonial-card-height: {{ card_height }}px;
    --testimonial-card-gap: {{ card_gap }}px;
    --testimonial-grass-height: {{ grass_height }}px;

    --testimonial-panel-bg: {{ panel_bg }};
    --testimonial-card-bg: {{ card_bg }};
    --testimonial-primary: {{ primary_green }};
    --testimonial-heading: {{ heading_color }};
    --testimonial-body: {{ body_color }};

    --testimonial-heading-size: {{ heading_size }}px;
    --testimonial-quote-size: {{ quote_size }}px;

    --testimonial-texture: {% if texture_url != blank %}url('{{ texture_url }}'){% else %}none{% endif %};
    --testimonial-texture-opacity: {{ texture_opacity }};
  "
>
  <div class="lawn-testimonial-custom__inner">
    <div class="lawn-testimonial-custom__person">
      {%- if person != blank -%}
        {{
          person
          | image_url: width: 1600
          | image_tag:
            loading: 'lazy',
            class: 'lawn-testimonial-custom__person-img',
            alt: person_alt,
            width: 1600,
            height: 1900
        }}
      {%- else -%}
        <img
          class="lawn-testimonial-custom__person-img"
          src="{{ 'testimonial-man.png' | asset_url }}"
          alt="{{ person_alt | escape }}"
          width="1600"
          height="1900"
          loading="lazy"
        >
      {%- endif -%}
    </div>

    <div class="lawn-testimonial-custom__content">
      {%- if eyebrow != blank -%}
        <p class="lawn-testimonial-custom__eyebrow">{{ eyebrow }}</p>
      {%- endif -%}

      {%- if heading != blank -%}
        <h2 class="lawn-testimonial-custom__heading">{{ heading }}</h2>
      {%- endif -%}

      <article class="lawn-testimonial-custom__card">
        <div class="lawn-testimonial-custom__avatar">
          {%- if avatar != blank -%}
            {{
              avatar
              | image_url: width: 220
              | image_tag:
                loading: 'lazy',
                class: 'lawn-testimonial-custom__avatar-img',
                alt: avatar_alt,
                width: 220,
                height: 220
            }}
          {%- else -%}
            <img
              class="lawn-testimonial-custom__avatar-img"
              src="{{ 'testimonial-avatar.png' | asset_url }}"
              alt="{{ avatar_alt | escape }}"
              width="220"
              height="220"
              loading="lazy"
            >
          {%- endif -%}
        </div>

        <span class="lawn-testimonial-custom__quote-mark">&rdquo;</span>

        {%- if quote != blank -%}
          <p class="lawn-testimonial-custom__quote">{{ quote }}</p>
        {%- endif -%}

        <div class="lawn-testimonial-custom__meta">
          <div>
            {%- if author_name != blank -%}
              <strong>{{ author_name }}</strong>
            {%- endif -%}

            {%- if author_role != blank -%}
              <small>{{ author_role }}</small>
            {%- endif -%}
          </div>

          {%- if stars != blank -%}
            <span class="lawn-testimonial-custom__stars">{{ stars }}</span>
          {%- endif -%}
        </div>
      </article>
    </div>
  </div>

  {%- if section.settings.show_grass_edge -%}
    <div class="lawn-testimonial-custom__grass">
      {%- if grass_edge != blank -%}
        {{
          grass_edge
          | image_url: width: 2800
          | image_tag: loading: 'lazy', class: 'lawn-testimonial-custom__grass-img', alt: '', width: 2800, height: 360
        }}
      {%- else -%}
        <img
          class="lawn-testimonial-custom__grass-img"
          src="{{ 'testimonial-grass-strip.png' | asset_url }}"
          alt=""
          width="2800"
          height="360"
          loading="lazy"
        >
      {%- endif -%}
    </div>
  {%- endif -%}
</section>

<style>
  #shopify-section-{{ section.id }} {
    position: relative;
    z-index: 2;
    overflow: visible;
    background: #ffffff;
  }

  #lawn-testimonial-{{ section.id }} {
    position: relative;
    z-index: 1;
    width: 100%;
    height: var(--testimonial-height);
    min-height: var(--testimonial-height);
    overflow: visible;
    background: #ffffff;
    color: var(--testimonial-body);
  }

  #lawn-testimonial-{{ section.id }} *,
  #lawn-testimonial-{{ section.id }} *::before,
  #lawn-testimonial-{{ section.id }} *::after {
    box-sizing: border-box;
  }

  #lawn-testimonial-{{ section.id }} {
    -webkit-font-smoothing: antialiased;
    text-rendering: geometricPrecision;
  }

  #lawn-testimonial-{{ section.id }} .lawn-testimonial-custom__inner {
    position: relative;
    width: min(100%, var(--testimonial-width));
    height: var(--testimonial-height);
    margin-inline: auto;
    overflow: visible;
    isolation: isolate;
  }

  #lawn-testimonial-{{ section.id }} .lawn-testimonial-custom__inner::before,
  #lawn-testimonial-{{ section.id }} .lawn-testimonial-custom__inner::after {
    content: "";
    position: absolute;
    top: 0;
    bottom: 0;
    left: var(--testimonial-panel-left);
    right: calc(50% - 50vw);
    border-top-left-radius: var(--testimonial-panel-radius);
    pointer-events: none;
  }

  #lawn-testimonial-{{ section.id }} .lawn-testimonial-custom__inner::before {
    z-index: 1;
    background: var(--testimonial-panel-bg);
  }

  #lawn-testimonial-{{ section.id }} .lawn-testimonial-custom__inner::after {
    z-index: 2;
    background-image:
      linear-gradient(0deg, rgba(4, 51, 32, 0.38), rgba(4, 51, 32, 0.38)),
      var(--testimonial-texture);
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
    opacity: var(--testimonial-texture-opacity);
    filter: grayscale(1) contrast(1.28) brightness(0.9);
  }

  #lawn-testimonial-{{ section.id }} .lawn-testimonial-custom__person {
    position: absolute;
    top: var(--testimonial-person-top);
    left: var(--testimonial-person-left);
    z-index: 4;
    width: var(--testimonial-person-width);
    height: var(--testimonial-person-height);
    pointer-events: none;
  }

  #lawn-testimonial-{{ section.id }} .lawn-testimonial-custom__person-img {
    display: block;
    width: 100%;
    height: 100%;
    max-width: none;
    object-fit: contain;
    object-position: left top;
  }

  #lawn-testimonial-{{ section.id }} .lawn-testimonial-custom__content {
    position: absolute;
    top: var(--testimonial-content-top);
    left: var(--testimonial-content-left);
    z-index: 5;
    width: var(--testimonial-content-width);
  }

  #lawn-testimonial-{{ section.id }} .lawn-testimonial-custom__eyebrow {
    margin: 0 0 15px;
    color: var(--testimonial-primary);
    font-family: "Poppins", var(--font-body-family), Arial, sans-serif;
    font-size: 18px;
    line-height: 1.3;
    font-weight: 500;
    letter-spacing: 0;
  }

  #lawn-testimonial-{{ section.id }} .lawn-testimonial-custom__heading {
    margin: 0;
    max-width: 647px;
    color: var(--testimonial-heading);
    font-family: "Clash Grotesk", "Clash Display", var(--font-heading-family), "Poppins", Arial, sans-serif;
    font-size: var(--testimonial-heading-size);
    line-height: 64px;
    font-weight: 600;
    letter-spacing: -0.4px;
  }

  #lawn-testimonial-{{ section.id }} .lawn-testimonial-custom__card {
    position: relative;
    width: var(--testimonial-card-width);
    min-height: var(--testimonial-card-height);
    margin-top: var(--testimonial-card-gap);
    padding: 54px 37px 36px;
    border-radius: 28px;
    background: var(--testimonial-card-bg);
    color: #ffffff;
    box-shadow: 0 24px 55px rgba(0, 0, 0, 0.18);
  }

  #lawn-testimonial-{{ section.id }} .lawn-testimonial-custom__avatar {
    position: absolute;
    top: -42px;
    left: 52px;
    z-index: 3;
    width: 78px;
    height: 78px;
    padding: 4px;
    border-radius: 999px;
    background: #ffffff;
    box-shadow: 0 10px 25px rgba(0, 0, 0, 0.18);
  }

  #lawn-testimonial-{{ section.id }} .lawn-testimonial-custom__avatar-img {
    display: block;
    width: 100%;
    height: 100%;
    border-radius: inherit;
    object-fit: cover;
  }

  #lawn-testimonial-{{ section.id }} .lawn-testimonial-custom__quote-mark {
    position: absolute;
    top: -42px;
    right: 38px;
    z-index: 2;
    color: #ffffff;
    font-family: Georgia, "Times New Roman", serif;
    font-size: 126px;
    line-height: 1;
    font-weight: 700;
    pointer-events: none;
  }

  #lawn-testimonial-{{ section.id }} .lawn-testimonial-custom__quote {
    position: relative;
    z-index: 3;
    margin: 0;
    max-width: 533px;
    color: #ffffff;
    font-family: "Inter", var(--font-body-family), Arial, sans-serif;
    font-size: var(--testimonial-quote-size);
    line-height: 36px;
    font-weight: 400;
    font-style: italic;
    letter-spacing: 0;
  }

  #lawn-testimonial-{{ section.id }} .lawn-testimonial-custom__meta {
    position: relative;
    z-index: 3;
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 28px;
    margin-top: 26px;
  }

  #lawn-testimonial-{{ section.id }} .lawn-testimonial-custom__meta strong {
    display: block;
    color: #ffffff;
    font-family: "Inter", "Poppins", var(--font-body-family), Arial, sans-serif;
    font-size: 24px;
    line-height: 28px;
    font-weight: 600;
    letter-spacing: -0.2px;
  }

  #lawn-testimonial-{{ section.id }} .lawn-testimonial-custom__meta small {
    display: block;
    margin-top: 3px;
    color: #ffffff;
    font-family: "Inter", "Poppins", var(--font-body-family), Arial, sans-serif;
    font-size: 13px;
    line-height: 16px;
    font-weight: 400;
    letter-spacing: 0;
  }

  #lawn-testimonial-{{ section.id }} .lawn-testimonial-custom__stars {
    flex: 0 0 auto;
    color: #ffffff;
    font-size: 22px;
    line-height: 1;
    letter-spacing: 5px;
    white-space: nowrap;
  }

  #lawn-testimonial-{{ section.id }} .lawn-testimonial-custom__grass {
    position: absolute;
    left: 50%;
    bottom: 0;
    z-index: 8;
    width: 100vw;
    height: var(--testimonial-grass-height);
    transform: translateX(-50%);
    pointer-events: none;
  }

  #lawn-testimonial-{{ section.id }} .lawn-testimonial-custom__grass-img {
    display: block;
    width: 100%;
    height: 100%;
    max-width: none;
    margin-top: 47px;
  }

  @media screen and (max-width: 1279px) and (min-width: 990px) {
    #lawn-testimonial-{{ section.id }} {
      height: 760px;
      min-height: 760px;
    }

    #lawn-testimonial-{{ section.id }} .lawn-testimonial-custom__inner {
      width: 100%;
      height: 760px;
    }

    #lawn-testimonial-{{ section.id }} .lawn-testimonial-custom__inner::before,
    #lawn-testimonial-{{ section.id }} .lawn-testimonial-custom__inner::after {
      left: 21%;
      right: calc(50% - 50vw);
      border-top-left-radius: 42px;
    }

    #lawn-testimonial-{{ section.id }} .lawn-testimonial-custom__person {
      top: 18px;
      left: 0;
      width: 54vw;
      height: 760px;
    }

    #lawn-testimonial-{{ section.id }} .lawn-testimonial-custom__content {
      top: 122px;
      left: 44%;
      width: min(52vw, var(--testimonial-content-width));
    }

    #lawn-testimonial-{{ section.id }} .lawn-testimonial-custom__eyebrow {
      font-size: 16px;
      line-height: 1.3;
    }

    #lawn-testimonial-{{ section.id }} .lawn-testimonial-custom__heading {
      font-size: 44px;
      line-height: 54px;
    }

    #lawn-testimonial-{{ section.id }} .lawn-testimonial-custom__card {
      width: 100%;
      min-height: 300px;
      margin-top: 48px;
      padding: 52px 32px 32px;
    }

    #lawn-testimonial-{{ section.id }} .lawn-testimonial-custom__quote {
      font-size: 22px;
      line-height: 34px;
    }

    #lawn-testimonial-{{ section.id }} .lawn-testimonial-custom__grass {
      height: 132px;
    }
  }

  @media screen and (max-width: 989px) {
    #lawn-testimonial-{{ section.id }} {
      height: auto;
      min-height: auto;
      padding: 52px 20px 128px;
      overflow: hidden;
