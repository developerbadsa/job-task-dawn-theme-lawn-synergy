      line-height: 1.3;
    }

    #lawn-testimonial-{{ section.id }} .lawn-testimonial-custom__heading {
      font-size: clamp(36px, 7vw, 46px);
      line-height: 1.18;
      letter-spacing: -0.3px;
    }

    #lawn-testimonial-{{ section.id }} .lawn-testimonial-custom__card {
      width: 100%;
      min-height: auto;
      margin-top: 70px;
