{%- liquid
  assign person = section.settings.person_image
  assign avatar = section.settings.avatar_image
  assign bg_texture = section.settings.bg_texture_image
  assign grass_edge = section.settings.grass_edge_image

  assign person_alt = section.settings.person_alt | default: 'Customer holding Envy grass seed'
  assign avatar_alt = section.settings.avatar_alt | default: 'Customer avatar'

  assign eyebrow = section.settings.eyebrow | default: 'Real Results'
  assign heading = section.settings.heading | default: 'What Happens When You Use Better Grass Seed'
  assign quote = section.settings.quote | default: 'I overseeded last fall and saw germination within days. My lawn filled in thick, dark green, and looks better than neighbors who use standard store seed.'
  assign author_name = section.settings.author_name | default: 'Helena'
  assign author_role = section.settings.author_role | default: 'Model'
  assign stars = section.settings.stars | default: '★★★★★'

  assign texture_opacity = section.settings.texture_opacity | default: 18 | divided_by: 100.0

  if bg_texture != blank
    assign texture_url = bg_texture | image_url: width: 2400
  else
    assign texture_url = blank
  endif
-%}

<section
  id="lawn-testimonial-{{ section.id }}"
  class="lawn-testimonial-custom"
  style="
    --testimonial-panel-bg: {{ section.settings.panel_bg | default: '#043320' }};
    --testimonial-card-bg: {{ section.settings.card_bg | default: '#25AA6C' }};
    --testimonial-primary: {{ section.settings.primary_green | default: '#20B26B' }};
    --testimonial-heading: {{ section.settings.heading_color | default: '#FFFFFF' }};
    --testimonial-texture-opacity: {{ texture_opacity }};
    --testimonial-texture-image: {% if texture_url != blank %}url('{{ texture_url }}'){% else %}none{% endif %};
  "
>
  <div class="lawn-testimonial-custom__inner">
    <div class="lawn-testimonial-custom__panel"></div>

    <div class="lawn-testimonial-custom__person">
      {%- if person != blank -%}
        {{
          person
          | image_url: width: 1600
          | image_tag:
            loading: 'lazy',
            class: 'lawn-testimonial-custom__person-img',
            alt: person_alt,
            width: 1600,
            height: 1900
        }}
      {%- else -%}
        <img
          class="lawn-testimonial-custom__person-img"
          src="{{ 'testimonial-man.png' | asset_url }}"
          alt="{{ person_alt | escape }}"
          width="1600"
          height="1900"
          loading="lazy"
        >
      {%- endif -%}
    </div>

    <div class="lawn-testimonial-custom__content">
      {%- if eyebrow != blank -%}
        <p class="lawn-testimonial-custom__eyebrow">{{ eyebrow }}</p>
      {%- endif -%}

      {%- if heading != blank -%}
        <h2 class="lawn-testimonial-custom__heading">{{ heading }}</h2>
      {%- endif -%}

      <article class="lawn-testimonial-custom__card">
        <div class="lawn-testimonial-custom__avatar">
          {%- if avatar != blank -%}
            {{
              avatar
              | image_url: width: 220
              | image_tag:
                loading: 'lazy',
                class: 'lawn-testimonial-custom__avatar-img',
                alt: avatar_alt,
                width: 220,
                height: 220
            }}
          {%- else -%}
            <img
              class="lawn-testimonial-custom__avatar-img"
              src="{{ 'testimonial-avatar.png' | asset_url }}"
              alt="{{ avatar_alt | escape }}"
              width="220"
              height="220"
              loading="lazy"
            >
          {%- endif -%}
        </div>

        <span class="lawn-testimonial-custom__quote-mark">&rdquo;</span>

        {%- if quote != blank -%}
          <p class="lawn-testimonial-custom__quote">{{ quote }}</p>
        {%- endif -%}

        <div class="lawn-testimonial-custom__meta">
          <div class="lawn-testimonial-custom__author">
            {%- if author_name != blank -%}
              <strong>{{ author_name }}</strong>
            {%- endif -%}

            {%- if author_role != blank -%}
              <small>{{ author_role }}</small>
            {%- endif -%}
          </div>

          {%- if stars != blank -%}
            <span class="lawn-testimonial-custom__stars">{{ stars }}</span>
          {%- endif -%}
        </div>
      </article>
    </div>

    {%- if section.settings.show_grass_edge -%}
      <div class="lawn-testimonial-custom__grass">
        {%- if grass_edge != blank -%}
          {{
            grass_edge
            | image_url: width: 2800
            | image_tag:
              loading: 'lazy',
              class: 'lawn-testimonial-custom__grass-img',
              alt: '',
              width: 2800,
              height: 360
          }}
        {%- else -%}
          <img
            class="lawn-testimonial-custom__grass-img"
            src="{{ 'testimonial-grass-strip.png' | asset_url }}"
            alt=""
            width="2800"
            height="360"
            loading="lazy"
          >
        {%- endif -%}
      </div>
    {%- endif -%}
  </div>
</section>

<style>
  #shopify-section-{{ section.id }} {
    position: relative;
    z-index: 2;
    overflow: hidden;
    background: #ffffff;
  }

  #lawn-testimonial-{{ section.id }} {
    position: relative;
    z-index: 1;
    width: 100%;
    height: 891px;
    min-height: 891px;
    overflow: hidden;
    background: #ffffff;
    color: #ffffff;
  }

  #lawn-testimonial-{{ section.id }} *,
  #lawn-testimonial-{{ section.id }} *::before,
  #lawn-testimonial-{{ section.id }} *::after {
    box-sizing: border-box;
  }

  #lawn-testimonial-{{ section.id }} .lawn-testimonial-custom__inner {
    position: relative;
    width: min(100%, 1440px);
    height: 891px;
    margin-inline: auto;
    overflow: visible;
  }

  #lawn-testimonial-{{ section.id }} .lawn-testimonial-custom__panel {
    position: absolute;
    top: 0;
    right: 0;
    bottom: 0;
    left: 301px;
    z-index: 1;
    overflow: hidden;
    border-top-left-radius: 50px;
    background-color: var(--testimonial-panel-bg);
  }

  #lawn-testimonial-{{ section.id }} .lawn-testimonial-custom__panel::before {
    content: "";
    position: absolute;
    inset: 0;
    z-index: 1;
    background-image:
      var(--testimonial-texture-image),
      radial-gradient(circle at 26% 18%, rgba(255, 255, 255, 0.16), transparent 28%),
      linear-gradient(135deg, rgba(255, 255, 255, 0.08) 0 1px, transparent 1px 18px);
    background-size: cover, 100% 100%, 22px 22px;
    background-position: center;
    background-repeat: no-repeat, no-repeat, repeat;
    opacity: var(--testimonial-texture-opacity);
    pointer-events: none;
  }

  #lawn-testimonial-{{ section.id }} .lawn-testimonial-custom__panel::after {
    content: "";
    position: absolute;
    inset: 0;
    z-index: 2;
    background:
      radial-gradient(circle at 38% 14%, rgba(255, 255, 255, 0.055), transparent 35%),
      linear-gradient(180deg, rgba(0, 0, 0, 0.03), rgba(0, 0, 0, 0.12));
    pointer-events: none;
  }

  #lawn-testimonial-{{ section.id }} .lawn-testimonial-custom__person {
    position: absolute;
    top: 0;
    left: 18px;
    z-index: 4;
    width: 779px;
    height: 905px;
    pointer-events: none;
  }

  #lawn-testimonial-{{ section.id }} .lawn-testimonial-custom__person-img {
    display: block;
    width: 100%;
    height: 100%;
    max-width: none;
    object-fit: contain;
    object-position: left top;
  }

  #lawn-testimonial-{{ section.id }} .lawn-testimonial-custom__content {
    position: absolute;
    top: 156px;
    left: 711px;
    z-index: 5;
    width: 647px;
  }

  #lawn-testimonial-{{ section.id }} .lawn-testimonial-custom__eyebrow {
    margin: 0 0 12px;
    color: var(--testimonial-primary);
    font-family: "Poppins", var(--font-body-family), Arial, sans-serif;
    font-size: 15px;
    line-height: 1.2;
    font-weight: 700;
    letter-spacing: -0.02em;
  }

  #lawn-testimonial-{{ section.id }} .lawn-testimonial-custom__heading {
    margin: 0;
    max-width: 647px;
    color: var(--testimonial-heading);
    font-family: "Clash Grotesk", "Poppins", var(--font-heading-family), Arial, sans-serif;
    font-size: 48px;
    line-height: 1.16;
    font-weight: 700;
    letter-spacing: -0.045em;
  }

  #lawn-testimonial-{{ section.id }} .lawn-testimonial-custom__card {
    position: relative;
    width: 647px;
    min-height: 328px;
    margin-top: 50px;
    padding: 64px 38px 34px;
    border-radius: 28px;
    background: var(--testimonial-card-bg);
    color: #ffffff;
    box-shadow: 0 24px 55px rgba(0, 0, 0, 0.12);
  }

  #lawn-testimonial-{{ section.id }} .lawn-testimonial-custom__avatar {
    position: absolute;
    top: -42px;
    left: 52px;
    z-index: 3;
    width: 78px;
    height: 78px;
    padding: 4px;
    border-radius: 999px;
    background: #ffffff;
    box-shadow: 0 10px 25px rgba(0, 0, 0, 0.18);
  }

  #lawn-testimonial-{{ section.id }} .lawn-testimonial-custom__avatar-img {
    display: block;
    width: 100%;
    height: 100%;
    border-radius: inherit;
    object-fit: cover;
  }

  #lawn-testimonial-{{ section.id }} .lawn-testimonial-custom__quote-mark {
    position: absolute;
    top: -42px;
    right: 38px;
    z-index: 2;
    color: #ffffff;
    font-family: Georgia, "Times New Roman", serif;
    font-size: 126px;
    line-height: 1;
    font-weight: 700;
    pointer-events: none;
  }

  #lawn-testimonial-{{ section.id }} .lawn-testimonial-custom__quote {
    position: relative;
    z-index: 3;
    margin: 0;
    max-width: 535px;
    color: #ffffff;
    font-family: "Poppins", var(--font-body-family), Arial, sans-serif;
    font-size: 24px;
    line-height: 1.45;
    font-weight: 500;
    font-style: italic;
    letter-spacing: -0.03em;
  }

  #lawn-testimonial-{{ section.id }} .lawn-testimonial-custom__meta {
    position: relative;
    z-index: 3;
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    gap: 28px;
    margin-top: 32px;
  }

  #lawn-testimonial-{{ section.id }} .lawn-testimonial-custom__meta strong {
    display: block;
    color: #ffffff;
    font-family: "Poppins", var(--font-body-family), Arial, sans-serif;
    font-size: 24px;
    line-height: 1.1;
    font-weight: 700;
    letter-spacing: -0.03em;
  }

  #lawn-testimonial-{{ section.id }} .lawn-testimonial-custom__meta small {
    display: block;
    margin-top: 5px;
    color: #ffffff;
    font-family: "Poppins", var(--font-body-family), Arial, sans-serif;
    font-size: 12px;
    line-height: 1.2;
    font-weight: 500;
  }

  #lawn-testimonial-{{ section.id }} .lawn-testimonial-custom__stars {
    flex: 0 0 auto;
    color: #ffffff;
    font-size: 22px;
    line-height: 1;
    letter-spacing: 5px;
    white-space: nowrap;
  }

  #lawn-testimonial-{{ section.id }} .lawn-testimonial-custom__grass {
    position: absolute;
    left: 50%;
    bottom: 0;
    z-index: 8;
    width: 100vw;
    height: 148px;
    transform: translateX(-50%);
    pointer-events: none;
  }

  #lawn-testimonial-{{ section.id }} .lawn-testimonial-custom__grass-img {
    display: block;
    width: 100%;
    height: 100%;
    max-width: none;
    object-fit: cover;
    object-position: center bottom;
  }

  @media screen and (max-width: 1439px) and (min-width: 990px) {
    #lawn-testimonial-{{ section.id }} {
      height: 760px;
      min-height: 760px;
    }

    #lawn-testimonial-{{ section.id }} .lawn-testimonial-custom__inner {
      width: 100%;
      height: 760px;
    }

    #lawn-testimonial-{{ section.id }} .lawn-testimonial-custom__panel {
      left: 21%;
      border-top-left-radius: 42px;
    }

    #lawn-testimonial-{{ section.id }} .lawn-testimonial-custom__person {
      top: 10px;
      left: 0;
      width: 56vw;
      height: 760px;
    }

    #lawn-testimonial-{{ section.id }} .lawn-testimonial-custom__content {
      top: 120px;
      left: 50%;
      width: min(46vw, 647px);
    }

    #lawn-testimonial-{{ section.id }} .lawn-testimonial-custom__heading {
      font-size: 42px;
    }

    #lawn-testimonial-{{ section.id }} .lawn-testimonial-custom__card {
      width: 100%;
      min-height: 300px;
      margin-top: 44px;
    }

    #lawn-testimonial-{{ section.id }} .lawn-testimonial-custom__quote {
      font-size: 21px;
    }

    #lawn-testimonial-{{ section.id }} .lawn-testimonial-custom__grass {
      height: 132px;
    }
  }

  @media screen and (max-width: 989px) {
    #lawn-testimonial-{{ section.id }} {
      height: auto;
      min-height: auto;
      padding: 52px 20px 128px;
      overflow: hidden;
      background: var(--testimonial-panel-bg);
    }

    #lawn-testimonial-{{ section.id }} .lawn-testimonial-custom__inner {
      width: min(100%, 640px);
      height: auto;
      margin-inline: auto;
      overflow: visible;
    }

    #lawn-testimonial-{{ section.id }} .lawn-testimonial-custom__panel {
      inset: -52px -20px -128px;
      left: -20px;
      right: -20px;
      border-radius: 0;
    }

    #lawn-testimonial-{{ section.id }} .lawn-testimonial-custom__person,
    #lawn-testimonial-{{ section.id }} .lawn-testimonial-custom__content {
      position: relative;
      inset: auto;
      width: 100%;
    }

    #lawn-testimonial-{{ section.id }} .lawn-testimonial-custom__person {
      z-index: 4;
      max-width: 430px;
      height: auto;
      margin: 0 auto 36px;
    }

    #lawn-testimonial-{{ section.id }} .lawn-testimonial-custom__person-img {
      width: 100%;
      height: auto;
      object-fit: contain;
    }

    #lawn-testimonial-{{ section.id }} .lawn-testimonial-custom__content {
      z-index: 5;
    }

    #lawn-testimonial-{{ section.id }} .lawn-testimonial-custom__heading {
      font-size: clamp(36px, 8vw, 48px);
    }

    #lawn-testimonial-{{ section.id }} .lawn-testimonial-custom__card {
      width: 100%;
      min-height: auto;
      margin-top: 70px;
      padding: 58px 26px 30px;
    }

    #lawn-testimonial-{{ section.id }} .lawn-testimonial-custom__quote {
      font-size: 20px;
    }

    #lawn-testimonial-{{ section.id }} .lawn-testimonial-custom__grass {
      height: 122px;
    }
  }

  @media screen and (max-width: 575px) {
    #lawn-testimonial-{{ section.id }} {
      padding: 44px 16px 110px;
    }

    #lawn-testimonial-{{ section.id }} .lawn-testimonial-custom__eyebrow {
      margin-bottom: 12px;
      font-size: 14px;
    }

    #lawn-testimonial-{{ section.id }} .lawn-testimonial-custom__heading {
      font-size: 34px;
      line-height: 1.18;
    }

    #lawn-testimonial-{{ section.id }} .lawn-testimonial-custom__quote {
      font-size: 18px;
      line-height: 1.45;
    }

    #lawn-testimonial-{{ section.id }} .lawn-testimonial-custom__meta {
      display: block;
    }

    #lawn-testimonial-{{ section.id }} .lawn-testimonial-custom__stars {
      display: block;
      margin-top: 20px;
      font-size: 18px;
      letter-spacing: 4px;
    }

    #lawn-testimonial-{{ section.id }} .lawn-testimonial-custom__quote-mark {
      top: -30px;
      right: 24px;
      font-size: 88px;
    }

    #lawn-testimonial-{{ section.id }} .lawn-testimonial-custom__avatar {
      left: 28px;
      width: 68px;
      height: 68px;
    }
  }
</style>

{% schema %}
{
  "name": "Lawn — Testimonial",
  "tag": "section",
  "class": "lawn-testimonial-section",
  "settings": [
    {
      "type": "header",
      "content": "Images"
    },
    {
      "type": "image_picker",
      "id": "person_image",
      "label": "Person photo"
    },
    {
      "type": "text",
      "id": "person_alt",
      "label": "Person alt text",
      "default": "Customer holding Envy grass seed"
    },
    {
      "type": "image_picker",
      "id": "bg_texture_image",
      "label": "Background texture image"
    },
    {
      "type": "range",
      "id": "texture_opacity",
      "label": "Texture opacity",
      "min": 0,
      "max": 40,
      "step": 1,
      "unit": "%",
      "default": 18
    },
    {
      "type": "image_picker",
      "id": "grass_edge_image",
      "label": "Bottom grass image"
    },
    {
      "type": "checkbox",
      "id": "show_grass_edge",
      "label": "Show bottom grass image",
      "default": true
    },
    {
      "type": "image_picker",
      "id": "avatar_image",
      "label": "Avatar"
    },
    {
      "type": "text",
      "id": "avatar_alt",
      "label": "Avatar alt text",
      "default": "Customer avatar"
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Real Results"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "What Happens When You Use Better Grass Seed"
    },
    {
      "type": "textarea",
      "id": "quote",
      "label": "Quote",
      "default": "I overseeded last fall and saw germination within days. My lawn filled in thick, dark green, and looks better than neighbors who use standard store seed."
    },
    {
      "type": "text",
      "id": "author_name",
      "label": "Author name",
      "default": "Helena"
    },
    {
      "type": "text",
      "id": "author_role",
      "label": "Author role",
      "default": "Model"
    },
    {
      "type": "text",
      "id": "stars",
      "label": "Stars",
      "default": "★★★★★"
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "panel_bg",
      "label": "Dark green background",
      "default": "#043320"
    },
    {
      "type": "color",
      "id": "card_bg",
      "label": "Quote card background",
      "default": "#25AA6C"
    },
    {
      "type": "color",
      "id": "primary_green",
      "label": "Eyebrow green",
      "default": "#20B26B"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading color",
      "default": "#FFFFFF"
    }
  ],
  "presets": [
    {
      "name": "Lawn — Testimonial"
    }
  ]
}
{% endschema %}