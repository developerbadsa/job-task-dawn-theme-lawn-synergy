{%- liquid
  assign section_title = section.settings.heading | default: 'What Makes Envy Different From Other Grass Seeds?'
  assign section_eyebrow = section.settings.eyebrow | default: 'Premium Difference'
  assign photo_alt = section.settings.photo_alt | default: 'Lawn specialist holding grass seed product'
-%}

<section id="PremiumDifference-{{ section.id }}" class="premium-difference-section">
  <div class="premium-difference__stage">
    <div class="premium-difference__header">
      {%- if section_eyebrow != blank -%}
        <p class="premium-difference__eyebrow">{{ section_eyebrow }}</p>
      {%- endif -%}

      {%- if section_title != blank -%}
        <h2 class="premium-difference__heading">{{ section_title }}</h2>
      {%- endif -%}
    </div>

    <article class="premium-difference-card premium-difference-card--one">
      <span class="premium-difference-card__icon" aria-hidden="true">
        {%- case section.settings.card_1_icon -%}
          {%- when 'chart' -%}
            <svg viewBox="0 0 32 32"><path d="M8 22v-6M15 22V9M22 22V5"/><path d="M6 25h20M20 7l4-4 3 4"/></svg>
          {%- when 'seed' -%}
            <svg viewBox="0 0 32 32"><path d="M11 18c-4 1-6 4-6 7 4 1 8-1 10-5"/><path d="M20 13c-3-3-3-7 0-10 4 2 5 6 3 10"/><path d="M19 22c2-4 6-5 10-3-1 5-5 7-10 6"/></svg>
          {%- else -%}
            <svg viewBox="0 0 32 32"><path d="M7 23c1.2-7 3.4-11.8 7.4-16"/><path d="M15 23c.4-6 2-10.5 5.2-14"/><path d="M22 23c-.2-5.2.9-9.5 3.8-13"/><path d="M5 24h22"/></svg>
        {%- endcase -%}
      </span>
      <svg class="premium-difference-card__mark" viewBox="0 0 120 96" aria-hidden="true">
        <path d="M9 88c4-29 16-55 39-77M45 90c-1-26 8-49 29-69M82 90c-5-22 2-42 22-60"/>
        <path d="M26 88C23 65 15 48 1 36M58 91C54 63 42 43 23 28M99 89C93 63 79 45 59 33"/>
      </svg>
      <h3>{{ section.settings.card_1_title | default: 'Thicker, Denser Turf' }}</h3>
      <p>{{ section.settings.card_1_text | default: 'Selected For Improved Lawn Density, Creating A Smoother, Thicker, More Uniform Appearance Across Your Entire Lawn.' }}</p>
    </article>

    <article class="premium-difference-card premium-difference-card--two">
      <span class="premium-difference-card__icon" aria-hidden="true">
        {%- case section.settings.card_2_icon -%}
          {%- when 'chart' -%}
            <svg viewBox="0 0 32 32"><path d="M8 22v-6M15 22V9M22 22V5"/><path d="M6 25h20M20 7l4-4 3 4"/></svg>
          {%- when 'seed' -%}
            <svg viewBox="0 0 32 32"><path d="M11 18c-4 1-6 4-6 7 4 1 8-1 10-5"/><path d="M20 13c-3-3-3-7 0-10 4 2 5 6 3 10"/><path d="M19 22c2-4 6-5 10-3-1 5-5 7-10 6"/></svg>
          {%- else -%}
            <svg viewBox="0 0 32 32"><path d="M7 23c1.2-7 3.4-11.8 7.4-16"/><path d="M15 23c.4-6 2-10.5 5.2-14"/><path d="M22 23c-.2-5.2.9-9.5 3.8-13"/><path d="M5 24h22"/></svg>
        {%- endcase -%}
      </span>
      <svg class="premium-difference-card__mark" viewBox="0 0 120 96" aria-hidden="true">
        <path d="M9 88c4-29 16-55 39-77M45 90c-1-26 8-49 29-69M82 90c-5-22 2-42 22-60"/>
        <path d="M26 88C23 65 15 48 1 36M58 91C54 63 42 43 23 28M99 89C93 63 79 45 59 33"/>
      </svg>
      <h3>{{ section.settings.card_2_title | default: 'Ultra-Dark Green' }}</h3>
      <p>{{ section.settings.card_2_text | default: 'Elite Varieties Chosen For Deep, Rich Green Color That Stands Out Beautifully In Any Lawn Setting.' }}</p>
    </article>

    <article class="premium-difference-card premium-difference-card--three">
      <span class="premium-difference-card__icon" aria-hidden="true">
        {%- case section.settings.card_3_icon -%}
          {%- when 'grass' -%}
            <svg viewBox="0 0 32 32"><path d="M7 23c1.2-7 3.4-11.8 7.4-16"/><path d="M15 23c.4-6 2-10.5 5.2-14"/><path d="M22 23c-.2-5.2.9-9.5 3.8-13"/><path d="M5 24h22"/></svg>
          {%- when 'seed' -%}
            <svg viewBox="0 0 32 32"><path d="M11 18c-4 1-6 4-6 7 4 1 8-1 10-5"/><path d="M20 13c-3-3-3-7 0-10 4 2 5 6 3 10"/><path d="M19 22c2-4 6-5 10-3-1 5-5 7-10 6"/></svg>
          {%- else -%}
            <svg viewBox="0 0 32 32"><path d="M8 22v-6M15 22V9M22 22V5"/><path d="M6 25h20M20 7l4-4 3 4"/></svg>
        {%- endcase -%}
      </span>
      <svg class="premium-difference-card__mark" viewBox="0 0 120 96" aria-hidden="true">
        <path d="M9 88c4-29 16-55 39-77M45 90c-1-26 8-49 29-69M82 90c-5-22 2-42 22-60"/>
        <path d="M26 88C23 65 15 48 1 36M58 91C54 63 42 43 23 28M99 89C93 63 79 45 59 33"/>
      </svg>
      <h3>{{ section.settings.card_3_title | default: 'Improved Fill-In' }}</h3>
      <p>{{ section.settings.card_3_text | default: 'Helps Reduce Thin, Patchy Areas Faster Compared To Standard Tall Fescue Blends Used In Lawns.' }}</p>
    </article>

    <article class="premium-difference-card premium-difference-card--four premium-difference-card--green">
      <span class="premium-difference-card__icon" aria-hidden="true">
        {%- case section.settings.card_4_icon -%}
          {%- when 'chart' -%}
            <svg viewBox="0 0 32 32"><path d="M8 22v-6M15 22V9M22 22V5"/><path d="M6 25h20M20 7l4-4 3 4"/></svg>
          {%- when 'grass' -%}
            <svg viewBox="0 0 32 32"><path d="M7 23c1.2-7 3.4-11.8 7.4-16"/><path d="M15 23c.4-6 2-10.5 5.2-14"/><path d="M22 23c-.2-5.2.9-9.5 3.8-13"/><path d="M5 24h22"/></svg>
          {%- else -%}
            <svg viewBox="0 0 32 32"><path d="M11 18c-4 1-6 4-6 7 4 1 8-1 10-5"/><path d="M20 13c-3-3-3-7 0-10 4 2 5 6 3 10"/><path d="M19 22c2-4 6-5 10-3-1 5-5 7-10 6"/></svg>
        {%- endcase -%}
      </span>
      <svg class="premium-difference-card__mark" viewBox="0 0 120 96" aria-hidden="true">
        <path d="M9 88c4-29 16-55 39-77M45 90c-1-26 8-49 29-69M82 90c-5-22 2-42 22-60"/>
        <path d="M26 88C23 65 15 48 1 36M58 91C54 63 42 43 23 28M99 89C93 63 79 45 59 33"/>
      </svg>
      <h3>{{ section.settings.card_4_title | default: '0% Weed Seed' }}</h3>
      <p>{{ section.settings.card_4_text | default: 'Clean, High-Quality Seed With Zero Weed Seeds And No Unnecessary Fillers For Better Lawn Results.' }}</p>
    </article>

    <div class="premium-difference__photo">
      {%- if section.settings.photo != blank -%}
        {{ section.settings.photo | image_url: width: 1000 | image_tag: loading: 'lazy', alt: photo_alt, widths: '480, 740, 1000', sizes: '(min-width: 750px) 370px, 100vw' }}
      {%- else -%}
        {{ 'image' | placeholder_svg_tag: 'premium-difference__placeholder' }}
      {%- endif -%}
    </div>

    {%- if section.settings.show_badge -%}
      <div class="premium-difference__badge" aria-hidden="true">
        <svg viewBox="0 0 76 76">
          <circle cx="38" cy="38" r="35"/>
          <path d="M18 56c2-18 8-32 19-42M36 57c0-16 5-29 17-39M53 57c-3-15 1-27 12-36"/>
          <path d="M20 57C18 43 13 34 6 27M42 58C39 41 31 29 19 21M64 56C60 42 51 30 39 25"/>
        </svg>
      </div>
    {%- endif -%}
  </div>
</section>

{% style %}
  #PremiumDifference-{{ section.id }} {
    --premium-difference-bg: {{ section.settings.background_color | default: '#EFF9F4' }};
    --premium-difference-dark: {{ section.settings.dark_color | default: '#063D2B' }};
    --premium-difference-green: {{ section.settings.green_color | default: '#22B86F' }};
    --premium-difference-card-green: {{ section.settings.card_green_color | default: '#63C69A' }};
    --premium-difference-text: {{ section.settings.text_color | default: '#21352E' }};
    --premium-difference-white: #ffffff;
    background: var(--premium-difference-bg);
    color: var(--premium-difference-text);
    font-family: var(--font-body-family, Inter, Arial, sans-serif);
    overflow: hidden;
  }

  #PremiumDifference-{{ section.id }} *,
  #PremiumDifference-{{ section.id }} *::before,
  #PremiumDifference-{{ section.id }} *::after {
    box-sizing: border-box;
  }

  #PremiumDifference-{{ section.id }} .premium-difference__stage {
    position: relative;
    width: min({{ section.settings.max_width }}px, 100vw);
    height: {{ section.settings.section_height }}px;
    margin: 0 auto;
  }

  #PremiumDifference-{{ section.id }} .premium-difference__header {
    position: absolute;
    top: 78px;
    left: 52px;
    width: 560px;
    z-index: 5;
  }

  #PremiumDifference-{{ section.id }} .premium-difference__eyebrow {
    margin: 0 0 9px;
    color: var(--premium-difference-green);
    font-size: 12px;
    line-height: 1.15;
    font-weight: 600;
    letter-spacing: -.1px;
  }

  #PremiumDifference-{{ section.id }} .premium-difference__heading {
    max-width: 545px;
    margin: 0;
    color: var(--premium-difference-dark);
    font-family: var(--font-heading-family, Inter, Arial, sans-serif);
    font-size: 32px;
    line-height: 1.22;
    font-weight: 900;
    letter-spacing: -1.35px;
  }

  #PremiumDifference-{{ section.id }} .premium-difference-card {
    position: absolute;
    z-index: 10;
    width: 205px;
    height: 190px;
    padding: 80px 14px 18px;
    border-radius: 10px;
    background: var(--premium-difference-white);
    color: var(--premium-difference-text);
    overflow: hidden;
  }

  #PremiumDifference-{{ section.id }} .premium-difference-card--one {
    left: 52px;
    top: 210px;
  }

  #PremiumDifference-{{ section.id }} .premium-difference-card--two {
    left: 277px;
    top: 248px;
  }

  #PremiumDifference-{{ section.id }} .premium-difference-card--three {
    left: 52px;
    top: 418px;
  }

  #PremiumDifference-{{ section.id }} .premium-difference-card--four {
    left: 277px;
    top: 456px;
  }

  #PremiumDifference-{{ section.id }} .premium-difference-card--green {
    background: var(--premium-difference-card-green);
    color: #fff;
    box-shadow: 0 18px 28px rgba(36, 114, 82, .23);
  }

  #PremiumDifference-{{ section.id }} .premium-difference-card__icon {
    position: absolute;
    top: 28px;
    left: 13px;
    z-index: 2;
    width: 50px;
    height: 50px;
    display: grid;
    place-items: center;
    border-radius: 999px;
    background: #fff;
    color: var(--premium-difference-green);
    box-shadow: 0 8px 18px rgba(7, 60, 43, .09);
  }

  #PremiumDifference-{{ section.id }} .premium-difference-card--green .premium-difference-card__icon {
    color: var(--premium-difference-green);
  }

  #PremiumDifference-{{ section.id }} .premium-difference-card__icon svg {
    width: 26px;
    height: 26px;
    display: block;
    fill: none;
    stroke: currentColor;
    stroke-width: 2.2;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  #PremiumDifference-{{ section.id }} .premium-difference-card__mark {
    position: absolute;
    top: 31px;
    right: 4px;
    width: 98px;
    height: 82px;
    fill: none;
    stroke: var(--premium-difference-green);
    stroke-width: 4.5;
    stroke-linecap: round;
    stroke-linejoin: round;
    opacity: .10;
  }

  #PremiumDifference-{{ section.id }} .premium-difference-card--green .premium-difference-card__mark {
    stroke: #198957;
    opacity: .06;
  }

  #PremiumDifference-{{ section.id }} .premium-difference-card h3 {
    position: relative;
    z-index: 2;
    margin: 0 0 11px;
    color: var(--premium-difference-dark);
    font-family: var(--font-heading-family, Inter, Arial, sans-serif);
    font-size: 17px;
    line-height: 1.18;
    font-weight: 900;
    letter-spacing: -.55px;
  }

  #PremiumDifference-{{ section.id }} .premium-difference-card--green h3 {
    color: #fff;
    font-size: 20px;
    line-height: 1.05;
    letter-spacing: -.7px;
  }

  #PremiumDifference-{{ section.id }} .premium-difference-card p {
    position: relative;
    z-index: 2;
    margin: 0;
    color: #263730;
    font-size: 11.5px;
    line-height: 1.55;
    font-weight: 600;
    letter-spacing: -.08px;
  }

  #PremiumDifference-{{ section.id }} .premium-difference-card--green p {
    color: #fff;
    font-size: 12px;
    line-height: 1.55;
    font-weight: 600;
  }

  #PremiumDifference-{{ section.id }} .premium-difference__photo {
    position: absolute;
    left: 465px;
    top: 193px;
    z-index: 3;
    width: 370px;
    height: 428px;
    border-radius: 11px;
    overflow: hidden;
    background: #dceee6;
  }

  #PremiumDifference-{{ section.id }} .premium-difference__photo img,
  #PremiumDifference-{{ section.id }} .premium-difference__photo svg {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: cover;
  }

  #PremiumDifference-{{ section.id }} .premium-difference__placeholder {
    background: #dceee6;
    color: rgba(6, 61, 43, .22);
  }

  #PremiumDifference-{{ section.id }} .premium-difference__badge {
    position: absolute;
    left: 789px;
    top: 270px;
    z-index: 12;
    width: 86px;
    height: 86px;
    display: grid;
    place-items: center;
    border-radius: 999px;
    background: #fff;
    box-shadow: 0 4px 14px rgba(4, 45, 31, .04);
  }

  #PremiumDifference-{{ section.id }} .premium-difference__badge svg {
    width: 78px;
    height: 78px;
    fill: none;
  }

  #PremiumDifference-{{ section.id }} .premium-difference__badge circle {
    stroke: var(--premium-difference-green);
    stroke-width: 1;
    stroke-dasharray: 2.4 3;
  }

  #PremiumDifference-{{ section.id }} .premium-difference__badge path {
    stroke: var(--premium-difference-green);
    stroke-width: 1.45;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  @media (max-width: 940px) {
    #PremiumDifference-{{ section.id }} .premium-difference__stage {
      transform-origin: top center;
    }
  }

  @media (max-width: 749px) {
    #PremiumDifference-{{ section.id }} {
      padding: 48px 20px 56px;
    }

    #PremiumDifference-{{ section.id }} .premium-difference__stage {
      width: 100%;
      height: auto;
      display: grid;
      gap: 18px;
    }

    #PremiumDifference-{{ section.id }} .premium-difference__header,
    #PremiumDifference-{{ section.id }} .premium-difference-card,
    #PremiumDifference-{{ section.id }} .premium-difference__photo,
    #PremiumDifference-{{ section.id }} .premium-difference__badge {
      position: relative;
      inset: auto;
    }

    #PremiumDifference-{{ section.id }} .premium-difference__header {
      width: 100%;
      margin-bottom: 6px;
    }

    #PremiumDifference-{{ section.id }} .premium-difference__heading {
      max-width: 100%;
      font-size: 30px;
      line-height: 1.17;
    }

    #PremiumDifference-{{ section.id }} .premium-difference__photo {
      order: 2;
      width: 100%;
      height: auto;
      aspect-ratio: 370 / 428;
    }

    #PremiumDifference-{{ section.id }} .premium-difference-card {
      order: 3;
      width: 100%;
      height: auto;
      min-height: 174px;
      padding: 82px 18px 22px;
    }

    #PremiumDifference-{{ section.id }} .premium-difference__badge {
      display: none;
    }
  }
{% endstyle %}

