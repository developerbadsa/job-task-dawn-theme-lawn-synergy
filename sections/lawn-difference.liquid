{%- liquid
  assign photo = section.settings.photo
-%}

<section class="difference">
  <div class="container">
    {%- if section.settings.eyebrow != blank -%}
      <p class="eyebrow">{{ section.settings.eyebrow }}</p>
    {%- endif -%}
    <h2>{{ section.settings.heading | default: 'What Makes Envy Different From Other Grass Seeds?' }}</h2>

    <div class="difference-grid">
      <div class="benefit-cards">
        {%- for block in section.blocks -%}
          {%- if block.type == 'card' -%}
            {%- assign card_classes = 'benefit-card' -%}
            {%- if block.settings.offset -%}
              {%- assign card_classes = card_classes | append: ' offset' -%}
            {%- endif -%}
            {%- if block.settings.style == 'green' -%}
              {%- assign card_classes = card_classes | append: ' green' -%}
            {%- endif -%}
            <article class="{{ card_classes }}" {{ block.shopify_attributes }}>
              <span class="mini-icon {{ block.settings.icon_class }}"></span>
              <h3>{{ block.settings.title }}</h3>
              <p>{{ block.settings.text }}</p>
            </article>
          {%- endif -%}
        {%- endfor -%}
      </div>

      <div class="difference-photo">
        {%- if photo != blank -%}
          {{ photo | image_url: width: 1200 | image_tag:
            loading: 'lazy',
            alt: section.settings.photo_alt | default: 'Lawn specialist',
            width: 1200,
            height: 1200
          }}
        {%- else -%}
          <img src="{{ 'difference-man.png' | asset_url }}"
               alt="{{ section.settings.photo_alt | default: 'Lawn Synergy specialist holding Envy grass seed' }}"
               width="1200" height="1200">
        {%- endif -%}
      </div>
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Lawn — Difference",
  "tag": "section",
  "class": "lawn-difference-section",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Premium Difference"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "What Makes Envy Different From Other Grass Seeds?"
    },
    {
      "type": "image_picker",
      "id": "photo",
      "label": "Right photo"
    },
    {
      "type": "text",
      "id": "photo_alt",
      "label": "Photo alt text",
      "default": "Lawn Synergy specialist holding Envy grass seed"
    }
  ],
  "blocks": [
    {
      "type": "card",
      "name": "Benefit card",
      "settings": [
        {
          "type": "select",
          "id": "icon_class",
          "label": "Icon style",
          "options": [
            { "value": "grass-icon", "label": "Sparkle" },
            { "value": "chart-icon", "label": "Chart" },
            { "value": "seed-icon", "label": "Seed (dot)" }
          ],
          "default": "grass-icon"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Thicker, Denser Turf"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Description",
          "default": "Selected For Improved Lawn Density, Creating A Smoother, Thicker, More Uniform Appearance Across Your Entire Lawn."
        },
        {
          "type": "checkbox",
          "id": "offset",
          "label": "Offset card downward",
          "default": false
        },
        {
          "type": "select",
          "id": "style",
          "label": "Color style",
          "options": [
            { "value": "default", "label": "White" },
            { "value": "green", "label": "Green" }
          ],
          "default": "default"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Lawn — Difference",
      "blocks": [
        { "type": "card", "settings": { "icon_class": "grass-icon", "title": "Thicker, Denser Turf", "text": "Selected For Improved Lawn Density, Creating A Smoother, Thicker, More Uniform Appearance Across Your Entire Lawn." } },
        { "type": "card", "settings": { "icon_class": "grass-icon", "title": "Ultra-Dark Green", "text": "Elite Varieties Chosen For Deep, Rich Green Color That Stands Out Beautifully In Any Lawn Setting.", "offset": true } },
        { "type": "card", "settings": { "icon_class": "chart-icon", "title": "Improved Fill-In", "text": "Helps Reduce Thin, Patchy Areas Faster Compared To Standard Tall Fescue Blends Used In Lawns." } },
        { "type": "card", "settings": { "icon_class": "seed-icon", "title": "0% Weed Seed", "text": "Clean, High-Quality Seed With Zero Weed Seeds And No Unnecessary Fillers For Better Lawn Results.", "offset": true, "style": "green" } }
      ]
    }
  ]
}
{% endschema %}
