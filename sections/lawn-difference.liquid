{%- liquid
  assign photo = section.settings.photo
  assign badge_image = section.settings.badge_image
-%}

<section
  id="difference-{{ section.id }}"
  class="difference-section"
  style="
    --section-bg: {{ section.settings.background_color }};
    --container-width: {{ section.settings.container_width }}px;
    --text-color: {{ section.settings.text_color }};
    --accent-color: {{ section.settings.accent_color }};
    --card-bg: {{ section.settings.card_background }};
    --green-card-bg: {{ section.settings.green_card_background }};
    --card-radius: {{ section.settings.card_radius }}px;
  "
>
  <div class="difference-section__inner">
    <div class="difference-section__header">
      {%- if section.settings.eyebrow != blank -%}
        <p class="difference-section__eyebrow">{{ section.settings.eyebrow }}</p>
      {%- endif -%}

      {%- if section.settings.heading != blank -%}
        <h2 class="difference-section__heading">{{ section.settings.heading }}</h2>
      {%- endif -%}
    </div>

    <div class="difference-section__layout">
      <div class="difference-section__cards">
        {%- for block in section.blocks limit: 4 -%}
          {%- if block.type == 'card' -%}
            {%- liquid
              assign is_green = false
              if block.settings.style == 'green'
                assign is_green = true
              endif
              if forloop.index == 4
                assign is_green = true
              endif
            -%}

            <article
              class="difference-card difference-card--{{ forloop.index }}{% if is_green %} difference-card--green{% endif %}"
              {{ block.shopify_attributes }}
            >
              <span class="difference-card__icon" aria-hidden="true">
                {%- if block.settings.icon_image != blank -%}
                  {{
                    block.settings.icon_image
                    | image_url: width: 96
                    | image_tag:
                      class: 'difference-card__icon-img',
                      loading: 'lazy',
                      alt: '',
                      width: 96,
                      height: 96
                  }}
                {%- elsif block.settings.icon_class == 'chart-icon' -%}
                  <svg viewBox="0 0 48 48" focusable="false">
                    <path d="M12 34h5V23h-5v11Zm10 0h5V16h-5v18Zm10 0h5V10h-5v24Z" />
                    <path d="M11 15.5 19 9l7 6 11-10 2.5 2.8L26.2 20 19 13.8l-5.8 4.7L11 15.5Z" />
                  </svg>
                {%- elsif block.settings.icon_class == 'seed-icon' -%}
                  <svg viewBox="0 0 48 48" focusable="false">
                    <path d="M18.8 15.6c4.4-3.4 9.3-3.3 11 .2 1.7 3.4-.4 8.8-4.8 12.2-4.4 3.4-9.3 3.3-11-.2-1.7-3.4.4-8.8 4.8-12.2Zm15.7 11.2c3.8.9 6.5 3.9 5.9 6.6-.7 2.7-4.4 4.1-8.2 3.2-3.9-.9-6.5-3.9-5.9-6.6.6-2.7 4.3-4.1 8.2-3.2Zm-20.4 7.1c2.9-1.6 6.2-1 7.4 1.2 1.2 2.2-.2 5.3-3.1 6.9-2.9 1.6-6.2 1-7.4-1.2-1.2-2.3.2-5.3 3.1-6.9Z" />
                  </svg>
                {%- else -%}
                  <svg viewBox="0 0 48 48" focusable="false">
                    <path d="M10 36c1.6-11.6 5.8-20 13.8-27.5C21.8 19 21.6 27.7 23 36h-4.5c-.9-5.8-.7-11.2.7-17.5C15.6 23 13.2 28.9 12 36h-2Zm15.5 0c-1.1-9.4 1.1-18 7.4-26.8-.3 9.2 1.2 17.5 5.1 26.8h-5c-2.3-6.3-3.3-12.1-3.1-18.4-2.3 5.7-2.9 11.7-1.8 18.4h-2.6Zm-11.9 0c5.4-7.5 12.4-12.5 22-14.9-5.9 4.2-10.9 9.1-14.5 14.9h-7.5Z" />
                  </svg>
                {%- endif -%}
              </span>

              <span class="difference-card__watermark" aria-hidden="true">
                <span class="difference-card__watermark-image"></span>
              </span>

              {%- if block.settings.title != blank -%}
                <h3 class="difference-card__title">{{ block.settings.title }}</h3>
              {%- endif -%}

              {%- if block.settings.text != blank -%}
                <p class="difference-card__text">{{ block.settings.text }}</p>
              {%- endif -%}
            </article>
          {%- endif -%}
        {%- endfor -%}
      </div>

      <div class="difference-section__photo-wrap">
        {%- if photo != blank -%}
          {{
            photo
            | image_url: width: 1200
            | image_tag:
              class: 'difference-section__photo',
              loading: 'lazy',
              alt: section.settings.photo_alt,
              width: 1200,
              height: 1400
          }}
        {%- else -%}
          <img
            class="difference-section__photo"
            src="{{ 'difference-man.png' | asset_url }}"
            alt="{{ section.settings.photo_alt | escape }}"
            width="1200"
            height="1400"
            loading="lazy"
          >
        {%- endif -%}
      </div>

      <div class="difference-section__badge" aria-hidden="true">
        {%- if badge_image != blank -%}
          {{
            badge_image
            | image_url: width: 180
            | image_tag:
              class: 'difference-section__badge-img',
              loading: 'lazy',
              alt: '',
              width: 180,
              height: 180
          }}
        {%- else -%}
          <svg viewBox="0 0 96 96" focusable="false">
            <path d="M18 78c2.8-21.6 10.8-38.5 27.2-55-5.2 20.5-6 38.7-1.8 55h-8.2c-2.7-12.1-2.7-24.2.1-36.4-7.1 10.1-11.1 21.8-12.7 36.4H18Z" />
            <path d="M47.6 78c-4.1-23.1 1.1-43.8 17-62.5-.8 22.6 3.8 43.2 14.1 62.5h-9.6c-6.5-12.8-9.9-25.4-10.5-38.4-4.5 11.3-5.5 23.8-3 38.4h-8Z" />
            <path d="M13 78c16.4-21.7 37.4-36.3 66.5-43.5-17.5 11.1-31.9 25.4-42.6 43.5H13Z" />
          </svg>
        {%- endif -%}
      </div>
    </div>
  </div>
</section>

<style>
  #difference-{{ section.id }} {
    position: relative;
    overflow: hidden;
    background: var(--section-bg);
    padding: 118px 24px 112px;
    color: var(--text-color);
  }

  #difference-{{ section.id }} * {
    box-sizing: border-box;
  }

  #difference-{{ section.id }} .difference-section__inner {
    max-width: var(--container-width);
    margin: 0 auto;
    position: relative;
  }

  #difference-{{ section.id }} .difference-section__header {
    max-width: 740px;
    margin: 0;
  }

  #difference-{{ section.id }} .difference-section__eyebrow {
    margin: 0 0 14px;
    color: var(--accent-color);
    font-size: 16px;
    line-height: 1.1;
    font-weight: 600;
    letter-spacing: -0.02em;
  }

  #difference-{{ section.id }} .difference-section__heading {
    margin: 0;
    max-width: 720px;
    color: var(--text-color);
    font-size: 48px;
    line-height: 1.14;
    font-weight: 800;
    letter-spacing: -0.045em;
  }

  #difference-{{ section.id }} .difference-section__layout {
    position: relative;
    height: 704px;
    margin-top: 48px;
  }

  #difference-{{ section.id }} .difference-section__cards {
    position: absolute;
    inset: 0;
    z-index: 4;
  }

  #difference-{{ section.id }} .difference-card {
    position: absolute;
    width: 323px;
    height: 299px;
    padding: 33px 22px 24px;
    border-radius: var(--card-radius);
    background: var(--card-bg);
    overflow: hidden;
    box-shadow: 0 20px 42px rgba(15, 72, 47, 0.04);
  }

  #difference-{{ section.id }} .difference-card--1 {
    left: 0;
    top: 26px;
  }

  #difference-{{ section.id }} .difference-card--2 {
    left: 356px;
    top: 84px;
    z-index: 5;
  }

  #difference-{{ section.id }} .difference-card--3 {
    left: 0;
    top: 354px;
  }

  #difference-{{ section.id }} .difference-card--4 {
    left: 356px;
    top: 384px;
    z-index: 6;
  }

  #difference-{{ section.id }} .difference-card--green {
    background: var(--green-card-bg);
    color: #ffffff;
    box-shadow: 0 23px 42px rgba(19, 105, 69, 0.22);
  }

  #difference-{{ section.id }} .difference-card__icon {
    position: relative;
    z-index: 2;
    width: 56px;
    height: 56px;
    display: inline-grid;
    place-items: center;
    border-radius: 999px;
    background: #ffffff;
    color: var(--accent-color);
    box-shadow: 0 8px 20px rgba(7, 59, 40, 0.08);
  }

  #difference-{{ section.id }} .difference-card__icon svg {
    width: 34px;
    height: 34px;
    fill: currentColor;
  }

  #difference-{{ section.id }} .difference-card__icon-img {
    display: block;
    width: 34px;
    height: 34px;
    object-fit: contain;
  }

  #difference-{{ section.id }} .difference-card__watermark {
    position: absolute;
    right: 0;
    top: 42px;
    width: 148px;
    height: 112px;
    color: #ccefe1;
    opacity: 0.7;
    pointer-events: none;
  }

  #difference-{{ section.id }} .difference-card--green .difference-card__watermark {
    color: #47b985;
    opacity: 0.48;
  }

  #difference-{{ section.id }} .difference-card__watermark-image {
    display: block;
    width: 100%;
    height: 100%;
    background: currentColor;
    mask: url("{{ 'difference-seed-watermark.png' | asset_url }}") center / contain no-repeat;
    -webkit-mask: url("{{ 'difference-seed-watermark.png' | asset_url }}") center / contain no-repeat;
  }

  #difference-{{ section.id }} .difference-card__title {
    position: relative;
    z-index: 2;
    margin: 36px 0 13px;
    color: currentColor;
    font-size: 24px;
    line-height: 1.05;
    font-weight: 800;
    letter-spacing: -0.045em;
  }

  #difference-{{ section.id }} .difference-card--green .difference-card__title {
    margin-top: 35px;
  }

  #difference-{{ section.id }} .difference-card__text {
    position: relative;
    z-index: 2;
    margin: 0;
    max-width: 250px;
    color: currentColor;
    font-size: 15px;
    line-height: 1.52;
    font-weight: 500;
    letter-spacing: -0.018em;
  }

  #difference-{{ section.id }} .difference-card--green .difference-card__text {
    max-width: 258px;
  }

  #difference-{{ section.id }} .difference-section__photo-wrap {
    position: absolute;
    z-index: 2;
    right: 50px;
    top: 0;
    width: 582px;
    height: 673px;
    overflow: hidden;
    border-radius: 20px;
  }

  #difference-{{ section.id }} .difference-section__photo {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  #difference-{{ section.id }} .difference-section__badge {
    position: absolute;
    z-index: 8;
    right: -12px;
    top: 125px;
    width: 112px;
    height: 112px;
    display: grid;
    place-items: center;
    border-radius: 999px;
    background: #ffffff;
    color: var(--accent-color);
    box-shadow: 0 12px 28px rgba(11, 74, 49, 0.08);
  }

  #difference-{{ section.id }} .difference-section__badge::before {
    content: "";
    position: absolute;
    inset: 8px;
    border-radius: inherit;
    border: 1px dashed var(--accent-color);
    opacity: 0.75;
  }

  #difference-{{ section.id }} .difference-section__badge svg {
    position: relative;
    z-index: 2;
    width: 72px;
    height: 72px;
    fill: currentColor;
  }

  #difference-{{ section.id }} .difference-section__badge-img {
    position: relative;
    z-index: 2;
    display: block;
    width: 74px;
    height: 74px;
    object-fit: contain;
  }

  @media screen and (max-width: 1340px) {
    #difference-{{ section.id }} {
      padding-left: 42px;
      padding-right: 42px;
    }

    #difference-{{ section.id }} .difference-section__inner {
      max-width: 1180px;
    }

    #difference-{{ section.id }} .difference-section__photo-wrap {
      right: 0;
      width: 540px;
      height: 624px;
    }

    #difference-{{ section.id }} .difference-section__badge {
      right: -38px;
    }

    #difference-{{ section.id }} .difference-card {
      width: 300px;
      height: 278px;
      padding: 30px 20px 22px;
    }

    #difference-{{ section.id }} .difference-card--2,
    #difference-{{ section.id }} .difference-card--4 {
      left: 330px;
    }

    #difference-{{ section.id }} .difference-card__title {
      font-size: 22px;
    }

    #difference-{{ section.id }} .difference-card__text {
      font-size: 14px;
    }
  }

  @media screen and (max-width: 989px) {
    #difference-{{ section.id }} {
      padding: 70px 20px 78px;
    }

    #difference-{{ section.id }} .difference-section__heading {
      font-size: 36px;
      max-width: 620px;
    }

    #difference-{{ section.id }} .difference-section__layout {
      height: auto;
      margin-top: 38px;
      display: flex;
      flex-direction: column-reverse;
      gap: 28px;
    }

    #difference-{{ section.id }} .difference-section__cards,
    #difference-{{ section.id }} .difference-section__photo-wrap,
    #difference-{{ section.id }} .difference-section__badge {
      position: relative;
      inset: auto;
    }

    #difference-{{ section.id }} .difference-section__photo-wrap {
      width: 100%;
      height: auto;
      aspect-ratio: 582 / 673;
      max-width: 582px;
    }

    #difference-{{ section.id }} .difference-section__badge {
      position: absolute;
      right: -10px;
      top: 74px;
      width: 92px;
      height: 92px;
    }

    #difference-{{ section.id }} .difference-section__cards {
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 18px;
    }

    #difference-{{ section.id }} .difference-card,
    #difference-{{ section.id }} .difference-card--1,
    #difference-{{ section.id }} .difference-card--2,
    #difference-{{ section.id }} .difference-card--3,
    #difference-{{ section.id }} .difference-card--4 {
      position: relative;
      left: auto;
      top: auto;
      width: 100%;
      height: auto;
      min-height: 260px;
    }
  }

  @media screen and (max-width: 575px) {
    #difference-{{ section.id }} {
      padding: 54px 16px 62px;
    }

    #difference-{{ section.id }} .difference-section__eyebrow {
      font-size: 14px;
    }

    #difference-{{ section.id }} .difference-section__heading {
      font-size: 30px;
      line-height: 1.18;
    }

    #difference-{{ section.id }} .difference-section__cards {
      grid-template-columns: 1fr;
    }

    #difference-{{ section.id }} .difference-card {
      min-height: 250px;
    }

    #difference-{{ section.id }} .difference-section__badge {
      width: 78px;
      height: 78px;
      top: 48px;
    }

    #difference-{{ section.id }} .difference-section__badge svg,
    #difference-{{ section.id }} .difference-section__badge-img {
      width: 52px;
      height: 52px;
    }
  }
</style>

{% schema %}
{
  "name": "Lawn — Difference",
  "tag": "section",
  "class": "lawn-difference-section",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Premium Difference"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "What Makes Envy Different From Other Grass Seeds?"
    },
    {
      "type": "image_picker",
      "id": "photo",
      "label": "Right photo"
    },
    {
      "type": "image_picker",
      "id": "badge_image",
      "label": "Circle badge image"
    },
    {
      "type": "text",
      "id": "photo_alt",
      "label": "Photo alt text",
      "default": "Lawn specialist holding Envy grass seed"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "container_width",
      "label": "Container width",
      "min": 1000,
      "max": 1440,
      "step": 10,
      "unit": "px",
      "default": 1280
    },
    {
      "type": "range",
      "id": "card_radius",
      "label": "Card radius",
      "min": 8,
      "max": 32,
      "step": 1,
      "unit": "px",
      "default": 20
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background",
      "default": "#EFF9F4"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text",
      "default": "#073B28"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Accent",
      "default": "#18B873"
    },
    {
      "type": "color",
      "id": "card_background",
      "label": "Card background",
      "default": "#FFFFFF"
    },
    {
      "type": "color",
      "id": "green_card_background",
      "label": "Green card background",
      "default": "#5CC493"
    }
  ],
  "blocks": [
    {
      "type": "card",
      "name": "Benefit card",
      "settings": [
        {
          "type": "image_picker",
          "id": "icon_image",
          "label": "Custom icon"
        },
        {
          "type": "select",
          "id": "icon_class",
          "label": "Icon style",
          "options": [
            {
              "value": "grass-icon",
              "label": "Grass"
            },
            {
              "value": "chart-icon",
              "label": "Chart"
            },
            {
              "value": "seed-icon",
              "label": "Seed"
            }
          ],
          "default": "grass-icon"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Thicker, Denser Turf"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Description",
          "default": "Selected For Improved Lawn Density, Creating A Smoother, Thicker, More Uniform Appearance Across Your Entire Lawn."
        },
        {
          "type": "checkbox",
          "id": "offset",
          "label": "Offset card downward",
          "default": false
        },
        {
          "type": "select",
          "id": "style",
          "label": "Color style",
          "options": [
            {
              "value": "default",
              "label": "White"
            },
            {
              "value": "green",
              "label": "Green"
            }
          ],
          "default": "default"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Lawn — Difference",
      "blocks": [
        {
          "type": "card",
          "settings": {
            "icon_class": "grass-icon",
            "title": "Thicker, Denser Turf",
            "text": "Selected For Improved Lawn Density, Creating A Smoother, Thicker, More Uniform Appearance Across Your Entire Lawn."
          }
        },
        {
          "type": "card",
          "settings": {
            "icon_class": "grass-icon",
            "title": "Ultra-Dark Green",
            "text": "Elite Varieties Chosen For Deep, Rich Green Color That Stands Out Beautifully In Any Lawn Setting."
          }
        },
        {
          "type": "card",
          "settings": {
            "icon_class": "chart-icon",
            "title": "Improved Fill-In",
            "text": "Helps Reduce Thin, Patchy Areas Faster Compared To Standard Tall Fescue Blends Used In Lawns."
          }
        },
        {
          "type": "card",
          "settings": {
            "icon_class": "seed-icon",
            "title": "0% Weed Seed",
            "text": "Clean, High-Quality Seed With Zero Weed Seeds And No Unnecessary Fillers For Better Lawn Results.",
            "style": "green"
          }
        }
      ]
    }
  ]
}
{% endschema %}
