{%- liquid
  assign section_id = 'PremiumDifference-' | append: section.id
  assign photo = section.settings.photo
  assign photo_alt = section.settings.photo_alt | default: 'Lawn specialist holding a grass seed product'
  assign badge_image = section.settings.badge_image
  assign badge_alt = section.settings.badge_alt | default: 'Premium grass icon'
-%}

<section
  id="{{ section_id }}"
  class="premium-difference"
  style="
    --section-bg: {{ section.settings.background_color }};
    --section-max: {{ section.settings.max_width }}px;
    --section-top: {{ section.settings.padding_top }}px;
    --section-bottom: {{ section.settings.padding_bottom }}px;
    --eyebrow-color: {{ section.settings.eyebrow_color }};
    --heading-color: {{ section.settings.heading_color }};
    --body-color: {{ section.settings.body_color }};
    --accent-color: {{ section.settings.accent_color }};
    --card-width: {{ section.settings.card_width }}px;
    --card-height: {{ section.settings.card_height }}px;
    --card-radius: {{ section.settings.card_radius }}px;
    --card-shadow: {{ section.settings.card_shadow_opacity | divided_by: 100.0 }};
    --card-icon-size: {{ section.settings.card_icon_size }}px;
    --watermark-size: {{ section.settings.watermark_size }}px;
    --watermark-opacity: {{ section.settings.watermark_opacity | divided_by: 100.0 }};
    --layout-height: {{ section.settings.layout_height }}px;
    --layout-margin: {{ section.settings.layout_margin_top }}px;
    --photo-width: {{ section.settings.photo_width }}px;
    --photo-height: {{ section.settings.photo_height }}px;
    --photo-top: {{ section.settings.photo_top }}px;
    --photo-right: {{ section.settings.photo_right }}px;
    --photo-radius: {{ section.settings.photo_radius }}px;
    --badge-size: {{ section.settings.badge_size }}px;
    --badge-top: {{ section.settings.badge_top }}px;
    --badge-right: {{ section.settings.badge_right }}px;
  "
>
  <div class="premium-difference__inner">
    <div class="premium-difference__copy">
      {%- if section.settings.eyebrow != blank -%}
        <p class="premium-difference__eyebrow">{{ section.settings.eyebrow }}</p>
      {%- endif -%}

      {%- if section.settings.heading != blank -%}
        <h2 class="premium-difference__heading">{{ section.settings.heading }}</h2>
      {%- endif -%}
    </div>

    <div class="premium-difference__layout">
      <div class="premium-difference__cards" aria-label="{{ section.settings.cards_label | escape }}">
        {%- for block in section.blocks -%}
          {%- if block.type == 'card' -%}
            {%- liquid
              assign card_title = block.settings.title
              assign card_text = block.settings.text
            -%}

            <article
              class="premium-difference__card"
              style="
                --card-x: {{ block.settings.desktop_x }}px;
                --card-y: {{ block.settings.desktop_y }}px;
                --card-bg: {{ block.settings.card_background }};
                --card-text: {{ block.settings.text_color }};
                --card-muted: {{ block.settings.description_color }};
                --icon-bg: {{ block.settings.icon_background }};
                --icon-color: {{ block.settings.icon_color }};
                --mark-color: {{ block.settings.watermark_color }};
                --card-z: {{ block.settings.z_index }};
              "
              {{ block.shopify_attributes }}
            >
              <span class="premium-difference__card-icon" aria-hidden="true">
                {%- if block.settings.icon_image != blank -%}
                  {{
                    block.settings.icon_image
                    | image_url: width: 120
                    | image_tag: loading: 'lazy', alt: '', widths: '60, 90, 120', sizes: '50px'
                  }}
                {%- else -%}
                  {%- case block.settings.icon -%}
                    {%- when 'chart' -%}
                      <svg viewBox="0 0 32 32" focusable="false">
                        <path d="M8 22V16" />
                        <path d="M14 22V12" />
                        <path d="M20 22V9" />
                        <path d="M25 8v7h-7" />
                        <path d="M18 15 25 8" />
                      </svg>
                    {%- when 'seed' -%}
                      <svg viewBox="0 0 32 32" focusable="false">
                        <path d="M10.4 18.6c2.8.4 5.5-1.4 6-4.1.2-1.2-.1-2.4-.9-3.4-3-.2-5.7 1.7-6.2 4.3-.2 1.2.2 2.3 1.1 3.2Z" />
                        <path d="M19 22.7c2.8.4 5.5-1.4 6-4.1.2-1.2-.1-2.4-.9-3.4-3-.2-5.7 1.7-6.2 4.3-.2 1.2.2 2.3 1.1 3.2Z" />
                        <path d="M10 24.5c2.2.3 4.2-1.1 4.6-3.1.2-.9-.1-1.8-.7-2.6-2.3-.1-4.4 1.3-4.7 3.3-.2.9.1 1.7.8 2.4Z" />
                      </svg>
                    {%- else -%}
                      <svg viewBox="0 0 32 32" focusable="false">
                        <path d="M7 24c1.1-7.2 3.6-12.5 7.4-15.9" />
                        <path d="M15 24c.1-6.4 1-11.8 2.8-16.2" />
                        <path d="M21.8 24c-.6-5.3-.3-9.9 1-13.8" />
                        <path d="M5.5 24h21" />
                      </svg>
                  {%- endcase -%}
                {%- endif -%}
              </span>

              {%- if section.settings.show_watermarks -%}
                <span class="premium-difference__watermark" aria-hidden="true">
                  <svg viewBox="0 0 120 120" focusable="false">
                    <path d="M20 99c6-34 18-58 36-73" />
                    <path d="M55 99c1-31 6-57 16-78" />
                    <path d="M87 99c-3-27 0-50 8-70" />
                    <path d="M12 100h96" />
                    <path d="M34 98C31 73 25 54 16 41" />
                    <path d="M72 99C66 67 56 45 42 31" />
                  </svg>
                </span>
              {%- endif -%}

              {%- if card_title != blank -%}
                <h3>{{ card_title }}</h3>
              {%- endif -%}

              {%- if card_text != blank -%}
                <p>{{ card_text }}</p>
              {%- endif -%}
            </article>
          {%- endif -%}
        {%- endfor -%}
      </div>

      <div class="premium-difference__visual">
        <div class="premium-difference__photo">
          {%- if photo != blank -%}
            {{
              photo
              | image_url: width: 1200
              | image_tag:
                loading: 'lazy',
                alt: photo_alt,
                widths: '370, 540, 740, 960, 1200',
                sizes: '(min-width: 990px) 370px, 100vw'
            }}
          {%- else -%}
            {{ 'image' | placeholder_svg_tag: 'placeholder-svg premium-difference__placeholder' }}
          {%- endif -%}
        </div>

        {%- if section.settings.show_badge -%}
          <div class="premium-difference__badge" aria-hidden="true">
            {%- if badge_image != blank -%}
              {{
                badge_image
                | image_url: width: 180
                | image_tag: loading: 'lazy', alt: badge_alt, widths: '90, 140, 180', sizes: '86px'
              }}
            {%- else -%}
              <svg viewBox="0 0 96 96" focusable="false">
                <path d="M18 74c5-24 14-42 28-53" />
                <path d="M47 75c.8-23 4.6-42 11.4-57" />
                <path d="M70 75c-2.2-19.5.1-36 6.8-49.5" />
                <path d="M14 75h68" />
                <path d="M30 74c-2.2-18.2-6.7-32.3-13.5-42.2" />
                <path d="M60 75c-4.8-23.4-12.7-39.8-23.7-49.1" />
              </svg>
            {%- endif -%}
          </div>
        {%- endif -%}
      </div>
    </div>
  </div>
</section>

{% style %}
  #{{ section_id }} {
    background: var(--section-bg);
    padding: var(--section-top) 0 var(--section-bottom);
    color: var(--body-color);
    font-family: var(--font-body-family, Inter, Arial, sans-serif);
    overflow: hidden;
  }

  #{{ section_id }} *,
  #{{ section_id }} *::before,
  #{{ section_id }} *::after {
    box-sizing: border-box;
  }

  #{{ section_id }} .premium-difference__inner {
    width: min(var(--section-max), calc(100vw - 36px));
    margin: 0 auto;
  }

  #{{ section_id }} .premium-difference__copy {
    max-width: {{ section.settings.heading_max_width }}px;
  }

  #{{ section_id }} .premium-difference__eyebrow {
    margin: 0 0 10px;
    color: var(--eyebrow-color);
    font-size: 13px;
    line-height: 1.2;
    font-weight: 600;
    letter-spacing: -0.12px;
  }

  #{{ section_id }} .premium-difference__heading {
    margin: 0;
    color: var(--heading-color);
    font-family: var(--font-heading-family, Inter, Arial, sans-serif);
    font-size: {{ section.settings.heading_size }}px;
    line-height: 1.2;
    font-weight: 900;
    letter-spacing: -1.1px;
  }

  #{{ section_id }} .premium-difference__layout {
    position: relative;
    height: var(--layout-height);
    margin-top: var(--layout-margin);
  }

  #{{ section_id }} .premium-difference__cards {
    position: relative;
    z-index: 3;
    height: 100%;
  }

  #{{ section_id }} .premium-difference__card {
    position: absolute;
    left: var(--card-x);
    top: var(--card-y);
    z-index: var(--card-z);
    width: var(--card-width);
    min-height: var(--card-height);
    padding: 75px 14px 18px;
    border-radius: var(--card-radius);
    background: var(--card-bg);
    color: var(--card-text);
    overflow: hidden;
    box-shadow: 0 18px 34px rgba(17, 78, 49, var(--card-shadow));
  }

  #{{ section_id }} .premium-difference__card-icon {
    position: absolute;
    left: 13px;
    top: 18px;
    z-index: 2;
    width: var(--card-icon-size);
    height: var(--card-icon-size);
    display: grid;
    place-items: center;
    border-radius: 50%;
    background: var(--icon-bg);
    color: var(--icon-color);
    box-shadow: 0 9px 24px rgba(5, 71, 41, .12);
  }

  #{{ section_id }} .premium-difference__card-icon svg,
  #{{ section_id }} .premium-difference__card-icon img {
    width: 28px;
    height: 28px;
    display: block;
  }

  #{{ section_id }} .premium-difference__card-icon svg {
    fill: none;
    stroke: currentColor;
    stroke-width: 2.5;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  #{{ section_id }} .premium-difference__watermark {
    position: absolute;
    right: 10px;
    top: 28px;
    width: var(--watermark-size);
    height: var(--watermark-size);
    color: var(--mark-color);
    opacity: var(--watermark-opacity);
    pointer-events: none;
  }

  #{{ section_id }} .premium-difference__watermark svg {
    width: 100%;
    height: 100%;
    display: block;
    fill: none;
    stroke: currentColor;
    stroke-width: 4;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  #{{ section_id }} .premium-difference__card h3 {
    position: relative;
    z-index: 2;
    margin: 0 0 10px;
    color: var(--card-text);
    font-family: var(--font-heading-family, Inter, Arial, sans-serif);
    font-size: 18px;
    line-height: 1.15;
    font-weight: 900;
    letter-spacing: -0.4px;
  }

  #{{ section_id }} .premium-difference__card p {
    position: relative;
    z-index: 2;
    margin: 0;
    color: var(--card-muted);
    font-size: 12px;
    line-height: 1.55;
    font-weight: 600;
    letter-spacing: -0.1px;
  }

  #{{ section_id }} .premium-difference__visual {
    position: absolute;
    top: var(--photo-top);
    right: var(--photo-right);
    z-index: 1;
    width: var(--photo-width);
    height: var(--photo-height);
  }

  #{{ section_id }} .premium-difference__photo {
    width: 100%;
    height: 100%;
    border-radius: var(--photo-radius);
    overflow: hidden;
    background: #d9eee3;
  }

  #{{ section_id }} .premium-difference__photo img,
  #{{ section_id }} .premium-difference__photo svg {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: {{ section.settings.photo_fit }};
    object-position: {{ section.settings.photo_position }};
  }

  #{{ section_id }} .premium-difference__placeholder {
    padding: 40px;
  }

  #{{ section_id }} .premium-difference__badge {
    position: absolute;
    top: var(--badge-top);
    right: var(--badge-right);
    z-index: 4;
    width: var(--badge-size);
    height: var(--badge-size);
    display: grid;
    place-items: center;
    border-radius: 50%;
    background: #fff;
    color: var(--accent-color);
    box-shadow: 0 8px 22px rgba(7, 60, 39, .08);
  }

  #{{ section_id }} .premium-difference__badge::before {
    content: "";
    position: absolute;
    inset: 7px;
    border: 1px dashed var(--accent-color);
    border-radius: 50%;
    opacity: .8;
  }

  #{{ section_id }} .premium-difference__badge svg,
  #{{ section_id }} .premium-difference__badge img {
    position: relative;
    z-index: 1;
    width: 58px;
    height: 58px;
    display: block;
  }

  #{{ section_id }} .premium-difference__badge svg {
    fill: none;
    stroke: currentColor;
    stroke-width: 2.2;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  @media (max-width: 989px) {
    #{{ section_id }} {
      padding: 56px 0 58px;
    }

    #{{ section_id }} .premium-difference__inner {
      width: min(680px, calc(100vw - 32px));
    }

    #{{ section_id }} .premium-difference__copy {
      max-width: 100%;
    }

    #{{ section_id }} .premium-difference__heading {
      font-size: clamp(30px, 5.5vw, {{ section.settings.heading_size }}px);
    }

    #{{ section_id }} .premium-difference__layout {
      height: auto;
      margin-top: 28px;
      display: flex;
      flex-direction: column;
      gap: 24px;
    }

    #{{ section_id }} .premium-difference__visual {
      position: relative;
      top: auto;
      right: auto;
      order: 1;
      width: 100%;
      height: auto;
      aspect-ratio: 370 / 428;
    }

    #{{ section_id }} .premium-difference__cards {
      order: 2;
      display: grid;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      gap: 18px;
      height: auto;
    }

    #{{ section_id }} .premium-difference__card {
      position: relative;
      left: auto;
      top: auto;
      width: 100%;
      min-height: 178px;
    }

    #{{ section_id }} .premium-difference__badge {
      top: 22px;
      right: -8px;
    }
  }

  @media (max-width: 560px) {
    #{{ section_id }} {
      padding: 44px 0 46px;
    }

    #{{ section_id }} .premium-difference__inner {
      width: min(420px, calc(100vw - 28px));
    }

    #{{ section_id }} .premium-difference__eyebrow {
      font-size: 12px;
    }

    #{{ section_id }} .premium-difference__heading {
      font-size: 30px;
      letter-spacing: -0.8px;
    }

    #{{ section_id }} .premium-difference__cards {
      grid-template-columns: 1fr;
    }

    #{{ section_id }} .premium-difference__card {
      min-height: 168px;
      padding-top: 70px;
    }

    #{{ section_id }} .premium-difference__badge {
      width: 74px;
      height: 74px;
    }

    #{{ section_id }} .premium-difference__badge svg,
    #{{ section_id }} .premium-difference__badge img {
      width: 48px;
      height: 48px;
    }
  }
{% endstyle %}

{% schema %}
{
  "name": "Premium Difference",
  "tag": "section",
  "class": "section-premium-difference",
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Premium Difference"
    },
    {
      "type": "textarea",
      "id": "heading",
      "label": "Heading",
      "default": "What Makes Envy Different From Other Grass Seeds?"
    },
    {
      "type": "text",
      "id": "cards_label",
      "label": "Cards accessibility label",
      "default": "Premium product benefits"
    },
    {
      "type": "header",
      "content": "Main image"
    },
    {
      "type": "image_picker",
      "id": "photo",
      "label": "Image"
    },
    {
      "type": "text",
      "id": "photo_alt",
      "label": "Image alt text",
      "default": "Lawn specialist holding Envy grass seed"
    },
    {
      "type": "select",
      "id": "photo_fit",
      "label": "Image fit",
      "options": [
        { "value": "cover", "label": "Cover" },
        { "value": "contain", "label": "Contain" }
      ],
      "default": "cover"
    },
    {
      "type": "text",
      "id": "photo_position",
      "label": "Image position",
      "default": "center center"
    },
    {
      "type": "checkbox",
      "id": "show_badge",
      "label": "Show round badge",
      "default": true
    },
    {
      "type": "image_picker",
      "id": "badge_image",
      "label": "Custom badge image"
    },
    {
      "type": "text",
      "id": "badge_alt",
      "label": "Badge image alt text",
      "default": "Grass icon"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "max_width",
      "label": "Container width",
      "min": 700,
      "max": 1100,
      "step": 4,
      "unit": "px",
      "default": 808
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Top padding",
      "min": 0,
      "max": 140,
      "step": 2,
      "unit": "px",
      "default": 78
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "label": "Bottom padding",
      "min": 0,
      "max": 140,
      "step": 2,
      "unit": "px",
      "default": 72
    },
    {
      "type": "range",
      "id": "layout_margin_top",
      "label": "Cards top spacing",
      "min": 10,
      "max": 80,
      "step": 2,
      "unit": "px",
      "default": 36
    },
    {
      "type": "range",
      "id": "layout_height",
      "label": "Desktop layout height",
      "min": 300,
      "max": 600,
      "step": 4,
      "unit": "px",
      "default": 436
    },
    {
      "type": "range",
      "id": "heading_max_width",
      "label": "Heading max width",
      "min": 320,
      "max": 620,
      "step": 5,
      "unit": "px",
      "default": 500
    },
    {
      "type": "range",
      "id": "heading_size",
      "label": "Heading size",
      "min": 24,
      "max": 46,
      "step": 1,
      "unit": "px",
      "default": 32
    },
    {
      "type": "header",
      "content": "Card style"
    },
    {
      "type": "range",
      "id": "card_width",
      "label": "Desktop card width",
      "min": 160,
      "max": 260,
      "step": 4,
      "unit": "px",
      "default": 204
    },
    {
      "type": "range",
      "id": "card_height",
      "label": "Desktop card height",
      "min": 150,
      "max": 230,
      "step": 4,
      "unit": "px",
      "default": 190
    },
    {
      "type": "range",
      "id": "card_radius",
      "label": "Card radius",
      "min": 0,
      "max": 30,
      "step": 1,
      "unit": "px",
      "default": 10
    },
    {
      "type": "range",
      "id": "card_icon_size",
      "label": "Icon circle size",
      "min": 42,
      "max": 64,
      "step": 2,
      "unit": "px",
      "default": 50
    },
    {
      "type": "range",
      "id": "card_shadow_opacity",
      "label": "Card shadow opacity",
      "min": 0,
      "max": 24,
      "step": 1,
      "unit": "%",
      "default": 9
    },
    {
      "type": "checkbox",
      "id": "show_watermarks",
      "label": "Show card background marks",
      "default": true
    },
    {
      "type": "range",
      "id": "watermark_size",
      "label": "Background mark size",
      "min": 40,
      "max": 140,
      "step": 2,
      "unit": "px",
      "default": 90
    },
    {
      "type": "range",
      "id": "watermark_opacity",
      "label": "Background mark opacity",
      "min": 0,
      "max": 30,
      "step": 1,
      "unit": "%",
      "default": 12
    },
    {
      "type": "header",
      "content": "Image sizing"
    },
    {
      "type": "range",
      "id": "photo_width",
      "label": "Desktop image width",
      "min": 280,
      "max": 460,
      "step": 2,
      "unit": "px",
      "default": 370
    },
    {
      "type": "range",
      "id": "photo_height",
      "label": "Desktop image height",
      "min": 320,
      "max": 520,
      "step": 2,
      "unit": "px",
      "default": 428
    },
    {
      "type": "range",
      "id": "photo_top",
      "label": "Desktop image top offset",
      "min": -40,
      "max": 80,
      "step": 2,
      "unit": "px",
      "default": -16
    },
    {
      "type": "range",
      "id": "photo_right",
      "label": "Desktop image right offset",
      "min": -40,
      "max": 80,
      "step": 2,
      "unit": "px",
      "default": 24
    },
    {
      "type": "range",
      "id": "photo_radius",
      "label": "Image radius",
      "min": 0,
      "max": 30,
      "step": 1,
      "unit": "px",
      "default": 12
    },
    {
      "type": "range",
      "id": "badge_size",
      "label": "Badge size",
      "min": 60,
      "max": 110,
      "step": 2,
      "unit": "px",
      "default": 86
    },
    {
      "type": "range",
      "id": "badge_top",
      "label": "Badge top offset",
      "min": 0,
      "max": 200,
      "step": 2,
      "unit": "px",
      "default": 76
    },
    {
      "type": "range",
      "id": "badge_right",
      "label": "Badge right offset",
      "min": -70,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": -42
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Section background",
      "default": "#EFF9F4"
    },
