{%- liquid
  assign logo = section.settings.logo
  assign logo_width = section.settings.logo_width | default: 176
  assign logo_style = 'width: ' | append: logo_width | append: 'px;'
  assign cart_label = section.settings.cart_label | default: 'Cart'
  assign icon_size = section.settings.icon_size | default: 18
  assign icon_style = 'width: ' | append: icon_size | append: 'px; height: ' | append: icon_size | append: 'px;'
  assign use_custom_action_icons = section.settings.use_custom_action_icons
-%}

<header class="site-header">
  <nav class="nav container" aria-label="Main navigation">
    <a class="brand" href="{{ routes.root_url }}">
      {%- if logo != blank -%}
        {{ logo | image_url: width: 400 | image_tag:
          loading: 'eager',
          width: logo.width,
          height: logo.height,
          alt: shop.name,
          style: logo_style
        }}
      {%- else -%}
        <img src="{{ 'lawn-synergy-logo.png' | asset_url }}"
             alt="{{ shop.name | escape }}"
             style="width: {{ logo_width }}px;"
             width="{{ logo_width }}"
             height="60">
      {%- endif -%}
    </a>

    <ul class="nav-links">
      {%- for block in section.blocks -%}
        {%- if block.type == 'link' -%}
          <li {{ block.shopify_attributes }}>
            <a href="{{ block.settings.url | default: '#' }}">{{ block.settings.label }}</a>
          </li>
        {%- endif -%}
      {%- endfor -%}
    </ul>

    <div class="nav-actions" aria-label="Shopping actions">
      <a class="cart-button" href="{{ routes.cart_url }}" type="button">
        {%- if use_custom_action_icons and section.settings.cart_icon != blank -%}
          {{ section.settings.cart_icon | image_url: width: 96 | image_tag:
            loading: 'lazy',
            class: 'header-action-icon header-action-icon--image',
            alt: section.settings.cart_icon_alt | default: cart_label,
            width: icon_size,
            height: icon_size,
            style: icon_style
          }}
        {%- else -%}
          <svg class="header-action-icon" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
            <path d="M6.4 7.2h14.1l-1.6 7.1H8.1L6.4 7.2Z" />
            <path d="M3.5 4.5h2l.9 2.7" />
            <path d="M9 19.2h.1M17.7 19.2h.1" />
          </svg>
        {%- endif -%}
        <span>{{ cart_label }}</span>
        <span class="cart-count">{{ cart.item_count | default: 0 }}</span>
      </a>
      {%- if section.settings.show_wishlist -%}
        <a class="icon-button" href="{{ section.settings.wishlist_url | default: '#' }}" aria-label="{{ section.settings.wishlist_label | default: 'Wishlist' }}">
          {%- if use_custom_action_icons and section.settings.wishlist_icon != blank -%}
            {{ section.settings.wishlist_icon | image_url: width: 96 | image_tag:
              loading: 'lazy',
              class: 'header-action-icon header-action-icon--image',
              alt: section.settings.wishlist_icon_alt | default: section.settings.wishlist_label | default: 'Wishlist',
              width: icon_size,
              height: icon_size,
              style: icon_style
            }}
          {%- else -%}
            <svg class="header-action-icon" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
              <path d="M20.4 5.8c-1.7-1.9-4.5-2-6.3-.2L12 7.7 9.9 5.6C8.1 3.8 5.3 3.9 3.6 5.8c-1.6 1.8-1.5 4.6.2 6.3l8.2 8 8.2-8c1.7-1.7 1.8-4.5.2-6.3Z" />
            </svg>
          {%- endif -%}
        </a>
      {%- endif -%}
      {%- if section.settings.show_account -%}
        <a class="icon-button" href="{%- if shop.customer_accounts_enabled -%}{{ routes.account_url }}{%- else -%}#{%- endif -%}" aria-label="{{ section.settings.account_label | default: 'Account' }}">
          {%- if use_custom_action_icons and section.settings.account_icon != blank -%}
            {{ section.settings.account_icon | image_url: width: 96 | image_tag:
              loading: 'lazy',
              class: 'header-action-icon header-action-icon--image',
              alt: section.settings.account_icon_alt | default: section.settings.account_label | default: 'Account',
              width: icon_size,
              height: icon_size,
              style: icon_style
            }}
          {%- else -%}
            <svg class="header-action-icon" viewBox="0 0 24 24" aria-hidden="true" focusable="false">
              <path d="M12 12.1a4 4 0 1 0 0-8 4 4 0 0 0 0 8Z" />
              <path d="M5 20.2c.8-3.3 3.4-5.2 7-5.2s6.2 1.9 7 5.2" />
            </svg>
          {%- endif -%}
        </a>
      {%- endif -%}
    </div>
  </nav>
</header>

{% schema %}
{
  "name": "Lawn — Header",
  "tag": "section",
  "class": "lawn-header-section",
  "settings": [
    {
      "type": "header",
      "content": "Logo"
    },
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo image"
    },
    {
      "type": "range",
      "id": "logo_width",
      "label": "Logo width (px)",
      "min": 80,
      "max": 320,
      "step": 4,
      "default": 176
    },
    {
      "type": "header",
      "content": "Cart & Account"
    },
    {
      "type": "text",
      "id": "cart_label",
      "label": "Cart label",
      "default": "Cart"
    },
    {
      "type": "checkbox",
      "id": "use_custom_action_icons",
      "label": "Use uploaded action icons",
      "default": false,
      "info": "Keep disabled to use the Figma-matched default cart, wishlist, and account icons."
    },
    {
      "type": "image_picker",
      "id": "cart_icon",
      "label": "Cart icon image"
    },
    {
      "type": "text",
      "id": "cart_icon_alt",
      "label": "Cart icon alt text",
      "default": "Cart"
    },
    {
      "type": "range",
      "id": "icon_size",
      "label": "Header icon size (px)",
      "min": 14,
      "max": 34,
      "step": 1,
      "default": 18
    },
    {
      "type": "checkbox",
      "id": "show_wishlist",
      "label": "Show wishlist icon",
      "default": true
    },
    {
      "type": "text",
      "id": "wishlist_label",
      "label": "Wishlist accessibility label",
      "default": "Wishlist"
    },
    {
      "type": "image_picker",
      "id": "wishlist_icon",
      "label": "Wishlist icon image"
    },
    {
      "type": "text",
      "id": "wishlist_icon_alt",
      "label": "Wishlist icon alt text",
      "default": "Wishlist"
    },
    {
      "type": "url",
      "id": "wishlist_url",
      "label": "Wishlist link"
    },
    {
      "type": "checkbox",
      "id": "show_account",
      "label": "Show account icon",
      "default": true
    },
    {
      "type": "text",
      "id": "account_label",
      "label": "Account accessibility label",
      "default": "Account"
    },
    {
      "type": "image_picker",
      "id": "account_icon",
      "label": "Account icon image"
    },
    {
      "type": "text",
      "id": "account_icon_alt",
      "label": "Account icon alt text",
      "default": "Account"
    }
  ],
  "blocks": [
    {
      "type": "link",
      "name": "Menu link",
      "settings": [
        {
          "type": "text",
          "id": "label",
          "label": "Label",
          "default": "Menu item"
        },
        {
          "type": "url",
          "id": "url",
          "label": "URL"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Lawn — Header",
      "blocks": [
        { "type": "link", "settings": { "label": "Home" } },
        { "type": "link", "settings": { "label": "Shop Now" } },
        { "type": "link", "settings": { "label": "Reviews" } },
        { "type": "link", "settings": { "label": "Order Tracking" } },
        { "type": "link", "settings": { "label": "Contact Us" } }
      ]
    }
  ]
}
{% endschema %}
