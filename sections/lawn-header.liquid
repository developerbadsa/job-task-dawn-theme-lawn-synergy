{%- liquid
  assign logo = section.settings.logo
  assign logo_width = section.settings.logo_width | default: 176
  assign cart_label = section.settings.cart_label | default: 'Cart'
  assign icon_size = section.settings.icon_size | default: 18
-%}

<header class="site-header">
  <nav class="nav container" aria-label="Main navigation">
    <a class="brand" href="{{ routes.root_url }}">
      {%- if logo != blank -%}
        {{ logo | image_url: width: 400 | image_tag:
          loading: 'eager',
          width: logo.width,
          height: logo.height,
          alt: shop.name,
          style: 'width: ' | append: logo_width | append: 'px;'
        }}
      {%- else -%}
        <img src="{{ 'lawn-synergy-logo.png' | asset_url }}"
             alt="{{ shop.name | escape }}"
             style="width: {{ logo_width }}px;"
             width="{{ logo_width }}"
             height="60">
      {%- endif -%}
    </a>

    <ul class="nav-links">
      {%- for block in section.blocks -%}
        {%- if block.type == 'link' -%}
          <li {{ block.shopify_attributes }}>
            <a href="{{ block.settings.url | default: '#' }}">{{ block.settings.label }}</a>
          </li>
        {%- endif -%}
      {%- endfor -%}
    </ul>

    <div class="nav-actions" aria-label="Shopping actions">
      <a class="cart-button" href="{{ routes.cart_url }}" type="button">
        {%- if section.settings.cart_icon != blank -%}
          {{ section.settings.cart_icon | image_url: width: 96 | image_tag:
            loading: 'lazy',
            class: 'header-action-icon header-action-icon--image',
            alt: section.settings.cart_icon_alt | default: cart_label,
            width: icon_size,
            height: icon_size
          }}
        {%- else -%}
          <span class="icon cart-icon"></span>
        {%- endif -%}
        <span>{{ cart_label }}</span>
        <span class="cart-count">{{ cart.item_count | default: 0 }}</span>
      </a>
      {%- if section.settings.show_wishlist -%}
        <a class="icon-button" href="{{ section.settings.wishlist_url | default: '#' }}" aria-label="{{ section.settings.wishlist_label | default: 'Wishlist' }}">
          {%- if section.settings.wishlist_icon != blank -%}
            {{ section.settings.wishlist_icon | image_url: width: 96 | image_tag:
              loading: 'lazy',
              class: 'header-action-icon header-action-icon--image',
              alt: section.settings.wishlist_icon_alt | default: section.settings.wishlist_label | default: 'Wishlist',
              width: icon_size,
              height: icon_size
            }}
          {%- else -%}
            <span class="icon heart-icon"></span>
          {%- endif -%}
        </a>
      {%- endif -%}
      {%- if section.settings.show_account -%}
        <a class="icon-button" href="{%- if shop.customer_accounts_enabled -%}{{ routes.account_url }}{%- else -%}#{%- endif -%}" aria-label="{{ section.settings.account_label | default: 'Account' }}">
          {%- if section.settings.account_icon != blank -%}
            {{ section.settings.account_icon | image_url: width: 96 | image_tag:
              loading: 'lazy',
              class: 'header-action-icon header-action-icon--image',
              alt: section.settings.account_icon_alt | default: section.settings.account_label | default: 'Account',
              width: icon_size,
              height: icon_size
            }}
          {%- else -%}
            <span class="icon user-icon"></span>
          {%- endif -%}
        </a>
      {%- endif -%}
    </div>
  </nav>
</header>

{% schema %}
{
  "name": "Lawn — Header",
  "tag": "section",
  "class": "lawn-header-section",
  "settings": [
    {
      "type": "header",
      "content": "Logo"
    },
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo image"
    },
    {
      "type": "range",
      "id": "logo_width",
      "label": "Logo width (px)",
      "min": 80,
      "max": 320,
      "step": 4,
      "default": 176
    },
    {
      "type": "header",
      "content": "Cart & Account"
    },
    {
      "type": "text",
      "id": "cart_label",
      "label": "Cart label",
      "default": "Cart"
    },
    {
      "type": "image_picker",
      "id": "cart_icon",
      "label": "Cart icon image"
    },
    {
      "type": "text",
      "id": "cart_icon_alt",
      "label": "Cart icon alt text",
      "default": "Cart"
    },
    {
      "type": "range",
      "id": "icon_size",
      "label": "Header icon size (px)",
      "min": 14,
      "max": 34,
      "step": 1,
      "default": 18
    },
    {
      "type": "checkbox",
      "id": "show_wishlist",
      "label": "Show wishlist icon",
      "default": true
    },
    {
      "type": "text",
      "id": "wishlist_label",
      "label": "Wishlist accessibility label",
      "default": "Wishlist"
    },
    {
      "type": "image_picker",
      "id": "wishlist_icon",
      "label": "Wishlist icon image"
    },
    {
      "type": "text",
      "id": "wishlist_icon_alt",
      "label": "Wishlist icon alt text",
      "default": "Wishlist"
    },
    {
      "type": "url",
      "id": "wishlist_url",
      "label": "Wishlist link"
    },
    {
      "type": "checkbox",
      "id": "show_account",
      "label": "Show account icon",
      "default": true
    },
    {
      "type": "text",
      "id": "account_label",
      "label": "Account accessibility label",
      "default": "Account"
    },
    {
      "type": "image_picker",
      "id": "account_icon",
      "label": "Account icon image"
    },
    {
      "type": "text",
      "id": "account_icon_alt",
      "label": "Account icon alt text",
      "default": "Account"
    }
  ],
  "blocks": [
    {
      "type": "link",
      "name": "Menu link",
      "settings": [
        {
          "type": "text",
          "id": "label",
          "label": "Label",
          "default": "Menu item"
        },
        {
          "type": "url",
          "id": "url",
          "label": "URL"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Lawn — Header",
      "blocks": [
        { "type": "link", "settings": { "label": "Home" } },
        { "type": "link", "settings": { "label": "Shop Now" } },
        { "type": "link", "settings": { "label": "Reviews" } },
        { "type": "link", "settings": { "label": "Order Tracking" } },
        { "type": "link", "settings": { "label": "Contact Us" } }
      ]
    }
  ]
}
{% endschema %}
