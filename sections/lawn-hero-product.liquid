{%- liquid
  # ===== Resolve the product (global > section picker) =====
  assign current_product = nil

  if product != blank and product.id != blank and product.handle != blank
    assign current_product = product
  endif

  if current_product == nil and section.settings.product != blank
    assign picked_product = section.settings.product
    if picked_product.id != blank and picked_product.handle != blank
      assign current_product = picked_product
    endif
  endif

  assign has_product = false
  if current_product != nil and current_product != blank and current_product.id != blank
    assign has_product = true
  endif

  assign selected_variant = nil
  if has_product
    assign selected_variant = current_product.selected_or_first_available_variant
  endif

  # ===== Block buckets =====
  assign thumb_blocks = section.blocks | where: 'type', 'thumb'
  assign size_blocks = section.blocks | where: 'type', 'size'
  assign trust_blocks = section.blocks | where: 'type', 'trust'
  assign feature_blocks = section.blocks | where: 'type', 'feature'
  assign accordion_blocks = section.blocks | where: 'type', 'accordion'

  # ===== Mode flags =====
  assign use_product_media = section.settings.use_product_media
  assign use_product_title = section.settings.use_product_title
  assign use_product_description = section.settings.use_product_description
  assign use_size_block_labels = section.settings.use_size_block_labels

  # ===== Title =====
  if has_product and use_product_title
    assign hero_title = current_product.title
  else
    assign hero_title = section.settings.title | default: 'Premium Product'
  endif

  # ===== Lead description (metafield > product description > section fallback) =====
  assign hero_lead = blank
  assign hero_lead_is_html = false

  if has_product and use_product_description
    assign meta_summary = current_product.metafields.lawn.short_summary
    if meta_summary != blank
      assign hero_lead = meta_summary | strip_html | truncatewords: 36
    elsif current_product.description != blank
      assign hero_lead = current_product.description | strip_html | truncatewords: 36
    endif
  endif

  if hero_lead == blank
    assign hero_lead = section.settings.lead | default: 'Premium product description.'
  endif

  # ===== Main image =====
  assign main_image = nil
  assign main_image_from_product = false
  if has_product and use_product_media and current_product.featured_image != blank
    assign main_image = current_product.featured_image
    assign main_image_from_product = true
  elsif section.settings.main_image != blank
    assign main_image = section.settings.main_image
  endif

  # ===== Gallery =====
  assign product_images_count = 0
  if has_product
    assign product_images_count = current_product.media.size
  endif
  assign show_product_media_gallery = false
  if has_product and use_product_media and product_images_count > 0
    assign show_product_media_gallery = true
  endif

  # ===== Size selector logic =====
  assign show_size_area = true
  if has_product and current_product.has_only_default_variant
    assign show_size_area = false
  endif
  assign use_real_variants = false
  if has_product and current_product.variants.size > 0 and show_size_area
    assign use_real_variants = true
  endif

  # ===== Price fallbacks (no product linked) =====
  assign sale_price_text = section.settings.sale_price | default: '$49.99'
  assign old_price_text = section.settings.old_price | default: '$56.25'

  # ===== Rating (metafield > section fallback) =====
  assign rating_value = blank
  assign rating_text_value = blank

  if has_product
    assign meta_rating_stars = current_product.metafields.lawn.rating_stars
    if meta_rating_stars != blank
      assign rating_value = meta_rating_stars
    else
      assign meta_rating = current_product.metafields.lawn.rating
      if meta_rating != blank
        assign rating_number = meta_rating | times: 1.0
        assign rating_int = rating_number | floor
        assign filled = ''
        for i in (1..rating_int)
          assign filled = filled | append: '★'
        endfor
        assign empties = 5 | minus: rating_int
        if empties > 0
          for i in (1..empties)
            assign filled = filled | append: '☆'
          endfor
        endif
        assign rating_value = filled
      endif
    endif

    assign meta_rating_text = current_product.metafields.lawn.rating_text
    if meta_rating_text != blank
      assign rating_text_value = meta_rating_text
    else
      assign meta_rating_count = current_product.metafields.lawn.rating_count
      if meta_rating_count != blank
        assign rating_text_value = 'Rated By ' | append: meta_rating_count | append: '+ Customers'
      endif
    endif
  endif

  if rating_value == blank
    assign rating_value = section.settings.rating_stars | default: '★★★★★'
  endif
  if rating_text_value == blank
    assign rating_text_value = section.settings.rating_text | default: 'Rated By 12,520+ Customers'
  endif

  # ===== Features (metafield list > feature blocks) =====
  assign features_from_metafield = false
  assign features_list = nil
  if has_product
    assign meta_features = current_product.metafields.lawn.features
    if meta_features != blank and meta_features.value != blank
      assign features_list = meta_features.value
      assign features_from_metafield = true
    endif
  endif

  # ===== Urgency text (metafield > section) =====
  assign urgency_text = section.settings.urgency_text
  if has_product
    assign meta_urgency = current_product.metafields.lawn.urgency_text
    if meta_urgency != blank
      assign urgency_text = meta_urgency
    endif
  endif

  # ===== Vendor / SKU display flags =====
  assign show_vendor = section.settings.show_vendor
  assign show_sku = section.settings.show_sku
-%}

<section class="hero product-section container" data-lawn-hero data-section-id="{{ section.id }}">
  <div class="product-media">
    <div class="gallery">
      <div class="thumbs" aria-label="Product gallery thumbnails">
        {%- if show_product_media_gallery -%}
          {%- for media in current_product.media -%}
            {%- if media.preview_image != blank -%}
              <button
                class="thumb{% if forloop.first %} is-active{% endif %}"
                type="button"
                data-thumb-image="{{ media.preview_image | image_url: width: 1200 }}"
                data-thumb-alt="{{ media.alt | default: current_product.title | escape }}"
              >
                {{ media.preview_image | image_url: width: 200 | image_tag:
                  loading: 'lazy',
                  alt: media.alt | default: current_product.title,
                  width: 200,
                  height: 200
                }}
              </button>
            {%- endif -%}
          {%- endfor -%}
        {%- else -%}
          {%- for block in thumb_blocks -%}
            {%- liquid
              assign thumb_idx = forloop.index0
              assign thumb_image = block.settings.image
              assign thumb_from_asset = false

              if thumb_image == blank and has_product and product_images_count > thumb_idx
                assign product_media_item = current_product.media[thumb_idx]
                if product_media_item != blank and product_media_item.preview_image != blank
                  assign thumb_image = product_media_item.preview_image
                endif
              endif

              if thumb_image == blank
                assign thumb_from_asset = true
                assign default_thumb_name = 'thumb-' | append: forloop.index | append: '.png'
              endif

              if thumb_from_asset
                assign large_url = default_thumb_name | asset_url
              else
                assign large_url = thumb_image | image_url: width: 1200
              endif
            -%}
            <button
              class="thumb{% if forloop.first %} is-active{% endif %}"
              type="button"
              data-thumb-image="{{ large_url }}"
              data-thumb-alt="{{ block.settings.alt | default: 'Product gallery thumbnail' | escape }}"
              {{ block.shopify_attributes }}
            >
              {%- if thumb_from_asset -%}
                <img src="{{ default_thumb_name | asset_url }}"
                     alt="{{ block.settings.alt | default: 'Product gallery thumbnail' }}"
                     width="200" height="200" loading="lazy">
              {%- else -%}
                {{ thumb_image | image_url: width: 200 | image_tag:
                  loading: 'lazy',
                  alt: block.settings.alt | default: 'Product gallery thumbnail',
                  width: 200,
                  height: 200
                }}
              {%- endif -%}
            </button>
          {%- endfor -%}
        {%- endif -%}
      </div>

      <div class="main-product-card" data-lawn-main-image>
        {%- if main_image != blank -%}
          {%- if main_image_from_product -%}
            {{ main_image | image_url: width: 1200 | image_tag:
              loading: 'eager',
              alt: current_product.title,
              width: 1200,
              height: 1200
            }}
          {%- else -%}
            {{ main_image | image_url: width: 1200 | image_tag:
              loading: 'eager',
              alt: section.settings.main_image_alt | default: hero_title,
              width: 1200,
              height: 1200
            }}
          {%- endif -%}
        {%- else -%}
          <img src="{{ 'envy-tall-fescue-design.png' | asset_url }}"
               alt="{{ section.settings.main_image_alt | default: hero_title }}"
               width="1200" height="1200">
        {%- endif -%}
      </div>
    </div>

    {%- if section.settings.show_dots -%}
      <div class="slider-dots" aria-hidden="true">
        {%- assign dot_count = section.settings.dot_count | default: 5 -%}
        {%- assign active_dot = section.settings.active_dot | default: 3 -%}
        {%- for i in (1..dot_count) -%}
          <span{% if i == active_dot %} class="active"{% endif %}></span>
        {%- endfor -%}
      </div>
    {%- endif -%}

    {%- if section.settings.show_trust -%}
      <div class="trust-row">
        {%- for block in trust_blocks -%}
          <div class="trust-item" {{ block.shopify_attributes }}>
            {%- if block.settings.image != blank -%}
              {{ block.settings.image | image_url: width: 200 | image_tag:
                loading: 'lazy',
                class: 'seal-img',
                alt: '',
                width: 86,
                height: 86
              }}
            {%- else -%}
              <img class="seal-img" src="{{ 'trust-shipping.png' | asset_url }}" alt="" width="86" height="86" loading="lazy">
            {%- endif -%}
            <strong>{{ block.settings.label }}</strong>
          </div>
        {%- endfor -%}
      </div>
    {%- endif -%}
  </div>

  <div class="product-info">
    {%- if show_vendor and has_product and current_product.vendor != blank -%}
      <p class="product-vendor">{{ current_product.vendor }}</p>
    {%- endif -%}

    {%- if section.settings.show_rating -%}
      <div class="rating">
        <span class="stars">{{ rating_value }}</span>
        <span>{{ rating_text_value }}</span>
      </div>
    {%- endif -%}

    <h1>{{ hero_title }}</h1>

    {%- if hero_lead_is_html -%}
      <div class="lead rte">{{ hero_lead }}</div>
    {%- else -%}
      <p class="lead">{{ hero_lead }}</p>
    {%- endif -%}

    <ul class="feature-list">
      {%- if features_from_metafield -%}
        {%- for f in features_list -%}
          <li>{{ f }}</li>
        {%- endfor -%}
      {%- else -%}
        {%- for block in feature_blocks -%}
          <li {{ block.shopify_attributes }}>{{ block.settings.text }}</li>
        {%- endfor -%}
      {%- endif -%}
    </ul>

    {%- if show_sku and has_product and selected_variant.sku != blank -%}
      <p class="product-sku" data-product-sku>SKU: {{ selected_variant.sku }}</p>
    {%- endif -%}

    <div class="price-row">
      {%- if has_product -%}
        <span class="sale-price" data-product-price>{{ selected_variant.price | money }}</span>
        {%- if selected_variant.compare_at_price > selected_variant.price -%}
          <span class="old-price" data-product-compare-price>{{ selected_variant.compare_at_price | money }}</span>
        {%- else -%}
          <span class="old-price" data-product-compare-price hidden></span>
        {%- endif -%}
      {%- else -%}
        <span class="sale-price">{{ sale_price_text }}</span>
        {%- if old_price_text != blank -%}
          <span class="old-price">{{ old_price_text }}</span>
        {%- endif -%}
      {%- endif -%}
    </div>

    {%- if show_size_area -%}
      <div class="size-area">
        <h2>{{ section.settings.size_heading | default: 'Select Your Size' }}</h2>
        <div class="size-grid" role="radiogroup" aria-label="Select size">
          {%- if use_real_variants -%}
            {%- for variant in current_product.variants -%}
              {%- liquid
                assign vidx = forloop.index0
                assign sblock = size_blocks[vidx]

                assign is_selected = false
                if variant.id == selected_variant.id
                  assign is_selected = true
                endif

                # Variant label: variant metafield > variant.title > size block fallback
                assign size_label = variant.title
                assign meta_size_label = variant.metafields.lawn.size_label
                if meta_size_label != blank
                  assign size_label = meta_size_label
                endif
                if use_size_block_labels and sblock.settings.size != blank
                  assign size_label = sblock.settings.size
                endif

                # Coverage: variant metafield > size block coverage
                assign meta_coverage = variant.metafields.lawn.coverage
                if meta_coverage != blank
                  assign coverage_text = meta_coverage
                else
                  assign coverage_text = sblock.settings.coverage
                endif

                # Badge: variant metafield > size block badge
                assign meta_badge = variant.metafields.lawn.badge
                if meta_badge != blank
                  assign badge_text = meta_badge
                else
                  assign badge_text = sblock.settings.badge
                endif
              -%}
              <button
                class="size-card{% if is_selected %} is-selected{% endif %}{% if badge_text != blank %} has-badge{% endif %}{% unless variant.available %} is-unavailable{% endunless %}"
                type="button"
                data-variant-id="{{ variant.id }}"
                data-variant-price="{{ variant.price | money }}"
                data-variant-compare-price="{% if variant.compare_at_price > variant.price %}{{ variant.compare_at_price | money }}{% endif %}"
                data-variant-available="{{ variant.available }}"
                data-variant-sku="{{ variant.sku | escape }}"
                aria-pressed="{% if is_selected %}true{% else %}false{% endif %}"
                {%- unless variant.available %} aria-disabled="true"{%- endunless %}
              >
                {%- if badge_text != blank -%}
                  <em>{{ badge_text }}</em>
                {%- endif -%}
                <strong>{{ size_label }}</strong>
                {%- if coverage_text != blank -%}
                  <span>{{ coverage_text }}</span>
                {%- else -%}
                  <span>&nbsp;</span>
                {%- endif -%}
                <b>{{ variant.price | money }}</b>
              </button>
            {%- endfor -%}
          {%- else -%}
            {%- for block in size_blocks -%}
              <button
                class="size-card{% if forloop.first %} is-selected{% endif %}{% if block.settings.badge != blank %} has-badge{% endif %}"
                type="button"
                aria-pressed="{% if forloop.first %}true{% else %}false{% endif %}"
                {{ block.shopify_attributes }}
              >
                {%- if block.settings.badge != blank -%}
                  <em>{{ block.settings.badge }}</em>
                {%- endif -%}
                <strong>{{ block.settings.size }}</strong>
                <span>{{ block.settings.coverage }}</span>
                <b>{{ block.settings.price }}</b>
              </button>
            {%- endfor -%}
          {%- endif -%}
        </div>
      </div>
    {%- endif -%}

    {%- if has_product and current_product != blank -%}
      {%- assign form_id = 'lawn-hero-product-form-' | append: section.id -%}
      {%- form 'product', current_product, id: form_id, class: 'lawn-product-form', novalidate: 'novalidate' -%}
        <input type="hidden" name="id" value="{{ selected_variant.id }}" data-product-variant-input>
        <div class="buy-box">
          <label for="quantity-{{ section.id }}">{{ section.settings.qty_label | default: 'Quantity:' }}</label>
          <div class="quantity">
            <button class="qty-btn" data-qty="minus" type="button" aria-label="Decrease quantity">-</button>
            <span id="quantityValue">{{ section.settings.default_qty | default: 1 }}</span>
            <button class="qty-btn" data-qty="plus" type="button" aria-label="Increase quantity">+</button>
            <input type="hidden" name="quantity" id="quantity-{{ section.id }}" value="{{ section.settings.default_qty | default: 1 }}" data-product-quantity-input>
          </div>
          {%- if urgency_text != blank -%}
            <span class="selling">{{ urgency_text }}</span>
          {%- endif -%}
        </div>

        {%- if section.settings.program_text != blank -%}
          <p class="program">
            {{ section.settings.program_text }}
            {%- if section.settings.program_link != blank -%}
              <a href="{{ section.settings.program_link }}">{{ section.settings.program_link_label | default: 'Join the Program' }}</a>
            {%- endif -%}
          </p>
        {%- endif -%}

        <button
          class="add-cart"
          type="submit"
          name="add"
          data-add-to-cart
          data-add-label="{{ section.settings.cta_label | default: 'Add To Cart' | escape }}"
          {%- unless selected_variant.available %} disabled{%- endunless %}
        >
          {%- if selected_variant.available -%}
            {{ section.settings.cta_label | default: 'Add To Cart' }}
          {%- else -%}
            {{ 'products.product.sold_out' | t | default: 'Sold Out' }}
          {%- endif -%}
        </button>
      {%- endform -%}
    {%- else -%}
      <div class="buy-box">
        <label>{{ section.settings.qty_label | default: 'Quantity:' }}</label>
        <div class="quantity">
          <button class="qty-btn" data-qty="minus" type="button" aria-label="Decrease quantity">-</button>
          <span id="quantityValue">{{ section.settings.default_qty | default: 1 }}</span>
          <button class="qty-btn" data-qty="plus" type="button" aria-label="Increase quantity">+</button>
        </div>
        {%- if urgency_text != blank -%}
          <span class="selling">{{ urgency_text }}</span>
        {%- endif -%}
      </div>

      {%- if section.settings.program_text != blank -%}
        <p class="program">
          {{ section.settings.program_text }}
          {%- if section.settings.program_link != blank -%}
            <a href="{{ section.settings.program_link }}">{{ section.settings.program_link_label | default: 'Join the Program' }}</a>
          {%- endif -%}
        </p>
      {%- endif -%}

      <button class="add-cart" type="button" disabled>{{ section.settings.cta_label | default: 'Add To Cart' }}</button>
      <p class="program" style="opacity:.7"><small>Link a product in the section settings to enable add to cart.</small></p>
    {%- endif -%}

    {%- if section.settings.show_shipping_line -%}
      <div class="shipping-line">
        {%- if section.settings.shipping_left != blank -%}
          <span>{{ section.settings.shipping_left }}</span>
        {%- endif -%}
        {%- if section.settings.shipping_right != blank -%}
          <span>{{ section.settings.shipping_right }}</span>
        {%- endif -%}
      </div>
    {%- endif -%}

    {%- if section.settings.show_payments -%}
      <div class="payments">
        {%- assign payments = section.settings.payment_labels | default: 'AMEX,Pay,G Pay,MC,MC,VISA' | split: ',' -%}
        {%- for payment in payments -%}
          <span>{{ payment | strip }}</span>
        {%- endfor -%}
      </div>
    {%- endif -%}

    <div class="product-accordions">
      {%- for block in accordion_blocks -%}
        {%- liquid
          assign accordion_content = block.settings.content
          assign metafield_key = block.settings.metafield_key

          # If a key is selected and the block has no content, pull from product metafield
          if accordion_content == blank and has_product and metafield_key != blank
            assign mf_val = current_product.metafields.lawn[metafield_key]
            if mf_val != blank
              assign accordion_content = mf_val
            endif
          endif

          # Auto-fallback: when title looks like "Product Details" and no content/metafield, use product description
          if accordion_content == blank and has_product
            assign title_lower = block.settings.title | downcase
            if title_lower contains 'product details' or title_lower contains 'description'
              if current_product.description != blank
                assign accordion_content = current_product.description
              endif
            endif
          endif
        -%}
        <details class="product-accordion" {{ block.shopify_attributes }}>
          <summary>
            <span>{{ block.settings.title }}</span>
            <i></i>
          </summary>
          {%- if accordion_content != blank -%}
            <div class="product-accordion__content rte">{{ accordion_content }}</div>
          {%- endif -%}
        </details>
      {%- endfor -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Lawn — Hero Product",
  "tag": "section",
  "class": "lawn-hero-section",
  "settings": [
    {
      "type": "header",
      "content": "Product (optional)"
    },
    {
      "type": "product",
      "id": "product",
      "label": "Linked product",
      "info": "On a product template the page product is used automatically. Use this to link a product on non-product templates (e.g. homepage)."
    },
    {
      "type": "paragraph",
      "content": "Tip: To make the section fully dynamic, define product metafields under the namespace 'lawn' (e.g. lawn.rating, lawn.features, lawn.product_details). Variant-level metafields supported: lawn.coverage, lawn.badge, lawn.size_label."
    },
    {
      "type": "header",
      "content": "Main media"
    },
    {
      "type": "checkbox",
      "id": "use_product_media",
      "label": "Use real product media",
      "default": true,
      "info": "When a product is linked, Shopify product images replace the custom image and thumbnail fallback."
    },
    {
      "type": "image_picker",
      "id": "main_image",
      "label": "Main image (fallback)",
      "info": "Used only when no product image is available."
    },
    {
      "type": "text",
      "id": "main_image_alt",
      "label": "Main image alt text",
      "default": "Product graphic"
    },
    {
      "type": "checkbox",
      "id": "show_dots",
      "label": "Show slider dots",
      "default": true
    },
    {
      "type": "range",
      "id": "dot_count",
      "label": "Number of dots",
      "min": 2,
      "max": 10,
      "step": 1,
      "default": 5
    },
    {
      "type": "range",
      "id": "active_dot",
      "label": "Active dot index",
      "min": 1,
      "max": 10,
      "step": 1,
      "default": 3
    },
    {
      "type": "checkbox",
      "id": "show_trust",
      "label": "Show trust row",
      "default": true
    },
    {
      "type": "header",
      "content": "Product info"
    },
    {
      "type": "checkbox",
      "id": "show_vendor",
      "label": "Show product vendor",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "show_sku",
      "label": "Show selected variant SKU",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "show_rating",
      "label": "Show rating row",
      "default": true
    },
    {
      "type": "text",
      "id": "rating_stars",
      "label": "Stars text (fallback)",
      "default": "★★★★★",
      "info": "Overridden by product metafield lawn.rating_stars or lawn.rating."
    },
    {
      "type": "text",
      "id": "rating_text",
      "label": "Rating text (fallback)",
      "default": "Rated By 12,520+ Customers",
      "info": "Overridden by product metafield lawn.rating_text or lawn.rating_count."
    },
    {
      "type": "checkbox",
      "id": "use_product_title",
      "label": "Use real product title",
      "default": true
    },
    {
      "type": "text",
      "id": "title",
      "label": "Title (fallback)",
      "default": "Premium Product"
    },
    {
      "type": "checkbox",
      "id": "use_product_description",
      "label": "Use product description / lawn.short_summary as lead",
      "default": true
    },
    {
      "type": "textarea",
      "id": "lead",
      "label": "Lead (fallback)",
      "default": "Premium product description."
    },
    {
      "type": "header",
      "content": "Price (used when no product is linked)"
    },
    {
      "type": "text",
      "id": "sale_price",
      "label": "Sale price",
      "default": "$49.99"
    },
    {
      "type": "text",
      "id": "old_price",
      "label": "Compare-at price",
      "default": "$56.25"
    },
    {
      "type": "header",
      "content": "Size selector"
    },
    {
      "type": "checkbox",
