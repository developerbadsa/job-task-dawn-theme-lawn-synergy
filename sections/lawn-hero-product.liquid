{%- liquid
  # =========================================================
  # Lawn Synergy Dynamic Product Hero
  # File: sections/lawn-product-hero.liquid
  # Dynamic source priority:
  # 1) Product page product object
  # 2) Section selected product
  # 3) Section fallback settings / blocks
  # =========================================================

  assign current_product = null

  if product != blank and product.id != blank
    assign current_product = product
  elsif section.settings.product != blank
    assign current_product = section.settings.product
  endif

  assign has_product = false
  if current_product != null and current_product.id != blank
    assign has_product = true
  endif

  assign selected_variant = null
  if has_product
    assign selected_variant = current_product.selected_or_first_available_variant
    if selected_variant == blank
      assign selected_variant = current_product.variants.first
    endif
  endif

  assign thumb_blocks = section.blocks | where: 'type', 'thumb'
  assign trust_blocks = section.blocks | where: 'type', 'trust'
  assign feature_blocks = section.blocks | where: 'type', 'feature'
  assign size_blocks = section.blocks | where: 'type', 'size'
  assign accordion_blocks = section.blocks | where: 'type', 'accordion'

  assign use_product_media = section.settings.use_product_media
  assign use_product_title = section.settings.use_product_title
  assign use_product_description = section.settings.use_product_description

  assign hero_title = section.settings.title | default: 'Envy Premium Tall Fescue Grass Seed Blend'
  if has_product and use_product_title
    assign hero_title = current_product.title
  endif

  assign hero_lead = section.settings.lead | default: 'Professional-Grade Tall Fescue Blend Designed For Durability, Color, And Performance Without The Hassle Of High Maintenance.'
  if has_product and use_product_description
    assign meta_summary = current_product.metafields.lawn.short_summary
    if meta_summary != blank
      assign hero_lead = meta_summary | metafield_text
    elsif current_product.description != blank
      assign hero_lead = current_product.description | strip_html | truncatewords: 28
    endif
  endif

  assign rating_stars = section.settings.rating_stars | default: '★★★★★'
  assign rating_text = section.settings.rating_text | default: 'Rated By 12,520+ Customers'
  if has_product
    assign meta_rating_stars = current_product.metafields.lawn.rating_stars
    assign meta_rating_text = current_product.metafields.lawn.rating_text
    assign meta_rating_count = current_product.metafields.lawn.rating_count

    if meta_rating_stars != blank
      assign rating_stars = meta_rating_stars | metafield_text
    endif

    if meta_rating_text != blank
      assign rating_text = meta_rating_text | metafield_text
    elsif meta_rating_count != blank
      assign rating_count_text = meta_rating_count | metafield_text
      assign rating_text = 'Rated By ' | append: rating_count_text | append: '+ Customers'
    endif
  endif

  assign main_image = null
  assign main_image_alt = hero_title
  if has_product and use_product_media and current_product.featured_media != blank and current_product.featured_media.preview_image != blank
    assign main_image = current_product.featured_media.preview_image
    assign main_image_alt = current_product.featured_media.alt | default: current_product.title
  elsif has_product and use_product_media and current_product.featured_image != blank
    assign main_image = current_product.featured_image
    assign main_image_alt = current_product.title
  elsif section.settings.main_image != blank
    assign main_image = section.settings.main_image
    assign main_image_alt = section.settings.main_image_alt | default: hero_title
  endif

  assign show_product_gallery = false
  if has_product and use_product_media and current_product.media.size > 0
    assign show_product_gallery = true
  endif

  assign show_size_area = true
  if has_product and current_product.has_only_default_variant
    assign show_size_area = false
  endif

  assign use_real_variants = false
  if has_product and show_size_area and current_product.variants.size > 0
    assign use_real_variants = true
  endif

  assign features_from_metafield = false
  assign features_list = null
  if has_product
    assign meta_features = current_product.metafields.lawn.features
    if meta_features != blank and meta_features.value != blank
      assign features_list = meta_features.value
      assign features_from_metafield = true
    endif
  endif

  assign urgency_text = section.settings.urgency_text | default: 'Selling Fast'
  if has_product and current_product.metafields.lawn.urgency_text != blank
    assign urgency_text = current_product.metafields.lawn.urgency_text | metafield_text
  endif

  assign fallback_sale_price = section.settings.sale_price | default: '$49.99'
  assign fallback_compare_price = section.settings.compare_price | default: '$56.25'
-%}

<section
  id="LawnFigmaProduct-{{ section.id }}"
  class="lawn-figma-product"
  data-lawn-figma-product
  data-section-id="{{ section.id }}"
>
  <div class="lawn-figma-product__inner">
    <div class="lawn-figma-product__media">
      <div class="lawn-figma-gallery">
        <div class="lawn-figma-gallery__thumbs" aria-label="Product media thumbnails">
          {%- if show_product_gallery -%}
            {%- for media in current_product.media limit: section.settings.max_thumbnails -%}
              {%- if media.preview_image != blank -%}
                <button
                  class="lawn-figma-thumb{% if forloop.first %} is-active{% endif %}"
                  type="button"
                  data-gallery-thumb
                  data-main-image="{{ media.preview_image | image_url: width: 1200 }}"
                  data-main-alt="{{ media.alt | default: current_product.title | escape }}"
                  aria-label="View image {{ forloop.index }}"
                >
                  {{
                    media.preview_image
                    | image_url: width: 180
                    | image_tag: loading: 'lazy', alt: media.alt
                    | default: current_product.title, widths: '90, 140, 180', sizes: '76px'
                  }}
                </button>
              {%- endif -%}
            {%- endfor -%}
          {%- else -%}
            {%- for block in thumb_blocks limit: section.settings.max_thumbnails -%}
              {%- liquid
                assign thumb_image = block.settings.image
                assign thumb_alt = block.settings.alt | default: hero_title
              -%}
              {%- if thumb_image != blank -%}
                <button
                  class="lawn-figma-thumb{% if forloop.first %} is-active{% endif %}"
                  type="button"
                  data-gallery-thumb
                  data-main-image="{{ thumb_image | image_url: width: 1200 }}"
                  data-main-alt="{{ thumb_alt | escape }}"
                  aria-label="View image {{ forloop.index }}"
                  {{ block.shopify_attributes }}
                >
                  {{
                    thumb_image
                    | image_url: width: 180
                    | image_tag: loading: 'lazy', alt: thumb_alt, widths: '90, 140, 180', sizes: '76px'
                  }}
                </button>
              {%- endif -%}
            {%- endfor -%}
          {%- endif -%}
        </div>

        <div class="lawn-figma-gallery__main">
          {%- if main_image != blank -%}
            <img
              src="{{ main_image | image_url: width: 1200 }}"
              alt="{{ main_image_alt | escape }}"
              width="1200"
              height="1200"
              loading="eager"
              data-main-image-target
            >
          {%- else -%}
            {{ 'product-1' | placeholder_svg_tag: 'placeholder-svg' }}
          {%- endif -%}
        </div>
      </div>

      {%- if section.settings.show_dots -%}
        <div class="lawn-figma-dots" aria-hidden="true">
          {%- for i in (1..5) -%}
            <span class="{% if i == section.settings.active_dot %}is-active{% endif %}"></span>
          {%- endfor -%}
        </div>
      {%- endif -%}

      {%- if section.settings.show_trust_badges -%}
        <div class="lawn-figma-trust" aria-label="Store benefits">
          {%- for block in trust_blocks -%}
            {%- liquid
              assign custom_icon_image = block.settings.custom_icon_image
              assign theme_icon_asset = block.settings.theme_icon_asset | strip
              assign has_custom_icon = false

              if custom_icon_image != blank or theme_icon_asset != blank
                assign has_custom_icon = true
              endif
            -%}
            <div class="lawn-figma-trust__item" {{ block.shopify_attributes }}>
              <span class="lawn-figma-trust__seal{% if has_custom_icon %} lawn-figma-trust__seal--custom{% endif %}" aria-hidden="true">
                {%- if custom_icon_image != blank -%}
                  {{
                    custom_icon_image
                    | image_url: width: 96
                    | image_tag:
                      loading: 'lazy',
                      alt: block.settings.label,
                      widths: '48, 72, 96',
                      sizes: '48px',
                      class: 'lawn-figma-trust__custom-icon'
                  }}
                {%- elsif theme_icon_asset != blank -%}
                  {%- if theme_icon_asset contains '.svg' -%}
                    {{ theme_icon_asset | inline_asset_content }}
                  {%- else -%}
                    <img
                      class="lawn-figma-trust__custom-icon"
                      src="{{ theme_icon_asset | asset_url }}"
                      alt="{{ block.settings.label | escape }}"
                      loading="lazy"
                      width="48"
                      height="48"
                    >
                  {%- endif -%}
                {%- else -%}
                  {%- case block.settings.icon -%}
                    {%- when 'quality' -%}
                      <svg viewBox="0 0 24 24" focusable="false">
                        <path d="M12 2.5l2.4 2 3.1-.1 1.1 2.9 2.5 1.9-1 3 1 3-2.5 1.9-1.1 2.9-3.1-.1-2.4 2-2.4-2-3.1.1-1.1-2.9L2.9 15.2l1-3-1-3 2.5-1.9 1.1-2.9 3.1.1 2.4-2z"/><path d="M8 12.3l2.5 2.5L16.4 9"/>
                      </svg>
                    {%- when 'secure' -%}
                      <svg viewBox="0 0 24 24" focusable="false">
                        <path d="M7 10V7a5 5 0 0 1 10 0v3"/><rect x="5" y="10" width="14" height="11" rx="2"/><path d="M12 15v2"/>
                      </svg>
                    {%- when 'return' -%}
                      <svg viewBox="0 0 24 24" focusable="false">
                        <path d="M20 7v5h-5"/><path d="M19 12a7 7 0 1 1-2-5"/><path d="M8 12h5"/>
                      </svg>
                    {%- else -%}
                      <svg viewBox="0 0 24 24" focusable="false">
                        <path d="M3 7h11v9H3z"/><path d="M14 10h3.5l2.5 3v3h-6z"/><circle cx="7" cy="17.5" r="1.8"/><circle cx="17.5" cy="17.5" r="1.8"/><path d="M5 10h5M5 13h4"/>
                      </svg>
                  {%- endcase -%}
                {%- endif -%}
              </span>
              <strong>{{ block.settings.label }}</strong>
            </div>
          {%- endfor -%}
        </div>
      {%- endif -%}
    </div>

    <div class="lawn-figma-product__info">
      {%- if section.settings.show_rating -%}
        <div class="lawn-figma-rating">
          <span class="lawn-figma-rating__stars" aria-hidden="true">{{ rating_stars }}</span>
          <span class="lawn-figma-rating__text">{{ rating_text }}</span>
        </div>
      {%- endif -%}

      <h1 class="lawn-figma-title">{{ hero_title }}</h1>

      {%- if hero_lead != blank -%}
        <p class="lawn-figma-lead">{{ hero_lead }}</p>
      {%- endif -%}

      <ul class="lawn-figma-features" role="list">
        {%- if features_from_metafield -%}
          {%- for feature in features_list -%}
            <li>
              <span aria-hidden="true">✓</span>
              <strong>{{ feature }}</strong>
            </li>
          {%- endfor -%}
        {%- else -%}
          {%- for block in feature_blocks -%}
            <li {{ block.shopify_attributes }}>
              <span aria-hidden="true">✓</span>
              <strong>{{ block.settings.text }}</strong>
            </li>
          {%- endfor -%}
        {%- endif -%}
      </ul>

      {%- if section.settings.show_sku and has_product and selected_variant.sku != blank -%}
        <p class="lawn-figma-sku" data-sku>SKU: {{ selected_variant.sku }}</p>
      {%- endif -%}

      <div class="lawn-figma-price">
        {%- if has_product and selected_variant != blank -%}
          <span class="lawn-figma-price__sale" data-product-price>{{ selected_variant.price | money }}</span>
          {%- if selected_variant.compare_at_price > selected_variant.price -%}
            <span class="lawn-figma-price__compare" data-product-compare-price>
              {{- selected_variant.compare_at_price | money -}}
            </span>
          {%- else -%}
            <span class="lawn-figma-price__compare" data-product-compare-price hidden></span>
          {%- endif -%}
        {%- else -%}
          <span class="lawn-figma-price__sale">{{ fallback_sale_price }}</span>
          <span class="lawn-figma-price__compare">{{ fallback_compare_price }}</span>
        {%- endif -%}
      </div>

      {%- if show_size_area -%}
        <div class="lawn-figma-size">
          <h2>{{ section.settings.size_heading }}</h2>
          <div
            class="lawn-figma-size__grid"
            role="radiogroup"
            aria-label="{{ section.settings.size_heading | escape }}"
          >
            {%- if use_real_variants -%}
              {%- for variant in current_product.variants limit: section.settings.max_variant_cards -%}
                {%- liquid
                  assign card_index = forloop.index0
                  assign fallback_size_block = size_blocks[card_index]

                  assign is_selected = false
                  if selected_variant.id == variant.id
                    assign is_selected = true
                  endif

                  assign size_label = variant.title
                  if variant.metafields.lawn.size_label != blank
                    assign size_label = variant.metafields.lawn.size_label | metafield_text
                  elsif fallback_size_block.settings.size != blank and section.settings.force_block_size_labels
                    assign size_label = fallback_size_block.settings.size
                  endif

                  assign coverage_text = ''
                  if variant.metafields.lawn.coverage != blank
                    assign coverage_text = variant.metafields.lawn.coverage | metafield_text
                  elsif fallback_size_block.settings.coverage != blank
                    assign coverage_text = fallback_size_block.settings.coverage
                  endif

                  assign badge_text = ''
                  if variant.metafields.lawn.badge != blank
                    assign badge_text = variant.metafields.lawn.badge | metafield_text
                  elsif fallback_size_block.settings.badge != blank
                    assign badge_text = fallback_size_block.settings.badge
                  endif

                  assign card_price_text = variant.price | money
                  if variant.metafields.lawn.card_price != blank
                    assign card_price_text = variant.metafields.lawn.card_price | metafield_text
                  endif
                -%}

                <button
                  type="button"
                  class="lawn-figma-size-card{% if is_selected %} is-selected{% endif %}{% if badge_text != blank %} has-badge{% endif %}{% unless variant.available %} is-unavailable{% endunless %}"
                  role="radio"
                  aria-checked="{% if is_selected %}true{% else %}false{% endif %}"
                  data-variant-card
                  data-variant-id="{{ variant.id }}"
                  data-variant-price="{{ variant.price | money | escape }}"
                  data-variant-compare="{% if variant.compare_at_price > variant.price %}{{ variant.compare_at_price | money | escape }}{% endif %}"
                  data-variant-available="{% if variant.available %}true{% else %}false{% endif %}"
                  data-variant-sku="{{ variant.sku | escape }}"
                  data-variant-image="{% if variant.featured_media != blank and variant.featured_media.preview_image != blank %}{{ variant.featured_media.preview_image | image_url: width: 1200 }}{% endif %}"
                  data-variant-alt="{{ variant.featured_media.alt | default: variant.title | escape }}"
                >
                  {%- if badge_text != blank -%}
                    <em>{{ badge_text }}</em>
                  {%- endif -%}
                  <strong>{{ size_label }}</strong>
                  <span>{{ coverage_text | default: '&nbsp;' }}</span>
                  <b>{{ card_price_text }}</b>
                </button>
              {%- endfor -%}
            {%- else -%}
              {%- for block in size_blocks -%}
                <button
                  type="button"
                  class="lawn-figma-size-card{% if forloop.first %} is-selected{% endif %}{% if block.settings.badge != blank %} has-badge{% endif %}"
                  role="radio"
                  aria-checked="{% if forloop.first %}true{% else %}false{% endif %}"
                  data-static-size-card
                  {{ block.shopify_attributes }}
                >
                  {%- if block.settings.badge != blank -%}
                    <em>{{ block.settings.badge }}</em>
                  {%- endif -%}
                  <strong>{{ block.settings.size }}</strong>
                  <span>{{ block.settings.coverage }}</span>
                  <b>{{ block.settings.price }}</b>
                </button>
              {%- endfor -%}
            {%- endif -%}
          </div>
        </div>
      {%- endif -%}

      {%- if has_product and selected_variant != blank -%}
        {%- assign form_id = 'lawn-figma-product-form-' | append: section.id -%}
        {%- form 'product', current_product, id: form_id, class: 'lawn-figma-form', novalidate: 'novalidate' -%}
          <input type="hidden" name="id" value="{{ selected_variant.id }}" data-variant-input>
          <input type="hidden" name="quantity" value="{{ section.settings.default_quantity }}" data-quantity-input>

          <div class="lawn-figma-buy">
            <label>{{ section.settings.quantity_label }}</label>
            <div class="lawn-figma-qty" aria-label="Quantity selector">
              <button type="button" data-qty-minus aria-label="Decrease quantity">−</button>
              <span data-qty-value>{{ section.settings.default_quantity }}</span>
              <button type="button" data-qty-plus aria-label="Increase quantity">+</button>
            </div>
            {%- if urgency_text != blank -%}
              <span class="lawn-figma-selling">{{ urgency_text }}</span>
            {%- endif -%}
          </div>

          {%- if section.settings.program_text != blank -%}
            <p class="lawn-figma-program">
              {{ section.settings.program_text }}
              {%- if section.settings.program_link != blank -%}
                <a href="{{ section.settings.program_link }}">{{ section.settings.program_link_label }}</a>
              {%- endif -%}
            </p>
          {%- endif -%}

          <button
            class="lawn-figma-cart"
            type="submit"
            name="add"
            data-add-to-cart
            data-add-label="{{ section.settings.cta_label | escape }}"
            data-sold-out-label="{{ section.settings.sold_out_label | escape }}"
            {% unless selected_variant.available %}
              disabled
            {% endunless %}
          >
            {%- if selected_variant.available -%}
              {{ section.settings.cta_label }}
            {%- else -%}
              {{ section.settings.sold_out_label }}
            {%- endif -%}
          </button>
        {%- endform -%}
      {%- else -%}
        <div class="lawn-figma-form">
          <div class="lawn-figma-buy">
            <label>{{ section.settings.quantity_label }}</label>
            <div class="lawn-figma-qty" aria-label="Quantity selector">
              <button type="button" data-qty-minus aria-label="Decrease quantity">−</button>
              <span data-qty-value>{{ section.settings.default_quantity }}</span>
              <button type="button" data-qty-plus aria-label="Increase quantity">+</button>
            </div>
            <span class="lawn-figma-selling">{{ urgency_text }}</span>
          </div>

          {%- if section.settings.program_text != blank -%}
            <p class="lawn-figma-program">
              {{ section.settings.program_text }}
              {%- if section.settings.program_link != blank -%}
                <a href="{{ section.settings.program_link }}">{{ section.settings.program_link_label }}</a>
              {%- endif -%}
            </p>
          {%- endif -%}

          <button class="lawn-figma-cart" type="button" disabled>{{ section.settings.cta_label }}</button>
        </div>
      {%- endif -%}

      {%- if section.settings.show_shipping_line -%}
        <div class="lawn-figma-shipping">
          <span>
            <svg viewBox="0 0 24 24" aria-hidden="true">
              <path d="M3 7h11v8H3z"/><path d="M14 10h3.5l2.5 3v2h-6z"/><circle cx="7" cy="16.5" r="1.5"/><circle cx="17.5" cy="16.5" r="1.5"/>
            </svg>
            {{ section.settings.shipping_left }}
          </span>
          <span>
            <svg viewBox="0 0 24 24" aria-hidden="true">
              <circle cx="12" cy="12" r="9"/><path d="M8 12l2.5 2.5L16 9"/>
            </svg>
            {{ section.settings.shipping_right }}
          </span>
        </div>
      {%- endif -%}

      {%- if section.settings.show_payment_icons -%}
        <div class="lawn-figma-payments" aria-label="Accepted payment methods">
          {%- if section.settings.use_shopify_payment_icons and shop.enabled_payment_types.size > 0 -%}
            {%- for type in shop.enabled_payment_types limit: 6 -%}
              <span class="lawn-figma-payment-svg">{{ type | payment_type_svg_tag }}</span>
            {%- endfor -%}
          {%- else -%}
            {%- assign payment_labels = section.settings.payment_labels | split: ',' -%}
            {%- for label in payment_labels -%}
              <span>{{ label | strip }}</span>
            {%- endfor -%}
          {%- endif -%}
        </div>
      {%- endif -%}

      {%- if accordion_blocks.size > 0 -%}
        <div class="lawn-figma-accordions">
          {%- for block in accordion_blocks -%}
            {%- liquid
              assign accordion_key = block.settings.metafield_key
              assign accordion_mf = blank

              if accordion_key == blank
                assign title_down = block.settings.title | downcase | strip
                case title_down
                  when 'product details'
                    assign accordion_key = 'product_details'
                  when 'spreader settings'
                    assign accordion_key = 'spreader_settings'
                  when "what's inside the blend?"
                    assign accordion_key = 'whats_inside'
                  when 'whats inside the blend'
                    assign accordion_key = 'whats_inside'
                  when 'what’s inside the blend?'
                    assign accordion_key = 'whats_inside'
                  when 'what’s inside the blend'
                    assign accordion_key = 'whats_inside'
                  when 'when to use'
                    assign accordion_key = 'when_to_use'
                  when 'grow a thicker greener lawn'
                    assign accordion_key = 'grow_tips'
                endcase
              endif

              if has_product and accordion_key != blank
                assign accordion_mf = current_product.metafields.lawn[accordion_key]
              endif
            -%}

            <details class="lawn-figma-accordion" {{ block.shopify_attributes }}>
              <summary>
                <span class="lawn-figma-accordion__icon" aria-hidden="true">
                  {%- case block.settings.icon -%}
                    {%- when 'spreader' -%}
                      <svg viewBox="0 0 24 24">
                        <path d="M7 9h10l-1 7H8L7 9z"/><path d="M9 9V6h6v3"/><circle cx="9" cy="18" r="1.5"/><circle cx="15" cy="18" r="1.5"/>
                      </svg>
                    {%- when 'blend' -%}
                      <svg viewBox="0 0 24 24">
                        <path d="M12 3l8 4.5v9L12 21l-8-4.5v-9L12 3z"/><path d="M4 7.5l8 4.5 8-4.5"/><path d="M12 12v9"/>
                      </svg>
                    {%- when 'calendar' -%}
                      <svg viewBox="0 0 24 24">
                        <rect x="4" y="5" width="16" height="15" rx="2"/><path d="M8 3v4M16 3v4M4 10h16"/><path d="M8 14l2 2 5-5"/>
                      </svg>
                    {%- when 'grow' -%}
                      <svg viewBox="0 0 24 24">
                        <path d="M12 20V9"/><path d="M12 12c-4 0-6-2-7-6 4 0 7 2 7 6z"/><path d="M12 15c4 0 6-2 7-6-4 0-7 2-7 6z"/>
                      </svg>
                    {%- else -%}
                      <svg viewBox="0 0 24 24">
                        <path d="M5 4h14v16H5z"/><path d="M8 8h8M8 12h8M8 16h5"/>
                      </svg>
                  {%- endcase -%}
                </span>
                <span class="lawn-figma-accordion__title">{{ block.settings.title }}</span>
                <span class="lawn-figma-accordion__chev" aria-hidden="true"></span>
              </summary>

              <div class="lawn-figma-accordion__content rte">
                {%- if block.settings.content != blank -%}
                  {{ block.settings.content }}
                {%- elsif accordion_mf != blank -%}
                  {{ accordion_mf | metafield_tag }}
                {%- elsif has_product
                  and current_product.description != blank
                  and accordion_key == 'product_details'
                -%}
                  {{ current_product.description }}
                {%- endif -%}
              </div>
            </details>
          {%- endfor -%}
        </div>
      {%- endif -%}
    </div>
  </div>
</section>

{% style %}
  #LawnFigmaProduct-{{ section.id }} {
    --lawn-green: {{ section.settings.green_color }};
    --lawn-dark: {{ section.settings.dark_color }};
    --lawn-orange: {{ section.settings.orange_color }};
    --lawn-text: {{ section.settings.text_color }};
    --lawn-muted: {{ section.settings.muted_color }};
    --lawn-line: {{ section.settings.line_color }};
    --lawn-bg: {{ section.settings.background_color }};
    --lawn-max: {{ section.settings.max_width }}px;
    --lawn-left: {{ section.settings.left_column_width }}px;
    --lawn-right: {{ section.settings.right_column_width }}px;
    background: var(--lawn-bg);
    color: var(--lawn-text);
    font-family: var(--font-body-family, Poppins, Inter, Arial, sans-serif);
    padding-top: {{ section.settings.padding_top }}px;
    padding-bottom: {{ section.settings.padding_bottom }}px;
  }

  #LawnFigmaProduct-{{ section.id }} *,
  #LawnFigmaProduct-{{ section.id }} *::before,
  #LawnFigmaProduct-{{ section.id }} *::after {
    box-sizing: border-box;
  }

  #LawnFigmaProduct-{{ section.id }} .lawn-figma-product__inner {
    width: min(var(--lawn-max), calc(100vw - 32px));
    margin: 0 auto;
    display: grid;
    grid-template-columns: minmax(0, var(--lawn-left)) minmax(390px, var(--lawn-right));
    gap: {{ section.settings.column_gap }}px;
    align-items: start;
        justify-content: space-between;
  }

  #LawnFigmaProduct-{{ section.id }} .lawn-figma-gallery {
    display: grid;
    grid-template-columns: 76px 1fr;
    gap: 12px;
    align-items: start;
  }

  #LawnFigmaProduct-{{ section.id }} .lawn-figma-gallery__thumbs {
    display: grid;
    grid-template-columns: 1fr;
    gap: 11px;
  }

  #LawnFigmaProduct-{{ section.id }} .lawn-figma-thumb {
    display: block;
    width: 76px;
    height: 76px;
    padding: 0;
    border: 1px solid transparent;
    border-radius: 5px;
    background: #fff;
    overflow: hidden;
    cursor: pointer;
    transition: border-color .18s ease, transform .18s ease;
  }

  #LawnFigmaProduct-{{ section.id }} .lawn-figma-thumb:hover,
  #LawnFigmaProduct-{{ section.id }} .lawn-figma-thumb.is-active {
    border-color: var(--lawn-green);
  }

  #LawnFigmaProduct-{{ section.id }} .lawn-figma-thumb img {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: cover;
  }

  #LawnFigmaProduct-{{ section.id }} .lawn-figma-gallery__main {
    height: 433px;
    border: 1px solid var(--lawn-green);
    border-radius: 7px;
    background: #fff;
    overflow: hidden;
  }

  #LawnFigmaProduct-{{ section.id }} .lawn-figma-gallery__main img,
  #LawnFigmaProduct-{{ section.id }} .lawn-figma-gallery__main svg {
    width: 100%;
    height: 100%;
    display: block;
    object-fit: {{ section.settings.main_image_fit }};
  }

  #LawnFigmaProduct-{{ section.id }} .lawn-figma-dots {
    display: flex;
    justify-content: center;
    gap: 8px;
    margin-top: 26px;
    padding-left: 88px;
  }

  #LawnFigmaProduct-{{ section.id }} .lawn-figma-dots span {
    width: 9px;
    height: 9px;
    border-radius: 999px;
    background: #fae5df;
  }

  #LawnFigmaProduct-{{ section.id }} .lawn-figma-dots span.is-active {
    background: var(--lawn-orange);
  }

  #LawnFigmaProduct-{{ section.id }} .lawn-figma-trust {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    margin-top: 33px;
    padding-left: 0;
    gap: 0;
  }

  #LawnFigmaProduct-{{ section.id }} .lawn-figma-trust__item {
    position: relative;
    display: grid;
    justify-items: center;
    gap: 14px;
    min-width: 0;
    text-align: center;
  }

  #LawnFigmaProduct-{{ section.id }} .lawn-figma-trust__item:not(:last-child)::after {
    content: "";
    position: absolute;
    right: 0;
    top: 10px;
    width: 1px;
    height: 54px;
    background: #eef4ee;
  }

  #LawnFigmaProduct-{{ section.id }} .lawn-figma-trust__seal {
    width: 66px;
    height: 66px;
    border-radius: 50%;
    display: grid;
    place-items: center;
    background: var(--lawn-green);
    color: #fff;
    outline: 2px dashed var(--lawn-green);
    outline-offset: 4px;
    box-shadow: inset 0 0 0 2px rgba(255,255,255,.7);
  }

  #LawnFigmaProduct-{{ section.id }} .lawn-figma-trust__seal:not(.lawn-figma-trust__seal--custom) svg {
    width: 33px;
    height: 33px;
    fill: none;
    stroke: currentColor;
    stroke-width: 1.9;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  #LawnFigmaProduct-{{ section.id }} .lawn-figma-trust__seal--custom svg,
  #LawnFigmaProduct-{{ section.id }} .lawn-figma-trust__seal img {
    display: block;
    width: 38px;
    height: 38px;
    object-fit: contain;
  }

  #LawnFigmaProduct-{{ section.id }} .lawn-figma-trust__seal:not(.lawn-figma-trust__seal--custom) svg path:first-child,
  #LawnFigmaProduct-{{ section.id }} .lawn-figma-trust__seal:not(.lawn-figma-trust__seal--custom) svg rect:first-child {
    fill: none;
  }

  #LawnFigmaProduct-{{ section.id }} .lawn-figma-trust__item strong {
    font-size: 14px;
    line-height: 1.1;
    font-weight: 800;
    color: #171717;
  }

  #LawnFigmaProduct-{{ section.id }} .lawn-figma-product__info {
    min-width: 0;
  }

  #LawnFigmaProduct-{{ section.id }} .lawn-figma-rating {
    display: flex;
    align-items: center;
    gap: 11px;
    margin-top: -1px;
    margin-bottom: 19px;
    line-height: 1;
  }

  #LawnFigmaProduct-{{ section.id }} .lawn-figma-rating__stars {
    color: #ff9200;
    font-size: 18px;
    letter-spacing: 1px;
    white-space: nowrap;
  }

  #LawnFigmaProduct-{{ section.id }} .lawn-figma-rating__text {
    color: #0a9c5d;
    font-size: 14px;
    font-weight: 700;
  }

  #LawnFigmaProduct-{{ section.id }} .lawn-figma-title {
    margin: 0 0 17px;
    color: var(--lawn-dark);
    font-family: var(--font-heading-family, Poppins, Inter, Arial, sans-serif);
    font-size: 38px;
    line-height: 1.27;
    letter-spacing: -1.15px;
    font-weight: 900;
  }

  #LawnFigmaProduct-{{ section.id }} .lawn-figma-lead {
    margin: 0;
    padding-bottom: 15px;
    border-bottom: 1px solid var(--lawn-line);
    color: #454545;
    font-size: 17px;
    line-height: 1.34;
    font-weight: 600;
    letter-spacing: -.22px;
  }

  #LawnFigmaProduct-{{ section.id }} .lawn-figma-features {
    list-style: none;
    padding: 0 0 21px;
    margin: 17px 0 0;
    border-bottom: 1px solid var(--lawn-line);
    display: grid;
    gap: 15px;
  }

  #LawnFigmaProduct-{{ section.id }} .lawn-figma-features li {
    display: flex;
    align-items: center;
    gap: 8px;
    color: var(--lawn-dark);
  }

  #LawnFigmaProduct-{{ section.id }} .lawn-figma-features li > span {
    flex: 0 0 auto;
    width: 17px;
    height: 17px;
    border-radius: 50%;
    display: grid;
    place-items: center;
    background: var(--lawn-green);
    color: #fff;
    font-size: 12px;
    font-weight: 900;
    line-height: 1;
  }

  #LawnFigmaProduct-{{ section.id }} .lawn-figma-features strong {
    font-size: 17px;
    line-height: 1.2;
    font-weight: 800;
  }

  #LawnFigmaProduct-{{ section.id }} .lawn-figma-sku {
    margin: 12px 0 -6px;
    font-size: 12px;
    color: var(--lawn-muted);
  }

  #LawnFigmaProduct-{{ section.id }} .lawn-figma-price {
    margin-top: 26px;
    display: flex;
    align-items: flex-end;
    gap: 16px;
  }

  #LawnFigmaProduct-{{ section.id }} .lawn-figma-price__sale {
    color: var(--lawn-orange);
    font-size: 42px;
    line-height: .95;
    font-weight: 900;
    letter-spacing: -1px;
  }

  #LawnFigmaProduct-{{ section.id }} .lawn-figma-price__compare {
    color: #484848;
    font-size: 20px;
    line-height: 1.05;
    font-weight: 800;
    text-decoration: line-through;
    margin-bottom: 5px;
  }

  #LawnFigmaProduct-{{ section.id }} .lawn-figma-size {
    margin-top: 27px;
    padding-bottom: 20px;
    border-bottom: 1px solid var(--lawn-line);
  }

  #LawnFigmaProduct-{{ section.id }} .lawn-figma-size h2 {
    margin: 0 0 26px;
    color: var(--lawn-dark);
    font-family: var(--font-heading-family, Poppins, Inter, Arial, sans-serif);
    font-size: 18px;
    line-height: 1;
    font-weight: 900;
    letter-spacing: -.15px;
  }

  #LawnFigmaProduct-{{ section.id }} .lawn-figma-size__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 8px;
  }

  #LawnFigmaProduct-{{ section.id }} .lawn-figma-size-card {
    position: relative;
    min-height: 125px;
    width: 100%;
    padding: 15px 10px 13px;
    border: 1px solid #35b77a;
    border-radius: 7px;
    background: #fff;
    color: var(--lawn-dark);
    text-align: center;
    cursor: pointer;
    transition: border-color .16s ease, box-shadow .16s ease, transform .16s ease;
  }

  #LawnFigmaProduct-{{ section.id }} .lawn-figma-size-card.is-selected {
    border-color: var(--lawn-green);
    box-shadow: 0 0 0 1px var(--lawn-green), 0 8px 18px rgba(22, 164, 98, .10);
  }

  #LawnFigmaProduct-{{ section.id }} .lawn-figma-size-card:hover {
    transform: translateY(-1px);
    box-shadow: 0 10px 18px rgba(10, 62, 39, .08);
  }

  #LawnFigmaProduct-{{ section.id }} .lawn-figma-size-card.is-unavailable {
    opacity: .55;
  }

  #LawnFigmaProduct-{{ section.id }} .lawn-figma-size-card em {
    position: absolute;
    top: -12px;
    left: 50%;
    transform: translateX(-50%);
    min-width: 90px;
    height: 20px;
    padding: 0 12px;
    display: inline-grid;
    place-items: center;
    border-radius: 999px;
    background: var(--lawn-green);
    color: #fff;
    font-style: normal;
    font-size: 11px;
    line-height: 1;
    font-weight: 700;
    white-space: nowrap;
  }

  #LawnFigmaProduct-{{ section.id }} .lawn-figma-size-card strong {
    display: block;
    font-size: 19px;
    line-height: 1.1;
    font-weight: 900;
    letter-spacing: -.25px;
  }

  #LawnFigmaProduct-{{ section.id }} .lawn-figma-size-card > span {
    display: block;
    margin-top: 5px;
    color: #777;
    font-size: 12px;
    line-height: 1.2;
    font-weight: 500;
  }

  #LawnFigmaProduct-{{ section.id }} .lawn-figma-size-card b {
    display: block;
    margin-top: 27px;
    color: var(--lawn-dark);
    font-size: 23px;
    line-height: 1;
    font-weight: 900;
  }

  #LawnFigmaProduct-{{ section.id }} .lawn-figma-form {
    margin-top: 16px;
  }

  #LawnFigmaProduct-{{ section.id }} .lawn-figma-buy {
    display: grid;
    grid-template-columns: auto auto 1fr;
    align-items: end;
    column-gap: 19px;
    row-gap: 11px;
  }

  #LawnFigmaProduct-{{ section.id }} .lawn-figma-buy label {
    grid-column: 1 / -1;
    color: #151515;
    font-size: 14px;
    line-height: 1;
    font-weight: 800;
  }

  #LawnFigmaProduct-{{ section.id }} .lawn-figma-qty {
    width: 146px;
    height: 47px;
    display: grid;
    grid-template-columns: 42px 1fr 42px;
    align-items: center;
    border: 1px solid #ff6947;
    border-radius: 999px;
    overflow: hidden;
    color: #151515;
    font-size: 19px;
    font-weight: 700;
  }

  #LawnFigmaProduct-{{ section.id }} .lawn-figma-qty button {
    width: 100%;
    height: 100%;
    border: 0;
    background: transparent;
    color: #1a1a1a;
    font-size: 18px;
    line-height: 1;
    cursor: pointer;
  }

  #LawnFigmaProduct-{{ section.id }} .lawn-figma-qty span {
    text-align: center;
  }

  #LawnFigmaProduct-{{ section.id }} .lawn-figma-selling {
    align-self: center;
    color: var(--lawn-orange);
    font-size: 16px;
    line-height: 1;
    font-weight: 500;
  }

  #LawnFigmaProduct-{{ section.id }} .lawn-figma-program {
    margin: 20px 0 21px;
    color: #111;
    font-size: 14px;
    line-height: 1.2;
    font-weight: 700;
  }

  #LawnFigmaProduct-{{ section.id }} .lawn-figma-program a {
    color: var(--lawn-orange);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  #LawnFigmaProduct-{{ section.id }} .lawn-figma-cart {
    width: 100%;
    height: 60px;
    border: 0;
    border-radius: 999px;
    background: var(--lawn-orange);
    color: #fff;
    font-family: var(--font-heading-family, Poppins, Inter, Arial, sans-serif);
    font-size: 25px;
    line-height: 1;
    font-weight: 900;
    letter-spacing: -.25px;
    cursor: pointer;
    transition: opacity .16s ease, transform .16s ease;
  }

  #LawnFigmaProduct-{{ section.id }} .lawn-figma-cart:hover {
    transform: translateY(-1px);
  }

  #LawnFigmaProduct-{{ section.id }} .lawn-figma-cart:disabled {
    opacity: .55;
    cursor: not-allowed;
    transform: none;
  }

  #LawnFigmaProduct-{{ section.id }} .lawn-figma-shipping {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 18px;
    margin-top: 14px;
    color: var(--lawn-dark);
    font-size: 12px;
    line-height: 1;
    font-weight: 500;
  }

  #LawnFigmaProduct-{{ section.id }} .lawn-figma-shipping span {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    white-space: nowrap;
  }

  #LawnFigmaProduct-{{ section.id }} .lawn-figma-shipping svg {
    width: 16px;
    height: 16px;
    fill: none;
    stroke: var(--lawn-green);
    stroke-width: 2;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  #LawnFigmaProduct-{{ section.id }} .lawn-figma-payments {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 10px;
    margin-top: 13px;
    padding-bottom: 19px;
    border-bottom: 1px solid var(--lawn-line);
  }

  #LawnFigmaProduct-{{ section.id }} .lawn-figma-payments > span {
    min-width: 34px;
    height: 20px;
    display: inline-grid;
    place-items: center;
    border-radius: 3px;
    background: #fff;
    box-shadow: 0 0 0 1px #edf0ee;
    color: #0e326b;
    font-size: 8px;
    line-height: 1;
    font-weight: 900;
  }

  #LawnFigmaProduct-{{ section.id }} .lawn-figma-payment-svg {
    box-shadow: none !important;
    background: transparent !important;
  }

  #LawnFigmaProduct-{{ section.id }} .lawn-figma-payment-svg svg {
    width: 34px;
    height: 22px;
    display: block;
  }

  #LawnFigmaProduct-{{ section.id }} .lawn-figma-accordions {
    border-bottom: 1px solid var(--lawn-line);
  }

  #LawnFigmaProduct-{{ section.id }} .lawn-figma-accordion {
    border-top: 1px solid var(--lawn-line);
  }

  #LawnFigmaProduct-{{ section.id }} .lawn-figma-accordion summary {
    min-height: 60px;
    display: grid;
    grid-template-columns: 22px 1fr 18px;
    gap: 0;
    align-items: center;
    color: var(--lawn-dark);
    list-style: none;
    cursor: pointer;
  }

  #LawnFigmaProduct-{{ section.id }} .lawn-figma-accordion summary::-webkit-details-marker {
    display: none;
  }

  #LawnFigmaProduct-{{ section.id }} .lawn-figma-accordion__icon svg {
    width: 18px;
    height: 18px;
    display: block;
    fill: none;
    stroke: var(--lawn-green);
    stroke-width: 2;
    stroke-linecap: round;
    stroke-linejoin: round;
  }

  #LawnFigmaProduct-{{ section.id }} .lawn-figma-accordion__title {
    font-size: 17px;
    line-height: 1.1;
    font-weight: 900;
  }

  #LawnFigmaProduct-{{ section.id }} .lawn-figma-accordion__chev {
    justify-self: end;
    width: 9px;
    height: 9px;
    border-right: 1.8px solid var(--lawn-dark);
    border-bottom: 1.8px solid var(--lawn-dark);
    transform: rotate(-45deg);
    transition: transform .18s ease;
  }

  #LawnFigmaProduct-{{ section.id }} .lawn-figma-accordion[open] .lawn-figma-accordion__chev {
    transform: rotate(45deg);
  }

  #LawnFigmaProduct-{{ section.id }} .lawn-figma-accordion__content {
    padding: 0 18px 20px 22px;
    color: #3e3e3e;
    font-size: 14px;
    line-height: 1.55;
  }

  #LawnFigmaProduct-{{ section.id }} .lawn-figma-accordion__content:empty {
    display: none;
  }

  #LawnFigmaProduct-{{ section.id }} .rte > *:first-child {
    margin-top: 0;
  }

  #LawnFigmaProduct-{{ section.id }} .rte > *:last-child {
    margin-bottom: 0;
  }

  @media (max-width: 989px) {
    #LawnFigmaProduct-{{ section.id }} {
      padding-top: 22px;
      padding-bottom: 38px;
    }

    #LawnFigmaProduct-{{ section.id }} .lawn-figma-product__inner {
      grid-template-columns: 1fr;
      gap: 30px;
      width: min(680px, calc(100vw - 28px));
    }

    #LawnFigmaProduct-{{ section.id }} .lawn-figma-gallery {
      grid-template-columns: 72px 1fr;
    }

    #LawnFigmaProduct-{{ section.id }} .lawn-figma-gallery__main {
      height: auto;
      aspect-ratio: 1 / 1;
    }

    #LawnFigmaProduct-{{ section.id }} .lawn-figma-dots {
      padding-left: 84px;
    }

    #LawnFigmaProduct-{{ section.id }} .lawn-figma-title {
      font-size: clamp(32px, 7vw, 38px);
    }
  }

  @media (max-width: 560px) {
    #LawnFigmaProduct-{{ section.id }} .lawn-figma-gallery {
      display: flex;
      flex-direction: column-reverse;
    }

    #LawnFigmaProduct-{{ section.id }} .lawn-figma-gallery__thumbs {
      display: flex;
      gap: 9px;
      overflow-x: auto;
      padding-bottom: 2px;
    }

    #LawnFigmaProduct-{{ section.id }} .lawn-figma-thumb {
      width: 68px;
      height: 68px;
      flex: 0 0 68px;
    }

    #LawnFigmaProduct-{{ section.id }} .lawn-figma-dots {
      padding-left: 0;
      margin-top: 18px;
    }

    #LawnFigmaProduct-{{ section.id }} .lawn-figma-trust {
      grid-template-columns: repeat(2, 1fr);
      gap: 24px 0;
    }

    #LawnFigmaProduct-{{ section.id }} .lawn-figma-trust__item:nth-child(2)::after {
      display: none;
    }

    #LawnFigmaProduct-{{ section.id }} .lawn-figma-size__grid {
      grid-template-columns: 1fr;
      gap: 14px;
    }

    #LawnFigmaProduct-{{ section.id }} .lawn-figma-size-card {
      min-height: 112px;
    }

    #LawnFigmaProduct-{{ section.id }} .lawn-figma-buy {
      grid-template-columns: auto 1fr;
    }

    #LawnFigmaProduct-{{ section.id }} .lawn-figma-selling {
      justify-self: start;
    }

    #LawnFigmaProduct-{{ section.id }} .lawn-figma-shipping {
      flex-wrap: wrap;
      gap: 10px 14px;
    }

    #LawnFigmaProduct-{{ section.id }} .lawn-figma-payments {
      flex-wrap: wrap;
    }
  }
{% endstyle %}

<script>
  (function () {
    function initLawnFigmaProduct(sectionId) {
      var root = document.getElementById('LawnFigmaProduct-' + sectionId);
      if (!root || root.dataset.lawnReady === 'true') return;
      root.dataset.lawnReady = 'true';

      var mainImage = root.querySelector('[data-main-image-target]');
      var thumbs = root.querySelectorAll('[data-gallery-thumb]');

      thumbs.forEach(function (thumb) {
        thumb.addEventListener('click', function () {
          if (!mainImage) return;
          var src = thumb.getAttribute('data-main-image');
          var alt = thumb.getAttribute('data-main-alt') || '';
          if (src) {
            mainImage.removeAttribute('srcset');
            mainImage.src = src;
            mainImage.alt = alt;
          }
          thumbs.forEach(function (item) {
            item.classList.remove('is-active');
          });
          thumb.classList.add('is-active');
        });
      });

      var qtyInput = root.querySelector('[data-quantity-input]');
      var qtyValue = root.querySelector('[data-qty-value]');
      var minus = root.querySelector('[data-qty-minus]');
      var plus = root.querySelector('[data-qty-plus]');

      function setQty(value) {
        var next = parseInt(value, 10);
        if (isNaN(next) || next < 1) next = 1;
        if (qtyInput) qtyInput.value = next;
        if (qtyValue) qtyValue.textContent = next;
      }

      if (minus) {
        minus.addEventListener('click', function () {
          var current = qtyInput ? qtyInput.value : qtyValue ? qtyValue.textContent : 1;
          setQty(parseInt(current, 10) - 1);
        });
      }

      if (plus) {
        plus.addEventListener('click', function () {
          var current = qtyInput ? qtyInput.value : qtyValue ? qtyValue.textContent : 1;
          setQty(parseInt(current, 10) + 1);
        });
      }

      var cards = root.querySelectorAll('[data-variant-card]');
      var variantInput = root.querySelector('[data-variant-input]');
      var price = root.querySelector('[data-product-price]');
      var compare = root.querySelector('[data-product-compare-price]');
      var sku = root.querySelector('[data-sku]');
      var addButton = root.querySelector('[data-add-to-cart]');

      cards.forEach(function (card) {
        card.addEventListener('click', function () {
          cards.forEach(function (item) {
            item.classList.remove('is-selected');
            item.setAttribute('aria-checked', 'false');
          });

          card.classList.add('is-selected');
          card.setAttribute('aria-checked', 'true');

          var variantId = card.getAttribute('data-variant-id');
          var variantPrice = card.getAttribute('data-variant-price');
          var variantCompare = card.getAttribute('data-variant-compare');
          var available = card.getAttribute('data-variant-available') === 'true';
          var variantSku = card.getAttribute('data-variant-sku');
          var variantImage = card.getAttribute('data-variant-image');
          var variantAlt = card.getAttribute('data-variant-alt') || '';

          if (variantInput && variantId) variantInput.value = variantId;
          if (price && variantPrice) price.textContent = variantPrice;

          if (compare) {
            if (variantCompare) {
              compare.textContent = variantCompare;
              compare.hidden = false;
            } else {
              compare.textContent = '';
              compare.hidden = true;
            }
          }

          if (sku) {
            sku.textContent = variantSku ? 'SKU: ' + variantSku : '';
            sku.hidden = !variantSku;
          }

          if (mainImage && variantImage) {
            mainImage.removeAttribute('srcset');
            mainImage.src = variantImage;
            mainImage.alt = variantAlt;
            thumbs.forEach(function (item) {
              item.classList.remove('is-active');
            });
          }

          if (addButton) {
            addButton.disabled = !available;
            addButton.textContent = available
              ? addButton.getAttribute('data-add-label')
              : addButton.getAttribute('data-sold-out-label');
          }
        });
      });

      var staticCards = root.querySelectorAll('[data-static-size-card]');
      staticCards.forEach(function (card) {
        card.addEventListener('click', function () {
          staticCards.forEach(function (item) {
            item.classList.remove('is-selected');
            item.setAttribute('aria-checked', 'false');
          });
          card.classList.add('is-selected');
          card.setAttribute('aria-checked', 'true');
        });
      });
    }

    initLawnFigmaProduct('{{ section.id }}');

    document.addEventListener('shopify:section:load', function (event) {
      if (event.detail && event.detail.sectionId === '{{ section.id }}') {
        initLawnFigmaProduct('{{ section.id }}');
      }
    });
  })();
</script>

