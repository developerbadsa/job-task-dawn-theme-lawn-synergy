{%- liquid
  assign bag = section.settings.bag_image
  assign grass_bg = section.settings.grass_bg_image
  assign grass_edge_img = section.settings.grass_edge_image
-%}

<section class="dark-feature">
  {%- if grass_bg != blank -%}
    <img class="grass-bg" src="{{ grass_bg | image_url: width: 2000 }}" alt="" width="2000" height="1333" loading="lazy" aria-hidden="true">
  {%- else -%}
    <img class="grass-bg" src="{{ 'grass-bg.jpg' | asset_url }}" alt="" width="2000" height="1333" loading="lazy" aria-hidden="true"
         onerror="this.style.display='none'">
  {%- endif -%}

  <div class="container dark-grid">
    <div class="bag-photo">
      {%- if bag != blank -%}
        {{ bag | image_url: width: 1200 | image_tag:
          loading: 'lazy',
          alt: section.settings.bag_alt | default: 'Envy Tall Fescue bag',
          width: 1200,
          height: 1500
        }}
      {%- else -%}
        <img src="{{ 'upgrade-bag.png' | asset_url }}"
             alt="{{ section.settings.bag_alt | default: 'Envy Tall Fescue bag in grass' }}"
             width="1200" height="1500">
      {%- endif -%}
    </div>

    <div class="dark-copy">
      {%- if section.settings.eyebrow != blank -%}
        <p class="eyebrow">{{ section.settings.eyebrow }}</p>
      {%- endif -%}
      <h2>{{ section.settings.heading | default: 'The Best Lawn Starts With The Right Seed' }}</h2>
      {%- if section.settings.body != blank -%}
        <p>{{ section.settings.body }}</p>
      {%- endif -%}
      {%- if section.settings.list_heading != blank -%}
        <h3>{{ section.settings.list_heading }}</h3>
      {%- endif -%}

      <ul class="feature-list light">
        {%- for block in section.blocks -%}
          {%- if block.type == 'feature' -%}
            <li {{ block.shopify_attributes }}>{{ block.settings.text }}</li>
          {%- endif -%}
        {%- endfor -%}
      </ul>

      {%- if section.settings.cta_label != blank -%}
        <a class="add-cart compact" href="{{ section.settings.cta_link | default: '#' }}" style="display: grid; place-items: center; text-decoration: none;">
          {{ section.settings.cta_label }}
        </a>
      {%- endif -%}
    </div>
  </div>

  {%- if section.settings.show_grass_edge -%}
    {%- if grass_edge_img != blank -%}
      <img class="grass-edge" src="{{ grass_edge_img | image_url: width: 2000 }}" alt="" width="2000" height="220" loading="lazy" aria-hidden="true">
    {%- else -%}
      <img class="grass-edge" src="{{ 'grass-strip.png' | asset_url }}" alt="" width="1440" height="160" loading="lazy" aria-hidden="true">
    {%- endif -%}
  {%- endif -%}
</section>

{% schema %}
{
  "name": "Lawn — Premium Upgrade",
  "tag": "section",
  "class": "lawn-dark-feature-section",
  "settings": [
    {
      "type": "image_picker",
      "id": "bag_image",
      "label": "Left bag image"
    },
    {
      "type": "image_picker",
      "id": "grass_bg_image",
      "label": "Background grass texture (low opacity overlay)",
      "info": "Falls back to assets/grass-bg.jpg when empty."
    },
    {
      "type": "image_picker",
      "id": "grass_edge_image",
      "label": "Bottom grass edge image",
      "info": "Falls back to assets/grass-strip.png when empty."
    },
    {
      "type": "text",
      "id": "bag_alt",
      "label": "Bag image alt text",
      "default": "Envy Tall Fescue bag in grass"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Premium Upgrade"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "The Best Lawn Starts With The Right Seed"
    },
    {
      "type": "textarea",
      "id": "body",
      "label": "Body",
      "default": "If You Want A Lawn That Actually Stands Out - Thicker, Darker, And More Uniform It All Starts With The Seed You Choose. Envy Premium Tall Fescue Is Our Highest-End Blend, Built For Homeowners Who Are Tired Of Thin, Patchy Grass And Want A Lawn That Looks Better, Fills In Thicker, And Performs Consistently Year After Year."
    },
    {
      "type": "text",
      "id": "list_heading",
      "label": "List heading",
      "default": "This Is The Right Seed For You If:"
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "CTA label",
      "default": "Add To Cart"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "CTA link"
    },
    {
      "type": "checkbox",
      "id": "show_grass_edge",
      "label": "Show bottom grass edge",
      "default": true
    }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "Feature point",
      "settings": [
        { "type": "text", "id": "text", "label": "Text", "default": "Feature item" }
      ]
    }
  ],
  "presets": [
    {
      "name": "Lawn — Premium Upgrade",
      "blocks": [
        { "type": "feature", "settings": { "text": "You Want A Darker Green, More Attractive Lawn" } },
        { "type": "feature", "settings": { "text": "Your Lawn Feels Thin Or Uneven" } },
        { "type": "feature", "settings": { "text": "You Want Better Density And A More Uniform Finish" } },
        { "type": "feature", "settings": { "text": "You Want Better Than Basic Seed" } }
      ]
    }
  ]
}
{% endschema %}
