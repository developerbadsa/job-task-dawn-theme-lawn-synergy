{%- liquid
  assign bag = section.settings.bag_image
  assign grass_bg = section.settings.grass_bg_image
  assign grass_edge_img = section.settings.grass_edge_image
  assign product_form_id = 'premium-upgrade-form-' | append: section.id

  if section.settings.product != blank
    assign selected_product = section.settings.product
  else
    assign selected_product = product
  endif

  if selected_product != blank
    assign selected_variant = selected_product.selected_or_first_available_variant
  endif
-%}

<section
  id="premium-upgrade-{{ section.id }}"
  class="premium-upgrade"
  style="
    --section-bg: {{ section.settings.background_color }};
    --content-width: {{ section.settings.content_width }}px;
    --section-min-height: {{ section.settings.section_min_height }}px;
    --section-padding-top: {{ section.settings.padding_top }}px;
    --section-padding-x: {{ section.settings.padding_horizontal }}px;
    --media-width: {{ section.settings.media_width }}px;
    --media-height: {{ section.settings.media_height }}px;
    --media-radius: {{ section.settings.media_radius }}px;
    --grid-gap: {{ section.settings.grid_gap }}px;
    --copy-top-offset: {{ section.settings.copy_top_offset }}px;
    --texture-opacity: {{ section.settings.texture_opacity | divided_by: 100.0 }};
    --texture-overlay-opacity: {{ section.settings.texture_overlay_opacity | divided_by: 100.0 }};
    --edge-height: {{ section.settings.grass_edge_height }}px;
    --edge-bottom: {{ section.settings.grass_edge_bottom }}px;
    --edge-opacity: {{ section.settings.grass_edge_opacity | divided_by: 100.0 }};
    --eyebrow-color: {{ section.settings.eyebrow_color }};
    --heading-color: {{ section.settings.heading_color }};
    --text-color: {{ section.settings.text_color }};
    --check-bg: {{ section.settings.check_color }};
    --button-bg: {{ section.settings.button_background }};
    --button-color: {{ section.settings.button_text_color }};
  "
>
  <div class="premium-upgrade__bg" aria-hidden="true">
    {%- if grass_bg != blank -%}
      {{
        grass_bg
        | image_url: width: 2400
        | image_tag:
          class: 'premium-upgrade__texture',
          loading: 'lazy',
          alt: '',
          width: 2400,
          height: 1400
      }}
    {%- endif -%}
  </div>

  <div class="premium-upgrade__inner">
    <div class="premium-upgrade__media">
      {%- if bag != blank -%}
        {{
          bag
          | image_url: width: 1400
          | image_tag:
            class: 'premium-upgrade__image',
            loading: 'lazy',
            alt: section.settings.bag_alt,
            width: 1400,
            height: 1800
        }}
      {%- endif -%}
    </div>

    <div class="premium-upgrade__copy">
      {%- if section.settings.eyebrow != blank -%}
        <p class="premium-upgrade__eyebrow">{{ section.settings.eyebrow }}</p>
      {%- endif -%}

      {%- if section.settings.heading != blank -%}
        <h2 class="premium-upgrade__heading">{{ section.settings.heading }}</h2>
      {%- endif -%}

      {%- if section.settings.body != blank -%}
        <div class="premium-upgrade__body">
          {{ section.settings.body | newline_to_br }}
        </div>
      {%- endif -%}

      {%- if section.settings.list_heading != blank -%}
        <h3 class="premium-upgrade__list-title">{{ section.settings.list_heading }}</h3>
      {%- endif -%}

      {%- if section.blocks.size > 0 -%}
        <ul class="premium-upgrade__list" role="list">
          {%- for block in section.blocks -%}
            {%- if block.type == 'feature' and block.settings.text != blank -%}
              <li class="premium-upgrade__item" {{ block.shopify_attributes }}>
                <span class="premium-upgrade__check" aria-hidden="true">
                  <svg viewBox="0 0 12 12" focusable="false">
                    <path d="M4.8 8.5 2.3 6l.9-.9 1.6 1.6 4-4 .9.9-4.9 4.9Z" />
                  </svg>
                </span>
                <span>{{ block.settings.text }}</span>
              </li>
            {%- endif -%}
          {%- endfor -%}
        </ul>
      {%- endif -%}

      {%- if section.settings.cta_label != blank -%}
        {%- if section.settings.button_action == 'add_to_cart' and selected_product != blank and selected_variant != blank -%}
          {%- form 'product', selected_product, id: product_form_id, class: 'premium-upgrade__form' -%}
            <input type="hidden" name="id" value="{{ selected_variant.id }}">
            <button
              type="submit"
              class="premium-upgrade__button"
              {% unless selected_variant.available %}disabled{% endunless %}
            >
              {%- if selected_variant.available -%}
                {{ section.settings.cta_label }}
              {%- else -%}
                {{ section.settings.sold_out_label }}
              {%- endif -%}
            </button>
          {%- endform -%}
        {%- else -%}
          <a class="premium-upgrade__button" href="{{ section.settings.cta_link | default: '#' }}">
            {{ section.settings.cta_label }}
          </a>
        {%- endif -%}
      {%- endif -%}
    </div>
  </div>

  {%- if section.settings.show_grass_edge and grass_edge_img != blank -%}
    {{
      grass_edge_img
      | image_url: width: 2400
      | image_tag:
        class: 'premium-upgrade__edge',
        loading: 'lazy',
        alt: '',
        width: 2400,
        height: 360
    }}
  {%- endif -%}
</section>

<style>
  #premium-upgrade-{{ section.id }} {
    position: relative;
    isolation: isolate;
    overflow: hidden;
    width: 100%;
    min-height: var(--section-min-height);
    padding: var(--section-padding-top) var(--section-padding-x) 0;
    background: var(--section-bg);
    font-family: inherit;
  }

  #premium-upgrade-{{ section.id }} .premium-upgrade__bg {
    position: absolute;
    inset: 0;
    z-index: -3;
    background: var(--section-bg);
    pointer-events: none;
  }

  #premium-upgrade-{{ section.id }} .premium-upgrade__texture {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: var(--texture-opacity);
    mix-blend-mode: soft-light;
    filter: saturate(0.85) contrast(1.08);
  }

  #premium-upgrade-{{ section.id }} .premium-upgrade__bg::after {
    content: "";
    position: absolute;
    inset: 0;
    background:
      radial-gradient(circle at 18% 12%, rgba(255, 255, 255, 0.08), transparent 29%),
      linear-gradient(90deg, rgba(0, 54, 31, 0.78) 0%, rgba(0, 52, 31, 0.94) 58%, rgba(0, 54, 31, 0.86) 100%);
    opacity: var(--texture-overlay-opacity);
  }

  #premium-upgrade-{{ section.id }} .premium-upgrade__inner {
    position: relative;
    z-index: 3;
    width: 100%;
    max-width: var(--content-width);
    margin: 0 auto;
    display: grid;
    grid-template-columns: var(--media-width) minmax(0, 1fr);
    column-gap: var(--grid-gap);
    align-items: start;
  }

  #premium-upgrade-{{ section.id }} .premium-upgrade__media {
    width: var(--media-width);
    height: var(--media-height);
    overflow: hidden;
    border-radius: var(--media-radius);
    box-shadow: none;
  }

  #premium-upgrade-{{ section.id }} .premium-upgrade__image {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  #premium-upgrade-{{ section.id }} .premium-upgrade__copy {
    position: relative;
    z-index: 6;
    max-width: 596px;
    padding-top: var(--copy-top-offset);
    color: var(--text-color);
  }

  #premium-upgrade-{{ section.id }} .premium-upgrade__eyebrow {
    margin: 0 0 12px;
    color: var(--eyebrow-color);
    font-size: 16px;
    line-height: 1.2;
    font-weight: 500;
    letter-spacing: -0.02em;
  }

  #premium-upgrade-{{ section.id }} .premium-upgrade__heading {
    max-width: 560px;
    margin: 0;
    color: var(--heading-color);
    font-size: 44px;
    line-height: 1.16;
    font-weight: 800;
    letter-spacing: -0.045em;
  }

  #premium-upgrade-{{ section.id }} .premium-upgrade__body {
    max-width: 560px;
    margin-top: 16px;
    color: var(--text-color);
    font-size: 16px;
    line-height: 1.52;
    font-weight: 500;
    letter-spacing: -0.016em;
  }

  #premium-upgrade-{{ section.id }} .premium-upgrade__list-title {
    margin: 27px 0 16px;
    color: var(--heading-color);
    font-size: 18px;
    line-height: 1.25;
    font-weight: 800;
    letter-spacing: -0.025em;
  }

  #premium-upgrade-{{ section.id }} .premium-upgrade__list {
    display: grid;
    gap: 13px;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  #premium-upgrade-{{ section.id }} .premium-upgrade__item {
    display: flex;
    align-items: flex-start;
    gap: 10px;
    color: var(--text-color);
    font-size: 16px;
    line-height: 1.18;
    font-weight: 600;
    letter-spacing: -0.018em;
  }

  #premium-upgrade-{{ section.id }} .premium-upgrade__check {
    flex: 0 0 17px;
    width: 17px;
    height: 17px;
    margin-top: 1px;
    display: inline-grid;
    place-items: center;
    border-radius: 50%;
    background: var(--check-bg);
  }

  #premium-upgrade-{{ section.id }} .premium-upgrade__check svg {
    width: 12px;
    height: 12px;
    fill: #ffffff;
  }

  #premium-upgrade-{{ section.id }} .premium-upgrade__form {
    margin: 0;
  }

  #premium-upgrade-{{ section.id }} .premium-upgrade__button {
    width: 254px;
    min-height: 64px;
    margin-top: 33px;
    display: inline-grid;
    place-items: center;
    border: 0;
    border-radius: 999px;
    background: var(--button-bg);
    color: var(--button-color);
    text-decoration: none;
    font-size: 24px;
    line-height: 1;
    font-weight: 800;
    letter-spacing: -0.03em;
    cursor: pointer;
    box-shadow: none;
    transition: transform 160ms ease, opacity 160ms ease;
  }

  #premium-upgrade-{{ section.id }} .premium-upgrade__button:hover {
    transform: translateY(-1px);
    opacity: 0.96;
  }

  #premium-upgrade-{{ section.id }} .premium-upgrade__button:disabled {
    cursor: not-allowed;
    opacity: 0.55;
    transform: none;
  }

  #premium-upgrade-{{ section.id }} .premium-upgrade__edge {
    position: absolute;
    left: 0;
    right: 0;
    bottom: var(--edge-bottom);
    z-index: 8;
    width: 100%;
    height: var(--edge-height);
    object-fit: cover;
    object-position: center bottom;
    opacity: var(--edge-opacity);
    pointer-events: none;
  }

  @media screen and (max-width: 1320px) {
    #premium-upgrade-{{ section.id }} {
      --section-padding-x: 40px;
    }

    #premium-upgrade-{{ section.id }} .premium-upgrade__inner {
      grid-template-columns: minmax(420px, var(--media-width)) minmax(0, 1fr);
    }
  }

  @media screen and (max-width: 989px) {
    #premium-upgrade-{{ section.id }} {
      min-height: auto;
      padding: 54px 20px 128px;
    }

    #premium-upgrade-{{ section.id }} .premium-upgrade__inner {
      max-width: 620px;
      grid-template-columns: 1fr;
      gap: 34px;
    }

    #premium-upgrade-{{ section.id }} .premium-upgrade__media {
      width: 100%;
      height: auto;
      aspect-ratio: 630 / 824;
    }

    #premium-upgrade-{{ section.id }} .premium-upgrade__copy {
      max-width: none;
      padding-top: 0;
    }

    #premium-upgrade-{{ section.id }} .premium-upgrade__heading {
      max-width: none;
      font-size: 36px;
    }

    #premium-upgrade-{{ section.id }} .premium-upgrade__body {
      max-width: none;
    }

    #premium-upgrade-{{ section.id }} .premium-upgrade__edge {
      height: 120px;
      min-width: 900px;
      left: 50%;
      right: auto;
      transform: translateX(-50%);
    }
  }

  @media screen and (max-width: 575px) {
    #premium-upgrade-{{ section.id }} {
      padding: 42px 16px 108px;
    }

    #premium-upgrade-{{ section.id }} .premium-upgrade__heading {
      font-size: 31px;
      line-height: 1.14;
    }

    #premium-upgrade-{{ section.id }} .premium-upgrade__body {
      font-size: 14px;
    }

    #premium-upgrade-{{ section.id }} .premium-upgrade__item {
      font-size: 14px;
    }

    #premium-upgrade-{{ section.id }} .premium-upgrade__button {
      width: 220px;
      min-height: 56px;
      font-size: 21px;
    }

    #premium-upgrade-{{ section.id }} .premium-upgrade__edge {
      height: 96px;
      min-width: 720px;
    }
  }
</style>

{% schema %}
{
  "name": "Lawn — Premium Upgrade",
  "tag": "section",
  "class": "lawn-premium-upgrade-section",
  "settings": [
    {
      "type": "header",
      "content": "Images"
    },
    {
      "type": "image_picker",
      "id": "bag_image",
      "label": "Left image"
    },
    {
      "type": "image_picker",
      "id": "grass_bg_image",
      "label": "Background texture image"
    },
    {
      "type": "image_picker",
      "id": "grass_edge_image",
      "label": "Bottom grass image"
    },
    {
      "type": "text",
      "id": "bag_alt",
      "label": "Image alt text",
      "default": "Envy Tall Fescue bag in grass"
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Premium Upgrade"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "The Best Lawn Starts With The Right Seed"
    },
    {
      "type": "textarea",
      "id": "body",
      "label": "Body",
      "default": "If You Want A Lawn That Actually Stands Out — Thicker, Darker, And More Uniform It All Starts With The Seed You Choose.\nEnvy Premium Tall Fescue Is Our Highest-End Blend, Built For Homeowners Who Are Tired Of Thin, Patchy Grass And Want A Lawn That Looks Better, Fills In Thicker, And Performs Consistently Year After Year."
    },
    {
      "type": "text",
      "id": "list_heading",
      "label": "List heading",
      "default": "This Is The Right Seed For You If:"
    },
    {
      "type": "header",
      "content": "Button"
    },
    {
      "type": "select",
      "id": "button_action",
      "label": "Button action",
      "options": [
        {
          "value": "link",
          "label": "Open link"
        },
        {
          "value": "add_to_cart",
          "label": "Add selected product to cart"
        }
      ],
      "default": "add_to_cart"
    },
    {
      "type": "product",
      "id": "product",
      "label": "Product for add to cart"
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "Button label",
      "default": "Add To Cart"
    },
    {
      "type": "text",
      "id": "sold_out_label",
      "label": "Sold out label",
      "default": "Sold Out"
    },
    {
      "type": "url",
      "id": "cta_link",
      "label": "Button link"
    },
    {
      "type": "header",
      "content": "Desktop layout"
    },
    {
      "type": "range",
      "id": "content_width",
      "label": "Content width",
      "min": 1000,
      "max": 1400,
      "step": 4,
      "unit": "px",
      "default": 1272
    },
    {
      "type": "range",
      "id": "section_min_height",
      "label": "Minimum height",
      "min": 620,
      "max": 980,
      "step": 4,
      "unit": "px",
      "default": 824
    },
    {
      "type": "range",
      "id": "padding_top",
      "label": "Top spacing",
      "min": 40,
      "max": 160,
      "step": 4,
      "unit": "px",
      "default": 108
    },
    {
      "type": "range",
      "id": "padding_horizontal",
      "label": "Side spacing",
      "min": 0,
      "max": 80,
      "step": 2,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "grid_gap",
      "label": "Column gap",
      "min": 20,
      "max": 80,
      "step": 2,
      "unit": "px",
      "default": 52
    },
    {
      "type": "range",
      "id": "copy_top_offset",
      "label": "Text top offset",
      "min": 0,
      "max": 120,
      "step": 2,
      "unit": "px",
      "default": 80
    },
    {
      "type": "range",
      "id": "media_width",
      "label": "Left image width",
      "min": 500,
      "max": 700,
      "step": 2,
      "unit": "px",
      "default": 630
    },
    {
      "type": "range",
      "id": "media_height",
      "label": "Left image height",
      "min": 720,
      "max": 920,
      "step": 2,
      "unit": "px",
      "default": 824
    },
    {
      "type": "range",
      "id": "media_radius",
      "label": "Image corner radius",
      "min": 0,
      "max": 32,
      "step": 1,
      "unit": "px",
      "default": 20
    },
    {
      "type": "header",
      "content": "Bottom grass"
    },
    {
      "type": "checkbox",
      "id": "show_grass_edge",
      "label": "Show bottom grass",
      "default": true
    },
    {
      "type": "range",
      "id": "grass_edge_height",
      "label": "Bottom grass height",
      "min": 80,
      "max": 220,
      "step": 2,
      "unit": "px",
      "default": 154
    },
    {
      "type": "range",
      "id": "grass_edge_bottom",
      "label": "Bottom grass position",
      "min": -30,
      "max": 30,
      "step": 1,
      "unit": "px",
      "default": 0
    },
    {
      "type": "range",
      "id": "grass_edge_opacity",
      "label": "Bottom grass opacity",
      "min": 40,
      "max": 100,
      "step": 1,
      "unit": "%",
      "default": 100
    },
    {
      "type": "header",
      "content": "Background"
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Background color",
      "default": "#00452A"
    },
    {
      "type": "range",
      "id": "texture_opacity",
      "label": "Texture opacity",
      "min": 0,
      "max": 50,
      "step": 1,
      "unit": "%",
      "default": 18
    },
    {
      "type": "range",
      "id": "texture_overlay_opacity",
      "label": "Dark overlay strength",
      "min": 20,
      "max": 100,
      "step": 1,
      "unit": "%",
      "default": 82
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "eyebrow_color",
      "label": "Eyebrow color",
      "default": "#20C875"
    },
    {
      "type": "color",
      "id": "heading_color",
      "label": "Heading color",
      "default": "#FFFFFF"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#FFFFFF"
    },
    {
      "type": "color",
      "id": "check_color",
      "label": "Check icon color",
      "default": "#22B974"
    },
    {
      "type": "color",
      "id": "button_background",
      "label": "Button background",
      "default": "#FC5810"
    },
    {
      "type": "color",
      "id": "button_text_color",
      "label": "Button text color",
      "default": "#FFFFFF"
    }
  ],
  "blocks": [
    {
      "type": "feature",
      "name": "Feature point",
      "settings": [
        {
          "type": "text",
          "id": "text",
          "label": "Text",
          "default": "Feature item"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Lawn — Premium Upgrade",
      "blocks": [
        {
          "type": "feature",
          "settings": {
            "text": "You Want A Darker Green, More Attractive Lawn"
          }
        },
        {
          "type": "feature",
          "settings": {
            "text": "Your Lawn Feels Thin Or Uneven"
          }
        },
        {
          "type": "feature",
          "settings": {
            "text": "You Want Better Density And A More Uniform Finish"
          }
        },
        {
          "type": "feature",
          "settings": {
            "text": "You Want Better Than Basic Seed"
          }
        }
      ]
    }
  ]
}
{% endschema %}