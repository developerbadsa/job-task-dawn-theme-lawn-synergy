{%- liquid
  assign main_image = section.settings.main_image
  assign texture_image = section.settings.texture_image
  assign bottom_grass = section.settings.bottom_grass
  assign form_product = product

  if section.settings.product != blank
    assign form_product = section.settings.product
  endif

  assign form_variant = blank
  if form_product != blank
    assign form_variant = form_product.selected_or_first_available_variant
  endif

  assign product_form_id = 'lawn-upgrade-form-' | append: section.id
-%}

<section
  id="lawn-upgrade-{{ section.id }}"
  class="lawn-upgrade-section"
  style="
    --section-bg: {{ section.settings.background_color }};
    --content-width: {{ section.settings.content_width }}px;
    --section-height: {{ section.settings.section_height }}px;
    --top-space: {{ section.settings.top_space }}px;
    --side-space: {{ section.settings.side_space }}px;
    --image-width: {{ section.settings.image_width }}px;
    --image-height: {{ section.settings.image_height }}px;
    --image-radius: {{ section.settings.image_radius }}px;
    --column-gap: {{ section.settings.column_gap }}px;
    --copy-offset: {{ section.settings.copy_offset }}px;
    --texture-opacity: {{ section.settings.texture_opacity | divided_by: 100.0 }};
    --overlay-opacity: {{ section.settings.overlay_opacity | divided_by: 100.0 }};
    --bottom-grass-height: {{ section.settings.bottom_grass_height }}px;
    --eyebrow-color: {{ section.settings.eyebrow_color }};
    --heading-color: {{ section.settings.heading_color }};
    --text-color: {{ section.settings.text_color }};
    --check-bg: {{ section.settings.check_color }};
    --button-bg: {{ section.settings.button_background }};
    --button-color: {{ section.settings.button_text_color }};
  "
>
  <div class="lawn-upgrade-section__background" aria-hidden="true">
    {%- if texture_image != blank -%}
      <img
        class="lawn-upgrade-section__texture"
        src="{{ texture_image | image_url: width: 2400 }}"
        alt=""
        loading="lazy"
        width="2400"
        height="1300">
    {%- else -%}
      <img
        class="lawn-upgrade-section__texture"
        src="{{ 'grass-bg.jpg' | asset_url }}"
        alt=""
        loading="lazy"
        width="2400"
        height="1300"
        onerror="this.style.display='none'">
    {%- endif -%}
  </div>

  <div class="lawn-upgrade-section__container">
    <div class="lawn-upgrade-section__image-wrap">
      {%- if main_image != blank -%}
        <img
          class="lawn-upgrade-section__image"
          src="{{ main_image | image_url: width: 1400 }}"
          alt="{{ section.settings.image_alt | escape }}"
          loading="lazy"
          width="1400"
          height="1800">
      {%- else -%}
        <img
          class="lawn-upgrade-section__image"
          src="{{ 'upgrade-bag.png' | asset_url }}"
          alt="{{ section.settings.image_alt | escape }}"
          loading="lazy"
          width="1400"
          height="1800">
      {%- endif -%}
    </div>

    <div class="lawn-upgrade-section__content">
      {%- if section.settings.eyebrow != blank -%}
        <p class="lawn-upgrade-section__eyebrow">{{ section.settings.eyebrow }}</p>
      {%- endif -%}

      {%- if section.settings.heading != blank -%}
        <h2 class="lawn-upgrade-section__heading">{{ section.settings.heading }}</h2>
      {%- endif -%}

      {%- if section.settings.body != blank -%}
        <div class="lawn-upgrade-section__body">
          {{ section.settings.body | newline_to_br }}
        </div>
      {%- endif -%}

      {%- if section.settings.list_heading != blank -%}
        <h3 class="lawn-upgrade-section__list-heading">{{ section.settings.list_heading }}</h3>
      {%- endif -%}

      {%- if section.blocks.size > 0 -%}
        <ul class="lawn-upgrade-section__list" role="list">
          {%- for block in section.blocks -%}
            {%- if block.type == 'point' and block.settings.text != blank -%}
              <li class="lawn-upgrade-section__point" {{ block.shopify_attributes }}>
                <span class="lawn-upgrade-section__check" aria-hidden="true">
                  <svg viewBox="0 0 12 12" focusable="false">
                    <path d="M4.7 8.6 2.1 6l.9-.9 1.7 1.7 4.2-4.2.9.9-5.1 5.1Z"></path>
                  </svg>
                </span>
                <span>{{ block.settings.text }}</span>
              </li>
            {%- endif -%}
          {%- endfor -%}
        </ul>
      {%- endif -%}

      {%- if section.settings.button_label != blank -%}
        {%- if section.settings.button_action == 'add_to_cart' and form_product != blank and form_variant != blank -%}
          {%- form 'product', form_product, id: product_form_id, class: 'lawn-upgrade-section__form' -%}
            <input type="hidden" name="id" value="{{ form_variant.id }}">
            <button
              type="submit"
              class="lawn-upgrade-section__button"
              {% unless form_variant.available %}disabled{% endunless %}
            >
              {%- if form_variant.available -%}
                {{ section.settings.button_label }}
              {%- else -%}
                {{ section.settings.sold_out_label }}
              {%- endif -%}
            </button>
          {%- endform -%}
        {%- else -%}
          <a class="lawn-upgrade-section__button" href="{{ section.settings.button_link | default: '#' }}">
            {{ section.settings.button_label }}
          </a>
        {%- endif -%}
      {%- endif -%}
    </div>
  </div>

  {%- if section.settings.show_bottom_grass -%}
    {%- if bottom_grass != blank -%}
      <img
        class="lawn-upgrade-section__bottom-grass"
        src="{{ bottom_grass | image_url: width: 2600 }}"
        alt=""
        loading="lazy"
        width="2600"
        height="320">
    {%- else -%}
      <img
        class="lawn-upgrade-section__bottom-grass"
        src="{{ 'grass-strip.png' | asset_url }}"
        alt=""
        loading="lazy"
        width="2600"
        height="320">
    {%- endif -%}
  {%- endif -%}
</section>

<style>
  #lawn-upgrade-{{ section.id }} {
    position: relative;
    isolation: isolate;
    width: 100%;
    height: var(--section-height);
    overflow: hidden;
    background: var(--section-bg);
    padding: var(--top-space) var(--side-space) 0;
    box-sizing: border-box;
  }

  #lawn-upgrade-{{ section.id }} *,
  #lawn-upgrade-{{ section.id }} *::before,
  #lawn-upgrade-{{ section.id }} *::after {
    box-sizing: border-box;
  }

  #lawn-upgrade-{{ section.id }} .lawn-upgrade-section__background {
    position: absolute;
    inset: 0;
    z-index: 0;
    background: var(--section-bg);
    pointer-events: none;
    overflow: hidden;
  }

  #lawn-upgrade-{{ section.id }} .lawn-upgrade-section__texture {
    position: absolute !important;
    inset: 0 !important;
    display: block !important;
    width: 100% !important;
    height: 100% !important;
    object-fit: cover !important;
    opacity: var(--texture-opacity) !important;
    visibility: visible !important;
    z-index: 1;
    filter: saturate(0.9) contrast(1.05);
  }

  #lawn-upgrade-{{ section.id }} .lawn-upgrade-section__background::after {
    content: "";
    position: absolute;
    inset: 0;
    z-index: 2;
    background:
      radial-gradient(circle at 18% 10%, rgba(255, 255, 255, 0.06), transparent 32%),
      linear-gradient(90deg, rgba(0, 50, 30, 0.55) 0%, rgba(0, 50, 30, 0.4) 100%);
    opacity: var(--overlay-opacity);
    pointer-events: none;
  }

  #lawn-upgrade-{{ section.id }} .lawn-upgrade-section__container {
    position: relative;
    z-index: 3;
    width: 100%;
    max-width: var(--content-width);
    height: 100%;
    margin: 0 auto;
    display: grid;
    grid-template-columns: var(--image-width) 1fr;
    column-gap: var(--column-gap);
    align-items: start;
  }

  #lawn-upgrade-{{ section.id }} .lawn-upgrade-section__image-wrap {
    position: relative;
    z-index: 3;
    width: var(--image-width);
    height: var(--image-height);
    border-radius: var(--image-radius);
    overflow: hidden;
    background: transparent;
    opacity: 1 !important;
    visibility: visible !important;
  }

  #lawn-upgrade-{{ section.id }} .lawn-upgrade-section__image {
    display: block !important;
    width: 100% !important;
    height: 100% !important;
    object-fit: cover !important;
    object-position: center center !important;
    opacity: 1 !important;
    visibility: visible !important;
    border-radius: var(--image-radius);
  }

  #lawn-upgrade-{{ section.id }} .lawn-upgrade-section__content {
    position: relative;
    z-index: 4;
    width: 100%;
    max-width: 596px;
    padding-top: var(--copy-offset);
    color: var(--text-color);
  }

  #lawn-upgrade-{{ section.id }} .lawn-upgrade-section__eyebrow {
    margin: 0 0 14px;
    color: var(--eyebrow-color);
    font-family: "Clash Grotesk", "Poppins", system-ui, sans-serif;
    font-size: 16px;
    line-height: 1.2;
    font-weight: 500;
    letter-spacing: -0.02em;
  }

  #lawn-upgrade-{{ section.id }} .lawn-upgrade-section__heading {
    margin: 0;
    max-width: 596px;
    color: var(--heading-color);
    font-family: "Clash Grotesk", "Poppins", system-ui, sans-serif;
    font-size: 52px;
    line-height: 1.15;
    font-weight: 600;
    letter-spacing: -0.4px;
  }

  #lawn-upgrade-{{ section.id }} .lawn-upgrade-section__body {
    margin-top: 16px;
    max-width: 560px;
    color: var(--text-color);
    font-family: "Clash Grotesk", "Poppins", system-ui, sans-serif;
    font-size: 16px;
    line-height: 1.55;
    font-weight: 400;
    letter-spacing: -0.01em;
  }

  #lawn-upgrade-{{ section.id }} .lawn-upgrade-section__list-heading {
    margin: 28px 0 16px;
    color: var(--heading-color);
    font-family: "Clash Grotesk", "Poppins", system-ui, sans-serif;
    font-size: 18px;
    line-height: 1.25;
    font-weight: 600;
    letter-spacing: -0.4px;
  }

  #lawn-upgrade-{{ section.id }} .lawn-upgrade-section__list {
    display: grid;
    gap: 13px;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  #lawn-upgrade-{{ section.id }} .lawn-upgrade-section__point {
    display: flex;
    align-items: flex-start;
    gap: 10px;
    margin: 0;
    color: var(--text-color);
    font-family: "Clash Grotesk", "Poppins", system-ui, sans-serif;
    font-size: 16px;
    line-height: 1.2;
    font-weight: 500;
    letter-spacing: -0.01em;
  }

  #lawn-upgrade-{{ section.id }} .lawn-upgrade-section__check {
    flex: 0 0 17px;
    width: 17px;
    height: 17px;
    margin-top: 1px;
    display: inline-grid;
    place-items: center;
    border-radius: 50%;
    background: var(--check-bg);
  }

  #lawn-upgrade-{{ section.id }} .lawn-upgrade-section__check svg {
    width: 12px;
    height: 12px;
    fill: #ffffff;
  }

  #lawn-upgrade-{{ section.id }} .lawn-upgrade-section__form {
    margin: 0;
  }

  #lawn-upgrade-{{ section.id }} .lawn-upgrade-section__button {
    width: {{ section.settings.button_width }}px;
    min-height: {{ section.settings.button_height }}px;
    margin-top: 33px;
    display: inline-grid;
    place-items: center;
    border: 0;
    border-radius: 999px;
    background: var(--button-bg);
    color: var(--button-color);
    text-decoration: none;
    font-family: "Clash Grotesk", "Poppins", system-ui, sans-serif;
    font-size: 24px;
    line-height: 1;
    font-weight: 600;
    letter-spacing: -0.4px;
    cursor: pointer;
    appearance: none;
    box-shadow: none;
  }

  #lawn-upgrade-{{ section.id }} .lawn-upgrade-section__button:disabled {
    opacity: 0.55;
    cursor: not-allowed;
  }

  #lawn-upgrade-{{ section.id }} .lawn-upgrade-section__bottom-grass {
    position: absolute !important;
    left: 0 !important;
    right: 0 !important;
    bottom: 0 !important;
    z-index: 8 !important;
    display: block !important;
    width: 100% !important;
    height: var(--bottom-grass-height) !important;
    object-fit: cover !important;
    object-position: center bottom !important;
    pointer-events: none;
    opacity: 1 !important;
    visibility: visible !important;
  }

  @media screen and (max-width: 1320px) {
    #lawn-upgrade-{{ section.id }} {
      padding-left: 32px;
      padding-right: 32px;
    }

    #lawn-upgrade-{{ section.id }} .lawn-upgrade-section__container {
      grid-template-columns: minmax(500px, var(--image-width)) minmax(0, 1fr);
    }
  }

  @media screen and (max-width: 989px) {
    #lawn-upgrade-{{ section.id }} {
      height: auto;
      min-height: 0;
      padding: 56px 20px 130px;
    }

    #lawn-upgrade-{{ section.id }} .lawn-upgrade-section__container {
      max-width: 620px;
      height: auto;
      grid-template-columns: 1fr;
      gap: 34px;
    }

    #lawn-upgrade-{{ section.id }} .lawn-upgrade-section__image-wrap {
      width: 100%;
      height: auto;
      aspect-ratio: 630 / 823;
    }

    #lawn-upgrade-{{ section.id }} .lawn-upgrade-section__content {
      max-width: none;
      padding-top: 0;
    }

    #lawn-upgrade-{{ section.id }} .lawn-upgrade-section__heading {
      max-width: none;
      font-size: 36px;
      line-height: 1.18;
    }

    #lawn-upgrade-{{ section.id }} .lawn-upgrade-section__bottom-grass {
      height: 118px !important;
      min-width: 900px;
      left: 50% !important;
      right: auto !important;
      transform: translateX(-50%);
    }
  }

  @media screen and (max-width: 575px) {
    #lawn-upgrade-{{ section.id }} {
      padding: 44px 16px 105px;
    }

    #lawn-upgrade-{{ section.id }} .lawn-upgrade-section__heading {
      font-size: 31px;
      line-height: 1.15;
    }

    #lawn-upgrade-{{ section.id }} .lawn-upgrade-section__body,
    #lawn-upgrade-{{ section.id }} .lawn-upgrade-section__point {
      font-size: 14px;
    }

    #lawn-upgrade-{{ section.id }} .lawn-upgrade-section__button {
      width: 220px;
      min-height: 56px;
      font-size: 21px;
    }

    #lawn-upgrade-{{ section.id }} .lawn-upgrade-section__bottom-grass {
      height: 96px !important;
      min-width: 720px;
    }
  }
</style>

