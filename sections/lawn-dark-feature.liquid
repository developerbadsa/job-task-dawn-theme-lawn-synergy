{%- liquid
  assign main_image = section.settings.main_image
  assign texture_image = section.settings.texture_image
  assign bottom_grass = section.settings.bottom_grass
  assign form_product = product

  if section.settings.product != blank
    assign form_product = section.settings.product
  endif

  assign form_variant = blank
  if form_product != blank
    assign form_variant = form_product.selected_or_first_available_variant
  endif

  assign product_form_id = 'premium-upgrade-form-' | append: section.id
-%}

<section
  id="premium-upgrade-{{ section.id }}"
  class="premium-upgrade-section"
  style="
    --section-bg: {{ section.settings.background_color }};
    --section-height: {{ section.settings.section_height }}px;
    --content-width: {{ section.settings.content_width }}px;
    --top-space: {{ section.settings.top_space }}px;
    --image-width: {{ section.settings.image_width }}px;
    --image-height: {{ section.settings.image_height }}px;
    --image-radius: {{ section.settings.image_radius }}px;
    --column-gap: {{ section.settings.column_gap }}px;
    --content-top-offset: {{ section.settings.content_top_offset }}px;
    --content-width-copy: {{ section.settings.content_copy_width }}px;
    --bottom-grass-height: {{ section.settings.bottom_grass_height }}px;
    --texture-opacity: {{ section.settings.texture_opacity | divided_by: 100.0 }};
    --overlay-opacity: {{ section.settings.overlay_opacity | divided_by: 100.0 }};
    --eyebrow-color: {{ section.settings.eyebrow_color }};
    --heading-color: {{ section.settings.heading_color }};
    --text-color: {{ section.settings.text_color }};
    --check-bg: {{ section.settings.check_color }};
    --button-bg: {{ section.settings.button_background }};
    --button-color: {{ section.settings.button_text_color }};
    --button-width: {{ section.settings.button_width }}px;
    --button-height: {{ section.settings.button_height }}px;
  "
>
  <div class="premium-upgrade-section__bg" aria-hidden="true">
    {%- if texture_image != blank -%}
      {{ texture_image | image_url: width: 2600 | image_tag:
        class: 'premium-upgrade-section__texture',
        loading: 'lazy',
        alt: '',
        width: 2600,
        height: 1200
      }}
    {%- endif -%}
  </div>

  <div class="premium-upgrade-section__inner">
    <div class="premium-upgrade-section__media">
      {%- if main_image != blank -%}
        {{ main_image | image_url: width: 1400 | image_tag:
          class: 'premium-upgrade-section__image',
          loading: 'lazy',
          alt: section.settings.image_alt,
          width: 1400,
          height: 1800
        }}
      {%- endif -%}
    </div>

    <div class="premium-upgrade-section__content">
      {%- if section.settings.eyebrow != blank -%}
        <p class="premium-upgrade-section__eyebrow">{{ section.settings.eyebrow }}</p>
      {%- endif -%}

      {%- if section.settings.heading != blank -%}
        <h2 class="premium-upgrade-section__heading">{{ section.settings.heading }}</h2>
      {%- endif -%}

      {%- if section.settings.body != blank -%}
        <div class="premium-upgrade-section__body">
          {{ section.settings.body | newline_to_br }}
        </div>
      {%- endif -%}

      {%- if section.settings.list_heading != blank -%}
        <h3 class="premium-upgrade-section__list-heading">{{ section.settings.list_heading }}</h3>
      {%- endif -%}

      {%- if section.blocks.size > 0 -%}
        <ul class="premium-upgrade-section__list" role="list">
          {%- for block in section.blocks -%}
            {%- if block.type == 'point' and block.settings.text != blank -%}
              <li class="premium-upgrade-section__point" {{ block.shopify_attributes }}>
                <span class="premium-upgrade-section__check" aria-hidden="true">
                  <svg viewBox="0 0 12 12" focusable="false">
                    <path d="M4.65 8.45 2.15 5.95l.85-.85 1.65 1.65 4.25-4.25.85.85-5.1 5.1Z"></path>
                  </svg>
                </span>
                <span>{{ block.settings.text }}</span>
              </li>
            {%- endif -%}
          {%- endfor -%}
        </ul>
      {%- endif -%}

      {%- if section.settings.button_label != blank -%}
        {%- if section.settings.button_action == 'add_to_cart' and form_product != blank and form_variant != blank -%}
          {%- form 'product', form_product, id: product_form_id, class: 'premium-upgrade-section__form' -%}
            <input type="hidden" name="id" value="{{ form_variant.id }}">
            <button
              type="submit"
              class="premium-upgrade-section__button"
              {% unless form_variant.available %}disabled{% endunless %}
            >
              {%- if form_variant.available -%}
                {{ section.settings.button_label }}
              {%- else -%}
                {{ section.settings.sold_out_label }}
              {%- endif -%}
            </button>
          {%- endform -%}
        {%- else -%}
          <a class="premium-upgrade-section__button" href="{{ section.settings.button_link | default: '#' }}">
            {{ section.settings.button_label }}
          </a>
        {%- endif -%}
      {%- endif -%}
    </div>
  </div>

  {%- if section.settings.show_bottom_grass and bottom_grass != blank -%}
    {{ bottom_grass | image_url: width: 2600 | image_tag:
      class: 'premium-upgrade-section__bottom-grass',
      loading: 'lazy',
      alt: '',
      width: 2600,
      height: 320
    }}
  {%- endif -%}
</section>

<style>
  #premium-upgrade-{{ section.id }} {
    position: relative;
    isolation: isolate;
    width: 100%;
    height: var(--section-height);
    overflow: hidden;
    background: var(--section-bg);
  }

  #premium-upgrade-{{ section.id }} *,
  #premium-upgrade-{{ section.id }} *::before,
  #premium-upgrade-{{ section.id }} *::after {
    box-sizing: border-box;
  }

  #premium-upgrade-{{ section.id }} .premium-upgrade-section__bg {
    position: absolute;
    inset: 0;
    z-index: 0;
    overflow: hidden;
    background: var(--section-bg);
    pointer-events: none;
  }

  #premium-upgrade-{{ section.id }} .premium-upgrade-section__texture {
    position: absolute;
    inset: 0;
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    opacity: var(--texture-opacity);
    filter: saturate(0.9) contrast(1.05);
  }

  #premium-upgrade-{{ section.id }} .premium-upgrade-section__bg::after {
    content: "";
    position: absolute;
    inset: 0;
    z-index: 2;
    background:
      radial-gradient(circle at 15% 12%, rgba(255, 255, 255, 0.06), transparent 34%),
      linear-gradient(90deg, rgba(0, 55, 34, 0.72) 0%, rgba(0, 55, 34, 0.66) 100%);
    opacity: var(--overlay-opacity);
  }

  #premium-upgrade-{{ section.id }} .premium-upgrade-section__inner {
    position: relative;
    z-index: 3;
    width: min(100% - 32px, var(--content-width));
    height: 100%;
    margin: 0 auto;
    padding-top: var(--top-space);
    display: grid;
    grid-template-columns: var(--image-width) minmax(0, var(--content-width-copy));
    column-gap: var(--column-gap);
    align-items: start;
  }

  #premium-upgrade-{{ section.id }} .premium-upgrade-section__media {
    position: relative;
    z-index: 3;
    width: var(--image-width);
    height: var(--image-height);
    border-radius: var(--image-radius);
    overflow: hidden;
    background: rgba(255, 255, 255, 0.04);
  }

  #premium-upgrade-{{ section.id }} .premium-upgrade-section__image {
    display: block;
    width: 100%;
    height: 100%;
    border-radius: var(--image-radius);
    object-fit: cover;
    object-position: center;
  }

  #premium-upgrade-{{ section.id }} .premium-upgrade-section__content {
    position: relative;
    z-index: 4;
    width: 100%;
    max-width: var(--content-width-copy);
    padding-top: var(--content-top-offset);
    color: var(--text-color);
  }

  #premium-upgrade-{{ section.id }} .premium-upgrade-section__eyebrow {
    margin: 0 0 14px;
    color: var(--eyebrow-color);
    font-family: "Clash Grotesk", "Poppins", system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
    font-size: 16px;
    line-height: 1.2;
    font-weight: 500;
    letter-spacing: -0.02em;
  }

  #premium-upgrade-{{ section.id }} .premium-upgrade-section__heading {
    margin: 0;
    max-width: 596px;
    color: var(--heading-color);
    font-family: "Clash Grotesk", "Poppins", system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
    font-size: 52px;
    line-height: 1.15;
    font-weight: 600;
    letter-spacing: -0.5px;
  }

  #premium-upgrade-{{ section.id }} .premium-upgrade-section__body {
    margin-top: 17px;
    max-width: 560px;
    color: var(--text-color);
    font-family: "Clash Grotesk", "Poppins", system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
    font-size: 16px;
    line-height: 1.55;
    font-weight: 400;
    letter-spacing: -0.01em;
  }

  #premium-upgrade-{{ section.id }} .premium-upgrade-section__list-heading {
    margin: 28px 0 16px;
    color: var(--heading-color);
    font-family: "Clash Grotesk", "Poppins", system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
    font-size: 18px;
    line-height: 1.25;
    font-weight: 600;
    letter-spacing: -0.35px;
  }

  #premium-upgrade-{{ section.id }} .premium-upgrade-section__list {
    display: grid;
    gap: 13px;
    margin: 0;
    padding: 0;
    list-style: none;
  }

  #premium-upgrade-{{ section.id }} .premium-upgrade-section__point {
    display: flex;
    align-items: flex-start;
    gap: 10px;
    margin: 0;
    color: var(--text-color);
    font-family: "Clash Grotesk", "Poppins", system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
    font-size: 16px;
    line-height: 1.22;
    font-weight: 500;
    letter-spacing: -0.01em;
  }

  #premium-upgrade-{{ section.id }} .premium-upgrade-section__check {
    flex: 0 0 17px;
    width: 17px;
    height: 17px;
    margin-top: 1px;
    display: inline-grid;
    place-items: center;
    border-radius: 999px;
    background: var(--check-bg);
  }

  #premium-upgrade-{{ section.id }} .premium-upgrade-section__check svg {
    display: block;
    width: 12px;
    height: 12px;
    fill: #ffffff;
  }

  #premium-upgrade-{{ section.id }} .premium-upgrade-section__form {
    margin: 0;
  }

  #premium-upgrade-{{ section.id }} .premium-upgrade-section__button {
    width: var(--button-width);
    min-height: var(--button-height);
    margin-top: 33px;
    display: inline-grid;
    place-items: center;
    border: 0;
    border-radius: 999px;
    background: var(--button-bg);
    color: var(--button-color);
    text-decoration: none;
    font-family: "Clash Grotesk", "Poppins", system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
    font-size: 24px;
    line-height: 1;
    font-weight: 600;
    letter-spacing: -0.4px;
    cursor: pointer;
    appearance: none;
    box-shadow: none;
  }

  #premium-upgrade-{{ section.id }} .premium-upgrade-section__button:disabled {
    opacity: 0.6;
    cursor: not-allowed;
  }

  #premium-upgrade-{{ section.id }} .premium-upgrade-section__bottom-grass {
    position: absolute;
    left: 0;
    right: 0;
    bottom: -60px;
    z-index: 22;
    display: block;
    width: 100%;
    height: 264px;
    object-fit: cover;
    object-position: center bottom;
    pointer-events: none;
    inset: 12
  }

  @media screen and (max-width: 1320px) {
    #premium-upgrade-{{ section.id }} .premium-upgrade-section__inner {
      width: min(100% - 64px, var(--content-width));
      grid-template-columns: minmax(420px, 0.52fr) minmax(0, 0.48fr);
      column-gap: clamp(28px, 3vw, var(--column-gap));
    }

    #premium-upgrade-{{ section.id }} .premium-upgrade-section__media {
      width: 100%;
      height: min(var(--image-height), 64vw);
    }

    #premium-upgrade-{{ section.id }} .premium-upgrade-section__heading {
      font-size: clamp(38px, 3.65vw, 52px);
    }
  }

  @media screen and (max-width: 989px) {
    #premium-upgrade-{{ section.id }} {
      height: auto;
      min-height: 0;
      padding: 56px 20px 128px;
    }

    #premium-upgrade-{{ section.id }} .premium-upgrade-section__inner {
      width: 100%;
      max-width: 680px;
      height: auto;
      padding-top: 0;
      display: grid;
      grid-template-columns: 1fr;
      gap: 34px;
    }

    #premium-upgrade-{{ section.id }} .premium-upgrade-section__media {
      width: 100%;
      height: auto;
      aspect-ratio: 630 / 823;
    }

    #premium-upgrade-{{ section.id }} .premium-upgrade-section__content {
      padding-top: 0;
      max-width: none;
    }

    #premium-upgrade-{{ section.id }} .premium-upgrade-section__heading {
      max-width: none;
      font-size: 38px;
      line-height: 1.16;
    }

    #premium-upgrade-{{ section.id }} .premium-upgrade-section__bottom-grass {
      height: 118px;
      width: 1100px;
      max-width: none;
      left: 50%;
      right: auto;
      transform: translateX(-50%);
    }
  }

  @media screen and (max-width: 575px) {
    #premium-upgrade-{{ section.id }} {
      padding: 44px 16px 108px;
    }

    #premium-upgrade-{{ section.id }} .premium-upgrade-section__heading {
      font-size: 32px;
    }

    #premium-upgrade-{{ section.id }} .premium-upgrade-section__eyebrow {
      font-size: 14px;
    }

    #premium-upgrade-{{ section.id }} .premium-upgrade-section__body,
    #premium-upgrade-{{ section.id }} .premium-upgrade-section__point {
      font-size: 14px;
    }

    #premium-upgrade-{{ section.id }} .premium-upgrade-section__button {
      width: 220px;
      min-height: 56px;
      font-size: 21px;
    }

    #premium-upgrade-{{ section.id }} .premium-upgrade-section__bottom-grass {
      height: 96px;
      width: 820px;
    }
  }
</style>

