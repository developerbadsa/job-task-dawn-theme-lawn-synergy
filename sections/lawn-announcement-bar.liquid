{%- liquid
  assign bg = section.settings.bg_color | default: '#61bd91'
  assign color = section.settings.text_color | default: '#ffffff'
-%}

<div class="promo" style="background: {{ bg }}; color: {{ color }};" role="region" aria-label="Promotion">
  {%- if section.settings.link != blank -%}
    <a href="{{ section.settings.link }}" style="color: inherit; text-decoration: none;">
      {{ section.settings.text }}
    </a>
  {%- else -%}
    {{ section.settings.text }}
  {%- endif -%}
</div>

{% schema %}
{
  "name": "Lawn — Promo Bar",
  "tag": "section",
  "class": "lawn-promo-section",
  "settings": [
    {
      "type": "text",
      "id": "text",
      "label": "Promo text",
      "default": "USE CODE: CELEBRATE10 FOR 10% OFF YOUR ORDER!"
    },
    {
      "type": "url",
      "id": "link",
      "label": "Optional link"
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Background color",
      "default": "#61bd91"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#ffffff"
    }
  ],
  "presets": [
    { "name": "Lawn — Promo Bar" }
  ]
}
{% endschema %}
