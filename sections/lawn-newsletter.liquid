{%- liquid
  assign bag = section.settings.bag_image
  assign heading = section.settings.heading | default: 'Grow Your Dream Lawn'
  assign body = section.settings.body
  assign placeholder = section.settings.placeholder | default: 'Mail Address'
  assign button_label = section.settings.button_label | default: 'Subscribe'
  assign success_text = section.settings.success_text | default: 'Thanks for subscribing!'
-%}

{% style %}
  #lawn-newsletter-{{ section.id }} {
    width: min(1128px, calc(100% - 112px));
    min-height: 328px;
    margin: 0 auto;
    padding: 45px 44px 62px;
    position: relative;
    overflow: hidden;
    box-sizing: border-box;
    border-radius: 12px;
    background: #27ad70;
  }

  #lawn-newsletter-{{ section.id }} * {
    box-sizing: border-box;
  }

  #lawn-newsletter-{{ section.id }} .newsletter-copy {
    width: 663px;
    max-width: 62%;
    position: relative;
    z-index: 3;
  }

  #lawn-newsletter-{{ section.id }} .newsletter-copy h2 {
    width: 663px;
    max-width: 100%;
    margin: 0 0 7px;
    color: #ffffff;
    font-family: "Clash Grotesk", var(--font-heading-family), var(--font-body-family), Arial, sans-serif;
    font-size: 52px;
    line-height: 64px;
    font-weight: 600;
    letter-spacing: -0.4px;
    text-transform: none;
  }

  #lawn-newsletter-{{ section.id }} .newsletter-copy p {
    width: 650px;
    max-width: 100%;
    margin: 0;
    color: #ffffff;
    font-family: "Clash Grotesk", var(--font-body-family), Arial, sans-serif;
    font-size: 17px;
    line-height: 28px;
    font-weight: 400;
    letter-spacing: -0.1px;
  }

  #lawn-newsletter-{{ section.id }} .newsletter-form-wrap {
    margin: 31px 0 0;
    padding: 0;
  }

  #lawn-newsletter-{{ section.id }} .newsletter-form-field {
    width: 540px;
    max-width: 100%;
    height: 72px;
    padding: 0 4px 0 27px;
    display: flex;
    align-items: center;
    border: 1px solid rgba(255, 255, 255, 0.82);
    border-radius: 50px;
    background: rgba(255, 255, 255, 0.08);
  }

  #lawn-newsletter-{{ section.id }} .newsletter-form-field input[type="email"] {
    width: 100%;
    min-width: 0;
    height: 100%;
    padding: 0 18px 0 0;
    border: 0;
    outline: 0;
    box-shadow: none;
    background: transparent;
    color: #ffffff;
    font-family: "Clash Grotesk", var(--font-body-family), Arial, sans-serif;
    font-size: 15px;
    line-height: 20px;
    font-weight: 400;
  }

  #lawn-newsletter-{{ section.id }} .newsletter-form-field input[type="email"]::placeholder {
    color: rgba(255, 255, 255, 0.72);
    opacity: 1;
  }

  #lawn-newsletter-{{ section.id }} .newsletter-form-field button {
    width: 230px;
    flex: 0 0 230px;
    height: 64px;
    margin: 0;
    padding: 0 24px;
    border: 0;
    border-radius: 50px;
    background: #fc5810;
    color: #ffffff;
    font-family: "Clash Grotesk", var(--font-heading-family), var(--font-body-family), Arial, sans-serif;
    font-size: 24px;
    line-height: 32px;
    font-weight: 600;
    letter-spacing: -0.2px;
    cursor: pointer;
    transition: transform 0.2s ease, opacity 0.2s ease;
  }

  #lawn-newsletter-{{ section.id }} .newsletter-form-field button:hover {
    transform: translateY(-1px);
    opacity: 0.96;
  }

  #lawn-newsletter-{{ section.id }} .newsletter-message {
    width: 540px;
    max-width: 100%;
    margin: 12px 0 0;
    color: #ffffff;
    font-family: "Clash Grotesk", var(--font-body-family), Arial, sans-serif;
    font-size: 14px;
    line-height: 20px;
  }

  #lawn-newsletter-{{ section.id }} .newsletter-message ul {
    margin: 0;
    padding-left: 18px;
  }

  #lawn-newsletter-{{ section.id }} .newsletter-bag {
    width: 475px;
    max-width: none;
    height: auto;
    position: absolute;
    right: 71px;
    bottom: 0;
    z-index: 2;
    display: block;
    pointer-events: none;
    user-select: none;
  }

  @media screen and (max-width: 1100px) {
    #lawn-newsletter-{{ section.id }} {
      width: calc(100% - 56px);
      padding: 42px 36px 54px;
    }

    #lawn-newsletter-{{ section.id }} .newsletter-copy {
      max-width: 64%;
    }

    #lawn-newsletter-{{ section.id }} .newsletter-copy h2 {
      font-size: 44px;
      line-height: 54px;
    }

    #lawn-newsletter-{{ section.id }} .newsletter-copy p {
      font-size: 15px;
      line-height: 24px;
    }

    #lawn-newsletter-{{ section.id }} .newsletter-bag {
      width: 410px;
      right: 28px;
    }
  }

  @media screen and (max-width: 749px) {
    #lawn-newsletter-{{ section.id }} {
      width: calc(100% - 28px);
      min-height: 455px;
      padding: 30px 22px 215px;
      border-radius: 14px;
    }

    #lawn-newsletter-{{ section.id }} .newsletter-copy {
      width: 100%;
      max-width: none;
    }

    #lawn-newsletter-{{ section.id }} .newsletter-copy h2 {
      width: 100%;
      font-size: 34px;
      line-height: 42px;
      letter-spacing: -0.3px;
      margin-bottom: 8px;
    }

    #lawn-newsletter-{{ section.id }} .newsletter-copy p {
      width: 100%;
      font-size: 14px;
      line-height: 22px;
    }

    #lawn-newsletter-{{ section.id }} .newsletter-form-wrap {
      margin-top: 26px;
    }

    #lawn-newsletter-{{ section.id }} .newsletter-form-field {
      width: 100%;
      height: 60px;
      padding-left: 18px;
    }

    #lawn-newsletter-{{ section.id }} .newsletter-form-field input[type="email"] {
      font-size: 13px;
    }

    #lawn-newsletter-{{ section.id }} .newsletter-form-field button {
      width: 145px;
      flex-basis: 145px;
      height: 52px;
      font-size: 18px;
      line-height: 24px;
      padding-inline: 14px;
    }

    #lawn-newsletter-{{ section.id }} .newsletter-bag {
      width: 330px;
      right: -20px;
      bottom: 0;
    }
  }

  @media screen and (max-width: 420px) {
    #lawn-newsletter-{{ section.id }} {
      min-height: 430px;
      padding: 28px 18px 198px;
    }

    #lawn-newsletter-{{ section.id }} .newsletter-copy h2 {
      font-size: 30px;
      line-height: 38px;
    }

    #lawn-newsletter-{{ section.id }} .newsletter-form-field {
      height: 58px;
      padding-left: 16px;
    }

    #lawn-newsletter-{{ section.id }} .newsletter-form-field button {
      width: 128px;
      flex-basis: 128px;
      height: 50px;
      font-size: 16px;
    }

    #lawn-newsletter-{{ section.id }} .newsletter-bag {
      width: 292px;
      right: -28px;
    }
  }
{% endstyle %}

<section id="lawn-newsletter-{{ section.id }}" class="newsletter container">
  <div class="newsletter-copy">
    <h2>{{ heading }}</h2>

    {%- if body != blank -%}
      <p>{{ body }}</p>
    {%- endif -%}

    {%- form 'customer', class: 'newsletter-form-wrap' -%}
      <input type="hidden" name="contact[tags]" value="newsletter">

      <div class="newsletter-form-field">
        <input
          type="email"
          name="contact[email]"
          id="LawnNewsletterEmail-{{ section.id }}"
          placeholder="{{ placeholder | escape }}"
          aria-label="{{ placeholder | escape }}"
          autocorrect="off"
          autocapitalize="off"
          autocomplete="email"
          required
        >
        <button type="submit">{{ button_label }}</button>
      </div>

      {%- if form.posted_successfully? -%}
        <div class="newsletter-message">{{ success_text }}</div>
      {%- endif -%}

      {%- if form.errors -%}
        <div class="newsletter-message">{{ form.errors | default_errors }}</div>
      {%- endif -%}
    {%- endform -%}
  </div>

  {%- if bag != blank -%}
    {{
      bag
      | image_url: width: 1000
      | image_tag:
        class: 'newsletter-bag',
        loading: 'lazy',
        alt: ''
    }}
  {%- elsif section.settings.show_default_bag -%}
    <img
      class="newsletter-bag"
      src="{{ 'newsletter-bag.png' | asset_url }}"
      alt="Envy product bag"
      width="475"
      height="328"
      loading="lazy"
    >
  {%- endif -%}
</section>

{% schema %}
{
  "name": "Lawn — Newsletter",
  "tag": "section",
  "class": "lawn-newsletter-section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Grow Your Dream Lawn"
    },
    {
      "type": "textarea",
      "id": "body",
      "label": "Body text",
      "default": "Get Our FREE Lawn Care Guide Plus Expert Tips On Maintaining A Lush, Weed Free Yard."
    },
    {
      "type": "text",
      "id": "placeholder",
      "label": "Email placeholder",
      "default": "Mail Address"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Subscribe"
    },
    {
      "type": "text",
      "id": "success_text",
      "label": "Success message",
      "default": "Thanks for subscribing!"
    },
    {
      "type": "image_picker",
      "id": "bag_image",
      "label": "Product image"
    },
    {
      "type": "checkbox",
      "id": "show_default_bag",
      "label": "Show default product image when none uploaded",
      "default": true
    }
  ],
  "presets": [
    {
      "name": "Lawn — Newsletter"
    }
  ]
}
{% endschema %}