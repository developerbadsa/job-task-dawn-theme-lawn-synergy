{%- liquid
  assign bag = section.settings.bag_image
  assign heading = section.settings.heading | default: 'Grow Your Dream Lawn'
  assign body = section.settings.body
  assign placeholder = section.settings.placeholder | default: 'Mail Address'
  assign button_label = section.settings.button_label | default: 'Subscribe'
  assign success_text = section.settings.success_text | default: 'Thanks for subscribing!'
-%}

{% style %}
  #lawn-newsletter-{{ section.id }} {
    width: 1128px !important;
    max-width: calc(100vw - 112px) !important;
    height: 328px !important;
    min-height: 328px !important;
    margin: 0 auto !important;
    padding: 45px 44px 0 44px !important;
    position: relative !important;
    overflow: hidden !important;
    box-sizing: border-box !important;
    border-radius: 12px !important;
    background: #27ad70 !important;
  }

  #lawn-newsletter-{{ section.id }},
  #lawn-newsletter-{{ section.id }} * {
    box-sizing: border-box !important;
  }

  #lawn-newsletter-{{ section.id }} .newsletter-copy {
    width: 663px !important;
    max-width: 663px !important;
    position: relative !important;
    z-index: 3 !important;
  }

  #lawn-newsletter-{{ section.id }} .newsletter-title {
    width: 663px !important;
    max-width: 663px !important;
    margin: 0 0 7px 0 !important;
    padding: 0 !important;
    color: #ffffff !important;
    font-family: "Clash Grotesk", "ClashGrotesk", var(--font-heading-family), Arial, sans-serif !important;
    font-size: 52px !important;
    line-height: 64px !important;
    font-weight: 600 !important;
    letter-spacing: -0.4px !important;
    text-transform: none !important;
  }

  #lawn-newsletter-{{ section.id }} .newsletter-text {
    width: 663px !important;
    max-width: 663px !important;
    margin: 0 !important;
    padding: 0 !important;
    color: #ffffff !important;
    font-family: 'Poppins' !important;
    font-size: 17px !important;
    line-height: 28px !important;
    font-weight: 400 !important;
    letter-spacing: -0.1px !important;
  }

  #lawn-newsletter-{{ section.id }} .newsletter-form {
    width: 640px !important;
    max-width: 640px !important;
    height: 72px !important;
    margin: 31px 0 0 0 !important;
    padding: 0 4px 0 27px !important;
    display: flex !important;
    align-items: center !important;
    position: relative !important;
    z-index: 4 !important;
    border: 1px solid rgba(255, 255, 255, 0.85) !important;
    border-radius: 50px !important;
    background: rgba(255, 255, 255, 0.08) !important;
  }

  #lawn-newsletter-{{ section.id }} .newsletter-form input[type="email"] {
    width: 100% !important;
    min-width: 0 !important;
    height: 100% !important;
    margin: 0 !important;
    padding: 0 22px 0 0 !important;
    border: 0 !important;
    outline: 0 !important;
    box-shadow: none !important;
    background: transparent !important;
    color: #ffffff !important;
    font-family: "Clash Grotesk", "ClashGrotesk", var(--font-body-family), Arial, sans-serif !important;
    font-size: 15px !important;
    line-height: 20px !important;
    font-weight: 400 !important;
  }

  #lawn-newsletter-{{ section.id }} .newsletter-form input[type="email"]::placeholder {
    color: rgba(255, 255, 255, 0.72) !important;
    opacity: 1 !important;
  }

  #lawn-newsletter-{{ section.id }} .newsletter-form button {
    width: 259px !important;
    min-width: 259px !important;
    flex: 0 0 259px !important;
    height: 64px !important;
    margin: 0 !important;
    padding: 0 24px !important;
    border: 0 !important;
    border-radius: 50px !important;
    background: #fc5810 !important;
    color: #ffffff !important;
    font-family: "Clash Grotesk", "ClashGrotesk", var(--font-heading-family), Arial, sans-serif !important;
    font-size: 24px !important;
    line-height: 32px !important;
    font-weight: 600 !important;
    letter-spacing: -0.2px !important;
    text-align: center !important;
    cursor: pointer !important;
    box-shadow: none !important;
    appearance: none !important;
  }

  #lawn-newsletter-{{ section.id }} .newsletter-message {
    width: 640px !important;
    max-width: 640px !important;
    margin: 12px 0 0 0 !important;
    color: #ffffff !important;
    font-size: 14px !important;
    line-height: 20px !important;
    font-family: "Clash Grotesk", "ClashGrotesk", var(--font-body-family), Arial, sans-serif !important;
  }

  #lawn-newsletter-{{ section.id }} .newsletter-message ul {
    margin: 0 !important;
    padding-left: 18px !important;
  }

  #lawn-newsletter-{{ section.id }} .newsletter-bag {
     width: 428px !important;
    max-width: none !important;
    height: auto !important;
    position: absolute !important;
    right: 37px !important;
    bottom: 0 !important;
    z-index: 2 !important;
    display: block !important;
    pointer-events: none !important;
    user-select: none !important;
}
  }

  @media screen and (max-width: 1199px) {
    #lawn-newsletter-{{ section.id }} {
      width: calc(100vw - 56px) !important;
      max-width: calc(100vw - 56px) !important;
    }

    #lawn-newsletter-{{ section.id }} .newsletter-title {
      font-size: 44px !important;
      line-height: 54px !important;
    }

    #lawn-newsletter-{{ section.id }} .newsletter-text {
      font-size: 15px !important;
      line-height: 24px !important;
    }

    #lawn-newsletter-{{ section.id }} .newsletter-copy {
      width: 610px !important;
      max-width: 58% !important;
    }

    #lawn-newsletter-{{ section.id }} .newsletter-form {
      width: 540px !important;
      max-width: 540px !important;
    }

    #lawn-newsletter-{{ section.id }} .newsletter-form button {
      width: 220px !important;
      min-width: 220px !important;
      flex-basis: 220px !important;
    }

    #lawn-newsletter-{{ section.id }} .newsletter-bag {
      width: 430px !important;
      right: 35px !important;
    }
  }

  @media screen and (max-width: 749px) {
    #lawn-newsletter-{{ section.id }} {
      width: calc(100vw - 28px) !important;
      max-width: calc(100vw - 28px) !important;
      height: auto !important;
      min-height: 455px !important;
      padding: 30px 22px 215px 22px !important;
      border-radius: 14px !important;
    }

    #lawn-newsletter-{{ section.id }} .newsletter-copy {
      width: 100% !important;
      max-width: 100% !important;
    }

    #lawn-newsletter-{{ section.id }} .newsletter-title {
      width: 100% !important;
      max-width: 100% !important;
      font-size: 34px !important;
      line-height: 42px !important;
      letter-spacing: -0.3px !important;
    }

    #lawn-newsletter-{{ section.id }} .newsletter-text {
      width: 100% !important;
      max-width: 100% !important;
      font-size: 14px !important;
      line-height: 22px !important;
    }

    #lawn-newsletter-{{ section.id }} .newsletter-form {
      width: 100% !important;
      max-width: 100% !important;
      height: 60px !important;
      margin-top: 26px !important;
      padding-left: 18px !important;
    }

    #lawn-newsletter-{{ section.id }} .newsletter-form input[type="email"] {
      font-size: 13px !important;
    }

    #lawn-newsletter-{{ section.id }} .newsletter-form button {
      width: 145px !important;
      min-width: 145px !important;
      flex-basis: 145px !important;
      height: 52px !important;
      font-size: 18px !important;
      line-height: 24px !important;
      padding-inline: 14px !important;
    }

    #lawn-newsletter-{{ section.id }} .newsletter-bag {
      width: 330px !important;
      right: -20px !important;
      bottom: 0 !important;
    }
  }

  @media screen and (max-width: 420px) {
    #lawn-newsletter-{{ section.id }} {
      min-height: 430px !important;
      padding: 28px 18px 198px 18px !important;
    }

    #lawn-newsletter-{{ section.id }} .newsletter-title {
      font-size: 30px !important;
      line-height: 38px !important;
    }

    #lawn-newsletter-{{ section.id }} .newsletter-form {
      height: 58px !important;
      padding-left: 16px !important;
    }

    #lawn-newsletter-{{ section.id }} .newsletter-form button {
      width: 128px !important;
      min-width: 128px !important;
      flex-basis: 128px !important;
      height: 50px !important;
      font-size: 16px !important;
    }

    #lawn-newsletter-{{ section.id }} .newsletter-bag {
      width: 292px !important;
      right: -28px !important;
    }
  }
{% endstyle %}

<section id="lawn-newsletter-{{ section.id }}" class="newsletter">
  <div class="newsletter-copy">
    <h2 class="newsletter-title">{{ heading }}</h2>

    {%- if body != blank -%}
      <p class="newsletter-text">{{ body }}</p>
    {%- endif -%}

    {%- form 'customer', class: 'newsletter-form' -%}
      <input type="hidden" name="contact[tags]" value="newsletter">

      <input
        type="email"
        name="contact[email]"
        id="LawnNewsletterEmail-{{ section.id }}"
        placeholder="{{ placeholder | escape }}"
        aria-label="{{ placeholder | escape }}"
        autocorrect="off"
        autocapitalize="off"
        autocomplete="email"
        required
      >

      <button type="submit">{{ button_label }}</button>

      {%- if form.posted_successfully? -%}
        <div class="newsletter-message">{{ success_text }}</div>
      {%- endif -%}

      {%- if form.errors -%}
        <div class="newsletter-message">{{ form.errors | default_errors }}</div>
      {%- endif -%}
    {%- endform -%}
  </div>

  {%- if bag != blank -%}
    {{
      bag
      | image_url: width: 1100
      | image_tag:
        class: 'newsletter-bag',
        loading: 'lazy',
        alt: ''
    }}
  {%- elsif section.settings.show_default_bag -%}
    <img
      class="newsletter-bag"
      src="{{ 'newsletter-bag.png' | asset_url }}"
      alt="Envy product bag"
      width="475"
      height="328"
      loading="lazy"
    >
  {%- endif -%}
</section>

{% schema %}
{
  "name": "Lawn — Newsletter",
  "tag": "section",
  "class": "lawn-newsletter-section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Grow Your Dream Lawn"
    },
    {
      "type": "textarea",
      "id": "body",
      "label": "Body text",
      "default": "Get Our FREE Lawn Care Guide Plus Expert Tips On Maintaining A Lush, Weed Free Yard."
    },
    {
      "type": "text",
      "id": "placeholder",
      "label": "Email placeholder",
      "default": "Mail Address"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Subscribe"
    },
    {
      "type": "text",
      "id": "success_text",
      "label": "Success message",
      "default": "Thanks for subscribing!"
    },
    {
      "type": "image_picker",
      "id": "bag_image",
      "label": "Product image"
    },
    {
      "type": "checkbox",
      "id": "show_default_bag",
      "label": "Show default product image when none uploaded",
      "default": true
    }
  ],
  "presets": [
    {
      "name": "Lawn — Newsletter"
    }
  ]
}
{% endschema %}